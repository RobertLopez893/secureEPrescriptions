# ─────────────────────────────────────────────────────────────────────────────
# RxPro — variables que consume docker-compose.yml.
# Copia este archivo como `.env` en la raíz del proyecto y ajusta los valores.
# Sin un `.env`, Postgres arranca con credenciales vacías y todo el stack falla.
# ─────────────────────────────────────────────────────────────────────────────

# development → siembra usuarios demo al arrancar (médico, paciente,
#               farmacéutico + admin) e imprime sus QR en los logs del backend.
# production  → no siembra nada y exige SECRET_KEY real.
APP_ENV=development

# ─── Base de datos (REQUERIDAS — sin default en docker-compose.yml) ─────────
POSTGRES_USER=rxpro
POSTGRES_PASSWORD=cambia-esta-password
POSTGRES_DB=e_prescriptions_db

# ─── CORS / red ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321
PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=4321
FRONTEND_INTERNAL_PORT=4321

# ─── Semillas demo (solo dev, opcionales) ───────────────────────────────────
# Defínelas para que los QR demo sean estables entre reinicios. Si se omiten,
# el backend genera semillas aleatorias y las imprime al stdout.
#DEMO_SEED_MEDICO=
#DEMO_SEED_FARMACEUTICO=
#DEMO_SEED_PACIENTE=
