---
import FlowLayout from '../../layouts/FlowLayout.astro'
const steps=[{label:'LOGIN',href:'/doctor'},{label:'PACIENTE',href:'/doctor/patient'},{label:'MEDICAMENTO',href:'/doctor/medication'},{label:'FIRMA',href:'/doctor/sign'}]
---
<FlowLayout title="Médico — Acceso" role="doctor" steps={steps} currentStep={0}>
<div class="anim-slide" style="display:flex;flex-direction:column;gap:20px;">
  <div style="text-align:center;">
    <div class="anim-bounce" style="display:flex;justify-content:center;margin-bottom:14px;">
      <svg width="60" height="70" viewBox="0 0 24 28" style="image-rendering:pixelated;"><use href="#ico-doctor"/></svg>
    </div>
    <h1 style="font-family:'Press Start 2P',monospace;font-size:13px;color:#f4f4f4;margin-bottom:8px;line-height:1.7;">ACCESO MÉDICO</h1>
    <p style="font-family:'VT323',monospace;font-size:22px;color:#c0cbdc;">Escanea tu tarjeta o ingresa credenciales</p>
  </div>

  <div style="background:#222639;border:3px solid #38b764;box-shadow:4px 4px 0 #257a43;padding:22px;">
    <div style="font-family:'Press Start 2P',monospace;font-size:8px;color:#38b764;margin-bottom:14px;display:flex;align-items:center;gap:8px;">
      <span class="anim-blink" style="display:inline-block;width:8px;height:8px;background:#38b764;"></span>
      LECTOR QR — TARJETA MÉDICO
    </div>

    <!-- QR scanner -->
    <div style="background:#061810;border:3px solid #38b764;position:relative;overflow:hidden;aspect-ratio:16/9;margin-bottom:18px;display:flex;align-items:center;justify-content:center;">
      <div style="position:absolute;top:10px;left:10px;width:24px;height:24px;border-top:4px solid #38b764;border-left:4px solid #38b764;"></div>
      <div style="position:absolute;top:10px;right:10px;width:24px;height:24px;border-top:4px solid #38b764;border-right:4px solid #38b764;"></div>
      <div style="position:absolute;bottom:10px;left:10px;width:24px;height:24px;border-bottom:4px solid #38b764;border-left:4px solid #38b764;"></div>
      <div style="position:absolute;bottom:10px;right:10px;width:24px;height:24px;border-bottom:4px solid #38b764;border-right:4px solid #38b764;"></div>
      <div style="position:absolute;left:18px;right:18px;height:2px;background:#38b764;box-shadow:0 0 8px #38b764;animation:px-scan 2s linear infinite;"></div>
      <div style="text-align:center;display:flex;flex-direction:column;align-items:center;gap:10px;">
        <svg width="40" height="40" viewBox="0 0 24 24" style="image-rendering:pixelated;color:#38b764;opacity:.6;">
          <rect x="0" y="0" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"/>
          <rect x="3" y="3" width="4" height="4" fill="currentColor"/>
          <rect x="14" y="0" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"/>
          <rect x="17" y="3" width="4" height="4" fill="currentColor"/>
          <rect x="0" y="14" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"/>
          <rect x="3" y="17" width="4" height="4" fill="currentColor"/>
          <rect x="12" y="12" width="2" height="2" fill="currentColor"/>
          <rect x="16" y="12" width="2" height="2" fill="currentColor"/>
          <rect x="20" y="12" width="4" height="4" fill="currentColor"/>
          <rect x="14" y="18" width="4" height="4" fill="currentColor"/>
          <rect x="20" y="20" width="4" height="4" fill="currentColor"/>
        </svg>
        <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:#38b764;" class="anim-blink">ESCANEANDO...</p>
      </div>
    </div>

    <div style="display:flex;align-items:center;gap:12px;margin-bottom:18px;">
      <div style="flex:1;height:2px;background:#29366f;"></div>
      <span style="font-family:'Press Start 2P',monospace;font-size:7px;color:#29366f;">O MANUAL</span>
      <div style="flex:1;height:2px;background:#29366f;"></div>
    </div>

    <form action="/doctor/patient" method="GET" style="display:flex;flex-direction:column;gap:14px;">
      <div>
        <label style="font-family:'Press Start 2P',monospace;font-size:8px;color:#38b764;display:block;margin-bottom:8px;">CÉDULA PROFESIONAL</label>
        <input type="text" name="cedula" placeholder="4892103" class="px-input green" required/>
      </div>
      <div>
        <label style="font-family:'Press Start 2P',monospace;font-size:8px;color:#38b764;display:block;margin-bottom:8px;">CONTRASEÑA</label>
        <input type="password" name="pw" placeholder="••••••••" class="px-input green" required/>
      </div>
      <button type="submit" class="px-btn px-btn-green px-btn-lg" style="width:100%;justify-content:center;margin-top:4px;">
        <svg width="14" height="11" viewBox="0 0 16 12" style="image-rendering:pixelated;color:white;">
          <rect x="0" y="4" width="12" height="4" fill="currentColor"/>
          <rect x="8" y="0" width="4" height="4" fill="currentColor"/>
          <rect x="8" y="8" width="4" height="4" fill="currentColor"/>
          <rect x="12" y="2" width="2" height="2" fill="currentColor"/>
          <rect x="12" y="8" width="2" height="2" fill="currentColor"/>
          <rect x="14" y="4" width="2" height="4" fill="currentColor"/>
        </svg>
        INICIAR SESIÓN
      </button>
    </form>
  </div>

  <div style="display:flex;align-items:center;justify-content:center;gap:8px;">
    <svg width="14" height="18" viewBox="0 0 20 24" style="image-rendering:pixelated;color:#29366f;"><use href="#ico-lock"/></svg>
    <p style="font-family:'Press Start 2P',monospace;font-size:7px;color:#29366f;line-height:1.8;">SESIÓN CIFRADA · ECDSA P-256 · FIPS 186-5</p>
  </div>
</div>
</FlowLayout>
