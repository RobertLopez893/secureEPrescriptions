---
import FlowLayout from '../../layouts/FlowLayout.astro'
const steps = [
  { label: 'ESCANEAR', href: '/pharmacy' },
  { label: 'VERIFICAR', href: '/pharmacy/verify' },
  { label: 'DISPENSAR', href: '/pharmacy/seal' },
]
const checks = [
  'IDENTIDAD DEL MÉDICO VERIFICADA',
  'CONTENIDO DE RECETA ÍNTEGRO',
  'DENTRO DEL PERÍODO DE VIGENCIA',
  'MÉDICO AUTORIZADO EN EL SISTEMA',
]
---
<FlowLayout title="Farmacia — Verificar" role="pharmacy" steps={steps} currentStep={1} back="/pharmacy" wide={true}>
<div class="anim-slide" style="display:flex;flex-direction:column;gap:20px;">
  <div>
    <h1 style="font-family:'Press Start 2P',monospace;font-size:13px;color:#f4f4f4;margin-bottom:6px;">VERIFICAR RECETA</h1>
    <p style="font-family:'VT323',monospace;font-size:22px;color:#c0cbdc;">Revisa la información antes de dispensar</p>
  </div>

  <!-- ── DEMO: selector de escenario ── -->
  <div style="background:#0d0e1a;border:3px dashed #29366f;padding:14px;display:flex;flex-wrap:wrap;align-items:center;gap:12px;">
    <span style="font-family:'Press Start 2P',monospace;font-size:7px;color:#29366f;flex-shrink:0;">DEMO MODE</span>
    <div style="display:flex;flex-wrap:wrap;gap:8px;">
      <button onclick="setScenario('valid')"   class="px-btn px-btn-ghost" style="font-size:7px;padding:5px 10px;" id="sc-valid">✓ VÁLIDA</button>
      <button onclick="setScenario('data')"     class="px-btn px-btn-ghost" style="font-size:7px;padding:5px 10px;" id="sc-data">⛔ DATOS INVÁLIDOS</button>
      <button onclick="setScenario('sig')"      class="px-btn px-btn-ghost" style="font-size:7px;padding:5px 10px;" id="sc-sig">⛔ FIRMA INVÁLIDA</button>
      <button onclick="setScenario('doctor')"   class="px-btn px-btn-ghost" style="font-size:7px;padding:5px 10px;" id="sc-doctor">⛔ MÉDICO NO AUTORIZADO</button>
    </div>
  </div>

  <!-- ══════════════════════════════════
       VISTA PRINCIPAL (grid 2 columnas)
  ══════════════════════════════════ -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">

    <!-- LEFT: detalles de la receta -->
    <div style="display:flex;flex-direction:column;gap:12px;">

      <!-- Paciente -->
      <div style="background:#0d1a2e;border:3px solid #41a6f6;box-shadow:4px 4px 0 #1a6eb0;padding:16px;display:flex;align-items:center;gap:12px;">
        <span style="font-size:36px;flex-shrink:0;">🧑‍💼</span>
        <div>
          <p style="font-family:'Press Start 2P',monospace;font-size:9px;color:#41a6f6;">GARCÍA MENDOZA, LUIS</p>
          <p id="curp-display" style="font-family:'VT323',monospace;font-size:19px;color:#c0cbdc;margin-top:4px;">GARM850315HDFNDS07</p>
          <p style="font-family:'VT323',monospace;font-size:18px;color:#5b6ee1;">FOLIO XYZ-123 · 20 MAR 2026</p>
        </div>
      </div>

      <!-- Prescripción -->
      <div id="rx-card" style="background:#222639;border:3px solid #e8003d;box-shadow:4px 4px 0 #8c0025;overflow:hidden;">
        <div style="background:#e8003d;padding:8px 14px;">
          <span style="font-family:'Press Start 2P',monospace;font-size:7px;color:white;">💊 PRESCRIPCIÓN</span>
        </div>
        <div style="padding:16px;">
          {[
            { l: 'MEDICAMENTO',   v: 'Amoxicilina',                     big: true },
            { l: 'DOSIS',         v: '500 mg · Cápsula' },
            { l: 'CANTIDAD',      v: '21 cápsulas' },
            { l: 'INSTRUCCIONES', v: '1 cápsula c/8h con alimentos, 7 días.' },
            { l: 'VIGENCIA',      v: '28 días restantes' },
            { l: 'MÉDICO',        v: 'Dr. Eduardo Ramírez' },
          ].map(f => (
            <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:2px solid #29366f;gap:8px;">
              <span style="font-family:'Press Start 2P',monospace;font-size:6px;color:#5b6ee1;flex-shrink:0;width:80px;">{f.l}</span>
              <span style={'text-align:right;font-family:\'VT323\',monospace;font-size:'+(f.big?'22px':'19px')+';color:'+(f.big?'#f4f4f4':'#c0cbdc')+';'}>{f.v}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Doctor chip -->
      <div id="doctor-chip" style="background:#1a2e1a;border:3px solid #38b764;padding:12px;display:flex;align-items:center;gap:10px;">
        <span style="font-size:24px;">👨‍⚕️</span>
        <div>
          <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:#38b764;">DR. EDUARDO RAMÍREZ</p>
          <p style="font-family:'VT323',monospace;font-size:18px;color:#c0cbdc;margin-top:3px;">Cédula 4892103 · Hospital Central · <span id="doctor-auth-label">AUTORIZADO ✓</span></p>
        </div>
      </div>
    </div>

    <!-- RIGHT: panel de resultado -->
    <div style="display:flex;flex-direction:column;gap:12px;">

      <!-- ── ESTADO: VÁLIDO ── -->
      <div id="state-valid" style="background:#1a2e1a;border:4px solid #38b764;box-shadow:6px 6px 0 #257a43;padding:28px;text-align:center;flex:1;display:flex;flex-direction:column;align-items:center;">
        <div class="anim-float" style="margin-bottom:16px;">
          <svg width="80" height="96" viewBox="0 0 20 24" style="image-rendering:pixelated;">
            <rect x="2" y="0" width="16" height="2" fill="#38b764"/>
            <rect x="0" y="2" width="20" height="14" fill="#38b764"/>
            <rect x="1" y="16" width="18" height="2" fill="#38b764"/>
            <rect x="2" y="18" width="16" height="2" fill="#38b764"/>
            <rect x="4" y="20" width="12" height="2" fill="#38b764"/>
            <rect x="6" y="22" width="8"  height="2" fill="#38b764"/>
            <rect x="8" y="24" width="4"  height="2" fill="#38b764"/>
            <rect x="2" y="0" width="16" height="4" fill="rgba(255,255,255,.3)"/>
            <rect x="4"  y="10" width="4" height="4" fill="white"/>
            <rect x="8"  y="12" width="4" height="2" fill="white"/>
            <rect x="10" y="8"  width="4" height="4" fill="white"/>
            <rect x="12" y="6"  width="4" height="2" fill="white"/>
            <rect x="14" y="4"  width="2" height="2" fill="white"/>
            <rect x="3"  y="3"  width="14" height="12" fill="none" stroke="rgba(255,255,255,.3)" stroke-width="1"/>
          </svg>
        </div>
        <h2 style="font-family:'Press Start 2P',monospace;font-size:11px;color:#38b764;line-height:1.7;margin-bottom:8px;">
          SELLO CRIPTOGRÁFICO<br/>VÁLIDO
        </h2>
        <p style="font-family:'VT323',monospace;font-size:20px;color:#c0cbdc;margin-bottom:20px;line-height:1.4;">
          La firma del médico es auténtica y la receta no fue modificada
        </p>
        <div style="width:100%;background:#222639;border:2px solid #38b764;padding:14px;text-align:left;">
          {checks.map(c => (
            <div style="display:flex;align-items:flex-start;gap:8px;padding:6px 0;border-bottom:1px solid #29366f;">
              <span style="color:#38b764;font-family:'Press Start 2P',monospace;font-size:8px;margin-top:2px;flex-shrink:0;">✓</span>
              <span style="font-family:'Press Start 2P',monospace;font-size:7px;color:#c0cbdc;line-height:1.7;">{c}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- ── ESTADO: DATOS INVÁLIDOS ── -->
      <div id="state-data" style="display:none;background:#2a0d0d;border:4px solid #e8003d;box-shadow:6px 6px 0 #8c0025;padding:28px;text-align:center;flex:1;flex-direction:column;align-items:center;">
        <!-- Pixel shield roto -->
        <div class="anim-bounce" style="margin-bottom:16px;">
          <svg width="80" height="96" viewBox="0 0 20 24" style="image-rendering:pixelated;">
            <rect x="2" y="0" width="16" height="2" fill="#e8003d"/>
            <rect x="0" y="2" width="20" height="14" fill="#e8003d"/>
            <rect x="1" y="16" width="18" height="2" fill="#e8003d"/>
            <rect x="2" y="18" width="16" height="2" fill="#e8003d"/>
            <rect x="4" y="20" width="12" height="2" fill="#e8003d"/>
            <!-- X en el escudo -->
            <rect x="5"  y="5"  width="3" height="3" fill="white"/>
            <rect x="12" y="5"  width="3" height="3" fill="white"/>
            <rect x="7"  y="7"  width="3" height="3" fill="white"/>
            <rect x="10" y="7"  width="3" height="3" fill="white"/>
            <rect x="8"  y="9"  width="4" height="2" fill="white"/>
            <rect x="7"  y="11" width="3" height="3" fill="white"/>
            <rect x="10" y="11" width="3" height="3" fill="white"/>
            <rect x="5"  y="13" width="3" height="3" fill="white"/>
            <rect x="12" y="13" width="3" height="3" fill="white"/>
            <!-- Grietas -->
            <rect x="3"  y="3"  width="1" height="6" fill="#8c0025" opacity=".7"/>
            <rect x="15" y="9"  width="1" height="5" fill="#8c0025" opacity=".7"/>
          </svg>
        </div>
        <h2 style="font-family:'Press Start 2P',monospace;font-size:10px;color:#e8003d;line-height:1.7;margin-bottom:8px;">
          DATOS INVÁLIDOS<br/>O MANIPULADOS
        </h2>
        <p style="font-family:'VT323',monospace;font-size:20px;color:#c0cbdc;margin-bottom:20px;line-height:1.4;">
          El contenido de la receta fue alterado después de ser firmado.<br/>
          <strong style="color:#ffcd75;">No dispensar este medicamento.</strong>
        </p>
        <div style="width:100%;background:#1a0505;border:2px solid #e8003d;padding:14px;text-align:left;">
          {[
            { label: 'FIRMA ECDSA',   ok: true  },
            { label: 'HASH SHA-256',  ok: false },
            { label: 'INTEGRIDAD',    ok: false },
            { label: 'MÉDICO AUTH',   ok: true  },
          ].map(c => (
            <div style="display:flex;align-items:flex-start;gap:8px;padding:6px 0;border-bottom:1px solid #29366f;">
              <span style={'color:'+(c.ok?'#38b764':'#e8003d')+';font-family:\'Press Start 2P\',monospace;font-size:8px;margin-top:2px;flex-shrink:0;'}>{c.ok ? '✓' : '✗'}</span>
              <span style={'font-family:\'Press Start 2P\',monospace;font-size:7px;color:'+(c.ok?'#c0cbdc':'#e8003d')+';line-height:1.7;'}>{c.label}{!c.ok ? ' — FALLO' : ''}</span>
            </div>
          ))}
        </div>
        <div style="width:100%;background:#1a0d0d;border:2px solid #e8003d;padding:12px;margin-top:12px;text-align:left;">
          <p style="font-family:'Press Start 2P',monospace;font-size:7px;color:#e8003d;margin-bottom:6px;">DETALLE TÉCNICO</p>
          <p style="font-family:'VT323',monospace;font-size:17px;color:#c0cbdc;line-height:1.5;word-break:break-all;">
            Hash esperado: <span style="color:#ffcd75;">a3f8c0…d4e1</span><br/>
            Hash recibido: <span style="color:#e8003d;">7b2a11…99fc</span>
          </p>
        </div>
      </div>

      <!-- ── ESTADO: FIRMA INVÁLIDA ── -->
      <div id="state-sig" style="display:none;background:#2a0d0d;border:4px solid #e8003d;box-shadow:6px 6px 0 #8c0025;padding:28px;text-align:center;flex:1;flex-direction:column;align-items:center;">
        <div class="anim-bounce" style="margin-bottom:16px;">
          <svg width="80" height="96" viewBox="0 0 20 24" style="image-rendering:pixelated;">
            <rect x="2" y="0" width="16" height="2" fill="#e8003d"/>
            <rect x="0" y="2" width="20" height="14" fill="#e8003d"/>
            <rect x="1" y="16" width="18" height="2" fill="#e8003d"/>
            <rect x="2" y="18" width="16" height="2" fill="#e8003d"/>
            <rect x="4" y="20" width="12" height="2" fill="#e8003d"/>
            <!-- ? en el escudo -->
            <rect x="8"  y="4"  width="4"  height="2" fill="white"/>
            <rect x="12" y="6"  width="2"  height="4" fill="white"/>
            <rect x="10" y="10" width="2"  height="2" fill="white"/>
            <rect x="9"  y="14" width="2"  height="2" fill="white"/>
          </svg>
        </div>
        <h2 style="font-family:'Press Start 2P',monospace;font-size:10px;color:#e8003d;line-height:1.7;margin-bottom:8px;">
          FIRMA DIGITAL<br/>INVÁLIDA
        </h2>
        <p style="font-family:'VT323',monospace;font-size:20px;color:#c0cbdc;margin-bottom:20px;line-height:1.4;">
          La firma ECDSA no pudo verificarse.<br/>
          La receta puede ser falsa o estar expirada.<br/>
          <strong style="color:#ffcd75;">No dispensar este medicamento.</strong>
        </p>
        <div style="width:100%;background:#1a0505;border:2px solid #e8003d;padding:14px;text-align:left;">
          {[
            { label: 'FIRMA ECDSA',   ok: false },
            { label: 'HASH SHA-256',  ok: true  },
            { label: 'CERTIFICADO',   ok: false },
            { label: 'MÉDICO AUTH',   ok: true  },
          ].map(c => (
            <div style="display:flex;align-items:flex-start;gap:8px;padding:6px 0;border-bottom:1px solid #29366f;">
              <span style={'color:'+(c.ok?'#38b764':'#e8003d')+';font-family:\'Press Start 2P\',monospace;font-size:8px;margin-top:2px;flex-shrink:0;'}>{c.ok ? '✓' : '✗'}</span>
              <span style={'font-family:\'Press Start 2P\',monospace;font-size:7px;color:'+(c.ok?'#c0cbdc':'#e8003d')+';line-height:1.7;'}>{c.label}{!c.ok ? ' — FALLO' : ''}</span>
            </div>
          ))}
        </div>
        <div style="width:100%;background:#1a0d0d;border:2px solid #e8003d;padding:12px;margin-top:12px;text-align:left;">
          <p style="font-family:'Press Start 2P',monospace;font-size:7px;color:#e8003d;margin-bottom:6px;">CÓDIGO DE ERROR</p>
          <p style="font-family:'VT323',monospace;font-size:17px;color:#c0cbdc;line-height:1.5;">
            ECDSA_VERIFY_FAILED · Clave pública no coincide con la firma.<br/>
            Posible causa: receta generada con credenciales revocadas.
          </p>
        </div>
      </div>

      <!-- ── ESTADO: MÉDICO NO AUTORIZADO ── -->
      <div id="state-doctor" style="display:none;background:#1a0d00;border:4px solid #ffcd75;box-shadow:6px 6px 0 #c48c00;padding:28px;text-align:center;flex:1;flex-direction:column;align-items:center;">
        <div class="anim-bounce" style="margin-bottom:16px;">
          <svg width="80" height="96" viewBox="0 0 20 24" style="image-rendering:pixelated;">
            <rect x="2" y="0" width="16" height="2" fill="#ffcd75"/>
            <rect x="0" y="2" width="20" height="14" fill="#ffcd75"/>
            <rect x="1" y="16" width="18" height="2" fill="#ffcd75"/>
            <rect x="2" y="18" width="16" height="2" fill="#ffcd75"/>
            <rect x="4" y="20" width="12" height="2" fill="#ffcd75"/>
            <!-- ! en el escudo -->
            <rect x="9" y="4"  width="2" height="8" fill="#1a0d00"/>
            <rect x="9" y="14" width="2" height="2" fill="#1a0d00"/>
          </svg>
        </div>
        <h2 style="font-family:'Press Start 2P',monospace;font-size:10px;color:#ffcd75;line-height:1.7;margin-bottom:8px;">
          MÉDICO NO<br/>AUTORIZADO
        </h2>
        <p style="font-family:'VT323',monospace;font-size:20px;color:#c0cbdc;margin-bottom:20px;line-height:1.4;">
          La firma es técnicamente válida, pero el médico<br/>
          no está registrado o tiene la cédula suspendida.<br/>
          <strong style="color:#ffcd75;">Contactar a la autoridad sanitaria.</strong>
        </p>
        <div style="width:100%;background:#12090a;border:2px solid #ffcd75;padding:14px;text-align:left;">
          {[
            { label: 'FIRMA ECDSA',        ok: true  },
            { label: 'HASH SHA-256',        ok: true  },
            { label: 'MÉDICO REGISTRADO',   ok: false },
            { label: 'CÉDULA VIGENTE',      ok: false },
          ].map(c => (
            <div style="display:flex;align-items:flex-start;gap:8px;padding:6px 0;border-bottom:1px solid #29366f;">
              <span style={'color:'+(c.ok?'#38b764':'#e8003d')+';font-family:\'Press Start 2P\',monospace;font-size:8px;margin-top:2px;flex-shrink:0;'}>{c.ok ? '✓' : '✗'}</span>
              <span style={'font-family:\'Press Start 2P\',monospace;font-size:7px;color:'+(c.ok?'#c0cbdc':'#ffcd75')+';line-height:1.7;'}>{c.label}{!c.ok ? ' — SUSPENDIDO' : ''}</span>
            </div>
          ))}
        </div>
        <div style="width:100%;background:#12090a;border:2px solid #ffcd75;padding:12px;margin-top:12px;text-align:left;">
          <p style="font-family:'Press Start 2P',monospace;font-size:7px;color:#ffcd75;margin-bottom:6px;">ESTADO DE CÉDULA</p>
          <p style="font-family:'VT323',monospace;font-size:17px;color:#c0cbdc;line-height:1.5;">
            Cédula 4892103 — Suspensión administrativa desde<br/>
            15 FEB 2026 · COFEPRIS Expediente #2026-0421
          </p>
        </div>
      </div>

      <!-- Botones de acción -->
      <div id="action-valid" style="display:flex;flex-direction:column;gap:8px;">
        <a href="/pharmacy/seal" class="px-btn px-btn-red px-btn-lg" style="width:100%;justify-content:center;text-decoration:none;font-size:10px;">
          💊 PROCEDER A DISPENSAR
        </a>
        <a href="/pharmacy" class="px-btn px-btn-ghost" style="width:100%;justify-content:center;text-decoration:none;">
          ✕ CANCELAR
        </a>
      </div>

      <div id="action-error" style="display:none;flex-direction:column;gap:8px;">
        <a href="/pharmacy" class="px-btn px-btn-red" style="width:100%;justify-content:center;text-decoration:none;font-size:9px;background:#2a0d0d;border-color:#e8003d;">
          ⛔ RECHAZAR RECETA
        </a>
        <a href="/pharmacy" class="px-btn px-btn-ghost" style="width:100%;justify-content:center;text-decoration:none;">
          ◄ ESCANEAR OTRA
        </a>
      </div>

      <div id="action-warn" style="display:none;flex-direction:column;gap:8px;">
        <button type="button" onclick="reportDoctor()" class="px-btn px-btn-yellow" style="width:100%;justify-content:center;font-size:9px;">
          ⚠ REPORTAR A COFEPRIS
        </button>
        <a href="/pharmacy" class="px-btn px-btn-ghost" style="width:100%;justify-content:center;text-decoration:none;">
          ◄ ESCANEAR OTRA
        </a>
      </div>

    </div>
  </div>
</div>
</FlowLayout>

<script>
const SCENARIOS = {
  valid:  { state: 'state-valid',  action: 'action-valid',  dcChip: '#38b764', dcLabel: 'AUTORIZADO ✓',     dcBg: '#1a2e1a' },
  data:   { state: 'state-data',   action: 'action-error',  dcChip: '#38b764', dcLabel: 'AUTORIZADO ✓',     dcBg: '#1a2e1a' },
  sig:    { state: 'state-sig',    action: 'action-error',  dcChip: '#e8003d', dcLabel: 'VERIFICACIÓN FALLO', dcBg:'#2a0d0d' },
  doctor: { state: 'state-doctor', action: 'action-warn',   dcChip: '#ffcd75', dcLabel: 'SUSPENDIDO ⚠',    dcBg: '#1a0d00' },
}

const ALL_STATES  = ['state-valid', 'state-data', 'state-sig', 'state-doctor']
const ALL_ACTIONS = ['action-valid', 'action-error', 'action-warn']
const ALL_SCS     = ['sc-valid', 'sc-data', 'sc-sig', 'sc-doctor']

function setScenario(key) {
  const sc = SCENARIOS[key]

  // Activar estado correcto
  ALL_STATES.forEach(id => {
    const el = document.getElementById(id)
    if (el) el.style.display = id === sc.state ? 'flex' : 'none'
  })
  ALL_ACTIONS.forEach(id => {
    const el = document.getElementById(id)
    if (el) el.style.display = id === sc.action ? 'flex' : 'none'
  })

  // Actualizar doctor chip
  const chip  = document.getElementById('doctor-chip')
  const label = document.getElementById('doctor-auth-label')
  if (chip)  { chip.style.borderColor  = sc.dcChip; chip.style.background = sc.dcBg }
  if (label) { label.textContent = sc.dcLabel; label.style.color = sc.dcChip }

  // Resaltar botón activo
  ALL_SCS.forEach(id => {
    const btn = document.getElementById(id)
    if (btn) {
      const active = id === 'sc-' + key
      btn.style.borderColor  = active ? '#f4f4f4' : '#29366f'
      btn.style.color        = active ? '#f4f4f4' : '#5b6ee1'
    }
  })
}

function reportDoctor() {
  const btn = event.currentTarget
  btn.textContent = '⏳ ENVIANDO REPORTE...'
  btn.disabled    = true
  btn.style.opacity = '.7'
  setTimeout(() => {
    btn.textContent  = '✓ REPORTE ENVIADO A COFEPRIS'
    btn.style.color  = '#38b764'
    btn.style.borderColor = '#38b764'
    btn.style.opacity = '1'
  }, 800)
}

// Iniciar en modo válido
setScenario('valid')
</script>
