---
import FlowLayout from '../../layouts/FlowLayout.astro'
const steps=[{label:'LOGIN',href:'/doctor'},{label:'PACIENTE',href:'/doctor/patient'},{label:'MEDICAMENTOS',href:'/doctor/medication'},{label:'FIRMA',href:'/doctor/sign'}]
---
<FlowLayout title="Médico — Medicamentos" role="doctor" steps={steps} currentStep={2} back="/doctor/patient">
<div class="anim-slide" style="display:flex;flex-direction:column;gap:20px;">

  <!-- Header -->
  <div>
    <h1 style="font-family:'Press Start 2P',monospace;font-size:13px;color:var(--text-primary);margin-bottom:6px;">PRESCRIPCIÓN</h1>
    <p style="font-family:'VT323',monospace;font-size:22px;color:var(--text-muted);">Agrega los medicamentos a recetar</p>
  </div>

  <!-- Contador -->
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;">
    <div style="display:flex;align-items:center;gap:10px;">
      <span style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--role-doctor);">MEDICAMENTOS:</span>
      <span id="med-count-badge"
            style="font-family:'Press Start 2P',monospace;font-size:10px;color:var(--accent-warn);border:2px solid var(--accent-warn);padding:2px 10px;">
        0 / 5
      </span>
    </div>
    <span style="font-family:'VT323',monospace;font-size:17px;color:var(--text-subtle);">NOM-004-SSA3 · máx 5 por receta</span>
  </div>

  <!-- Aviso de límite -->
  <div id="limit-warning"
       style="display:none;background:#1a0a0a;border:3px solid var(--role-pharmacy);padding:14px 16px;gap:12px;align-items:flex-start;">
    <svg width="20" height="20" viewBox="0 0 20 20" style="image-rendering:pixelated;color:var(--role-pharmacy);flex-shrink:0;">
      <rect x="8" y="0" width="4" height="12" fill="currentColor"/>
      <rect x="8" y="14" width="4" height="4" fill="currentColor"/>
    </svg>
    <div>
      <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--role-pharmacy);margin-bottom:6px;line-height:1.8;">
        PRESCRIPCIÓN COMPLETA (5/5)
      </p>
      <p style="font-family:'VT323',monospace;font-size:19px;color:var(--text-muted);line-height:1.5;">
        Alcanzaste el límite por NOM-004-SSA3. Si necesitas más medicamentos, emite una nueva receta.
      </p>
    </div>
  </div>

  <!-- Tarjetas de medicamentos (JS las inserta aquí) -->
  <div id="meds-container" style="display:flex;flex-direction:column;gap:14px;"></div>

  <!-- Botón AGREGAR -->
  <button type="button" id="add-med-btn"
          style="width:100%;padding:12px;background:transparent;border:3px dashed var(--role-doctor);
                 font-family:'Press Start 2P',monospace;font-size:9px;color:var(--role-doctor);cursor:pointer;
                 display:flex;align-items:center;justify-content:center;gap:10px;">
    <span style="font-size:18px;line-height:1;">＋</span>
    AGREGAR MEDICAMENTO
  </button>

  <!-- Campos globales -->
  <div style="background:var(--surface-card);border:3px solid var(--role-doctor);box-shadow:4px 4px 0 var(--role-doctor-d);padding:20px;">
    <div style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--role-doctor);margin-bottom:16px;display:flex;align-items:center;gap:8px;">
      <span class="anim-blink" style="display:inline-block;width:7px;height:7px;background:var(--role-doctor);"></span>
      DATOS DE EMISIÓN
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
      <div>
        <label class="px-label" style="color:var(--role-doctor);">FECHA EMISIÓN</label>
        <input type="date" id="g-date" class="px-input green"/>
      </div>
      <div>
        <label class="px-label" style="color:var(--role-doctor);">VIGENCIA (DÍAS)</label>
        <input type="number" id="g-validity" value="30" min="1" max="365" class="px-input green"/>
      </div>
    </div>
  </div>

  <!-- Preview -->
  <div style="background:#1a2e1a;border:3px solid var(--role-doctor);padding:16px;">
    <div style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--role-doctor);margin-bottom:12px;opacity:.7;">
      PREVISUALIZACIÓN DE RECETA
    </div>
    <div id="preview-list" style="display:flex;flex-direction:column;gap:10px;">
      <p style="font-family:'VT323',monospace;font-size:18px;color:var(--text-subtle);">Agrega medicamentos para verlos aquí...</p>
    </div>
  </div>

  <!-- Botón FIRMAR -->
  <button type="button" id="submit-btn" class="px-btn px-btn-green px-btn-lg"
          style="width:100%;justify-content:center;">
    ► REVISAR Y FIRMAR
  </button>

</div>
</FlowLayout>

<script>
import { requireSession } from '../../utils/sessionGuard.ts'
requireSession('Medico', '/doctor')

// ─────────────────────────────────────────────────────────────────────────────
// IMPORTANTE: Este script pasa por Vite/TypeScript — NO usar define:vars
// MAX_MEDS está fijado aquí directamente (NOM-004-SSA3)
// ─────────────────────────────────────────────────────────────────────────────
const MAX_MEDS = 5

const FORMAS = [
  'CÁPSULA','TABLETA','GRAGEA','SOLUCIÓN ORAL','JARABE',
  'INYECTABLE','CREMA','UNGÜENTO','GEL','GOTAS','SPRAY','PARCHE','POLVO',
]

// ── Estado ────────────────────────────────────────────────────────────────
let medications: number[] = []
let nextId = 1

// ── DOM ───────────────────────────────────────────────────────────────────
const container    = document.getElementById('meds-container')!
const addBtn       = document.getElementById('add-med-btn')   as HTMLButtonElement
const submitBtn    = document.getElementById('submit-btn')    as HTMLButtonElement
const countBadge   = document.getElementById('med-count-badge')!
const limitWarning = document.getElementById('limit-warning') as HTMLDivElement
const previewList  = document.getElementById('preview-list')!
const gDate        = document.getElementById('g-date')        as HTMLInputElement
const gValidity    = document.getElementById('g-validity')    as HTMLInputElement

// Fecha de hoy por defecto
gDate.value = new Date().toISOString().split('T')[0]

// ── Crear HTML de una tarjeta ─────────────────────────────────────────────
function buildCard(id: number): HTMLElement {
  const card = document.createElement('div')
  card.id = `med-card-${id}`
  card.style.cssText = [
    'background:#222639',
    'border:3px solid #38b764',
    'box-shadow:4px 4px 0 #257a43',
    'padding:20px',
  ].join(';')

  const removeBtn = id > 1
    ? `<button type="button" data-remove="${id}"
         style="background:transparent;border:2px solid #e8003d;padding:4px 8px;
                font-family:'Press Start 2P',monospace;font-size:7px;color:#e8003d;cursor:pointer;">
         ✕ QUITAR
       </button>`
    : ''

  const options = FORMAS.map(f => `<option value="${f}">${f}</option>`).join('')

  card.innerHTML = `
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <span style="background:#38b764;color:#1a1c2c;padding:3px 8px;
                   font-family:'Press Start 2P',monospace;font-size:8px;">MED #${id}</span>
      ${removeBtn}
    </div>

    <div style="display:flex;flex-direction:column;gap:14px;">

      <div>
        <label class="px-label" style="color:var(--role-doctor);">MEDICAMENTO *</label>
        <input id="m${id}-name" type="text" class="px-input green"
               placeholder="Amoxicilina, Ibuprofeno, Metformina..."
               autocomplete="off" required/>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div>
          <label class="px-label" style="color:var(--role-doctor);">DOSIS *</label>
          <input id="m${id}-dose" type="text" class="px-input green"
                 placeholder="500 mg, 10 ml, 1 g..." required/>
        </div>
        <div>
          <label class="px-label" style="color:var(--role-doctor);">FORMA FARMACÉUTICA *</label>
          <select id="m${id}-form" class="px-input green">
            <option value="">SELECCIONAR...</option>
            ${options}
          </select>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div>
          <label class="px-label" style="color:var(--role-doctor);">CANTIDAD *</label>
          <input id="m${id}-qty" type="number" class="px-input green"
                 placeholder="14" min="1" required/>
        </div>
        <div>
          <label class="px-label" style="color:var(--role-doctor);">RECARGAS</label>
          <input id="m${id}-refills" type="number" class="px-input green"
                 placeholder="0" min="0" max="5" value="0"/>
        </div>
      </div>

      <div>
        <label class="px-label" style="color:var(--role-doctor);">INSTRUCCIONES *</label>
        <textarea id="m${id}-instr" rows="2" class="px-input green"
                  placeholder="Tomar 1 cápsula cada 8 horas con alimentos..." required></textarea>
      </div>
    </div>
  `

  // Listeners de inputs para preview en tiempo real
  const fields = [`m${id}-name`, `m${id}-dose`, `m${id}-form`, `m${id}-qty`, `m${id}-instr`]
  fields.forEach(fid => {
    document.getElementById(fid)?.addEventListener('input', syncPreview)
    document.getElementById(fid)?.addEventListener('change', syncPreview)
  })

  // Listener del botón quitar
  card.querySelector('[data-remove]')?.addEventListener('click', (e) => {
    const btn = e.currentTarget as HTMLElement
    const removeId = Number(btn.dataset.remove)
    removeMed(removeId)
  })

  return card
}

// ── Agregar medicamento ───────────────────────────────────────────────────
function addMed() {
  if (medications.length >= MAX_MEDS) return
  const id = nextId++
  medications.push(id)
  container.appendChild(buildCard(id))
  updateUI()
  syncPreview()
  document.getElementById(`med-card-${id}`)?.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
}

// ── Quitar medicamento ────────────────────────────────────────────────────
function removeMed(id: number) {
  medications = medications.filter(m => m !== id)
  document.getElementById(`med-card-${id}`)?.remove()
  updateUI()
  syncPreview()
}

// ── Actualizar badge y controles ──────────────────────────────────────────
function updateUI() {
  const count = medications.length
  countBadge.textContent = `${count} / ${MAX_MEDS}`

  if (count >= MAX_MEDS) {
    countBadge.setAttribute('style',
      'font-family:\'Press Start 2P\',monospace;font-size:10px;color:#e8003d;border:2px solid #e8003d;padding:2px 10px;')
    addBtn.style.display    = 'none'
    limitWarning.style.display = 'flex'
  } else {
    countBadge.setAttribute('style',
      'font-family:\'Press Start 2P\',monospace;font-size:10px;color:#ffcd75;border:2px solid #ffcd75;padding:2px 10px;')
    addBtn.style.display    = 'flex'
    limitWarning.style.display = 'none'
  }
}

// ── Preview en tiempo real ────────────────────────────────────────────────
// Se construye con DOM API (no innerHTML) para que los valores que el
// doctor escribe en los inputs no puedan interpretarse como HTML/JS al
// pintarlos en el preview.
function syncPreview() {
  previewList.replaceChildren()

  if (medications.length === 0) {
    const empty = document.createElement('p')
    empty.style.cssText = "font-family:'VT323',monospace;font-size:18px;color:#29366f;"
    empty.textContent = 'Agrega medicamentos para verlos aquí...'
    previewList.appendChild(empty)
    return
  }

  medications.forEach((id, idx) => {
    const nameEl  = document.getElementById(`m${id}-name`)  as HTMLInputElement   | null
    const doseEl  = document.getElementById(`m${id}-dose`)  as HTMLInputElement   | null
    const formEl  = document.getElementById(`m${id}-form`)  as HTMLSelectElement  | null
    const qtyEl   = document.getElementById(`m${id}-qty`)   as HTMLInputElement   | null
    const instrEl = document.getElementById(`m${id}-instr`) as HTMLTextAreaElement| null

    const name  = nameEl?.value.trim()  || '—'
    const dose  = doseEl?.value.trim()  || '?'
    const form  = formEl?.value         || '?'
    const qty   = qtyEl?.value.trim()   || '?'
    const instr = instrEl?.value.trim() || ''

    const row = document.createElement('div')
    row.style.cssText = 'display:flex;align-items:flex-start;gap:12px;padding-bottom:10px;border-bottom:2px solid #1a3a1a;'

    const num = document.createElement('span')
    num.style.cssText = "font-family:'Press Start 2P',monospace;font-size:9px;color:#38b764;flex-shrink:0;margin-top:2px;"
    num.textContent = String(idx + 1).padStart(2, '0')

    const body = document.createElement('div')
    body.style.cssText = 'flex:1;'

    const title = document.createElement('div')
    title.style.cssText = "font-family:'Press Start 2P',monospace;font-size:8px;color:#f4f4f4;margin-bottom:4px;"
    title.textContent = name

    const meta = document.createElement('div')
    meta.style.cssText = "font-family:'VT323',monospace;font-size:19px;color:#c0cbdc;"
    meta.textContent = `${dose} · ${form} · ${qty} unidades`

    body.append(title, meta)

    if (instr) {
      const instrEl = document.createElement('div')
      instrEl.style.cssText = "font-family:'VT323',monospace;font-size:17px;color:#637087;margin-top:2px;"
      instrEl.textContent = instr
      body.appendChild(instrEl)
    }

    row.append(num, body)
    previewList.appendChild(row)
  })
}

// ── Validar y pasar a firma ───────────────────────────────────────────────
submitBtn.addEventListener('click', () => {
  if (medications.length === 0) {
    window.showToast('Agrega al menos un medicamento', '#e8003d')
    return
  }

  const meds: Array<{nombre:string;dosis:string;frecuencia:string;duracion:string}> = []
  let firstInvalid = -1

  for (const id of medications) {
    const name  = (document.getElementById(`m${id}-name`)  as HTMLInputElement)?.value.trim()
    const dose  = (document.getElementById(`m${id}-dose`)  as HTMLInputElement)?.value.trim()
    const form  = (document.getElementById(`m${id}-form`)  as HTMLSelectElement)?.value
    const qty   = (document.getElementById(`m${id}-qty`)   as HTMLInputElement)?.value.trim()
    const instr = (document.getElementById(`m${id}-instr`) as HTMLTextAreaElement)?.value.trim()

    if (!name || !dose || !form || !qty || !instr) {
      if (firstInvalid < 0) firstInvalid = id
      const card = document.getElementById(`med-card-${id}`)
      if (card) {
        card.style.borderColor = '#e8003d'
        setTimeout(() => { card.style.borderColor = '#38b764' }, 2000)
      }
    } else {
      meds.push({
        nombre:     `${name} ${dose} ${form}`,
        dosis:      `${dose} · ${form}`,
        frecuencia: instr,
        duracion:   `${gValidity.value} días`,
      })
    }
  }

  if (firstInvalid >= 0) {
    document.getElementById(`med-card-${firstInvalid}`)
      ?.scrollIntoView({ behavior: 'smooth', block: 'start' })
    window.showToast('Completa todos los campos marcados con *', '#e8003d')
    return
  }

  sessionStorage.setItem('rxpro_receta', JSON.stringify({
    medicamentos:  meds,
    fecha_emision: gDate.value,
    vigencia_dias: gValidity.value,
  }))

  submitBtn.textContent = 'PROCESANDO...'
  submitBtn.setAttribute('disabled', '')
  window.location.href = '/doctor/sign'
})

// Botón agregar
addBtn.addEventListener('click', addMed)

// ── Init ──────────────────────────────────────────────────────────────────
addMed()
</script>
