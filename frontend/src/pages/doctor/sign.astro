---
import FlowLayout from '../../layouts/FlowLayout.astro'
const steps = [
  { label: 'LOGIN',       href: '/doctor' },
  { label: 'PACIENTE',    href: '/doctor/patient' },
  { label: 'MEDICAMENTO', href: '/doctor/medication' },
  { label: 'FIRMA',       href: '/doctor/sign' },
]
const rows = [
  { l: 'PACIENTE',      v: 'García Mendoza, Luis' },
  { l: 'CURP',          v: 'GARM850315HDFNDS07' },
  { l: 'MEDICAMENTO',   v: 'Amoxicilina', big: true },
  { l: 'DOSIS',         v: '500 mg · Cápsula' },
  { l: 'CANTIDAD',      v: '21 cápsulas' },
  { l: 'INSTRUCCIONES', v: '1 cápsula c/8h con alimentos, 7 días.' },
  { l: 'VIGENCIA',      v: '30 días desde hoy' },
]
---
<FlowLayout title="Médico — Firma" role="doctor" steps={steps} currentStep={3} back="/doctor/medication">
<div class="anim-slide" style="display:flex;flex-direction:column;gap:20px;">

  <div>
    <h1 style="font-family:'Press Start 2P',monospace;font-size:13px;color:var(--text-primary);margin-bottom:6px;">REVISAR Y FIRMAR</h1>
    <p style="font-family:'VT323',monospace;font-size:22px;color:var(--accent-warn);">Una vez firmada, la receta no puede modificarse.</p>
  </div>

  <!-- Resumen receta -->
  <div style="background:var(--surface-card);border:3px solid var(--role-doctor);box-shadow:4px 4px 0 var(--role-doctor-d);padding:0;overflow:hidden;">
    <div style="background:var(--role-doctor);padding:10px 16px;">
      <span style="font-family:'Press Start 2P',monospace;font-size:8px;color:#1a1c2c;">📋 RESUMEN DE RECETA</span>
    </div>
    <div style="padding:20px;">
      {rows.map(f => (
        <div style="display:flex;justify-content:space-between;align-items:flex-start;padding:10px 0;border-bottom:2px solid var(--border-default);gap:12px;">
          <span style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--text-dim);flex-shrink:0;width:100px;">{f.l}</span>
          <span style={'text-align:right;font-family:'+(f.big?'"Press Start 2P"':'"VT323"')+',monospace;font-size:'+(f.big?'11px':'21px')+';color:'+(f.big?'var(--role-doctor)':'var(--text-primary)')+';'}>{f.v}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ① JSON Canonicalizado -->
  <div style="background:var(--surface-inset);border:3px solid #5b6ee1;box-shadow:4px 4px 0 var(--border-default);overflow:hidden;">
    <div style="background:var(--border-default);padding:10px 16px;display:flex;align-items:center;justify-content:space-between;">
      <span style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--text-primary);">① JSON CANONICALIZADO — RFC 8785 / JCS</span>
      <span style="font-family:'VT323',monospace;font-size:16px;color:var(--text-muted);">canonicalizeJSON() · @noble</span>
    </div>
    <div style="padding:14px;">
      <pre id="jcs-output" style="font-family:'VT323',monospace;font-size:17px;color:var(--role-patient);white-space:pre-wrap;word-break:break-all;margin:0;line-height:1.5;"></pre>
    </div>
  </div>

  <!-- ② SHA-256 del payload -->
  <div style="background:var(--surface-inset);border:3px solid #5b6ee1;box-shadow:4px 4px 0 var(--border-default);overflow:hidden;">
    <div style="background:var(--border-default);padding:10px 16px;display:flex;align-items:center;justify-content:space-between;">
      <span style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--text-primary);">② SHA-256 DEL PAYLOAD — FIPS 180-4</span>
      <span style="font-family:'VT323',monospace;font-size:16px;color:var(--text-muted);">sha256() · @noble/hashes</span>
    </div>
    <div style="padding:14px;display:flex;align-items:center;gap:12px;">
      <div style="flex:1;">
        <p style="font-family:'Press Start 2P',monospace;font-size:6px;color:var(--text-dim);margin-bottom:6px;">DIGEST HEX (256 bits = 64 chars)</p>
        <p id="sha256-output" style="font-family:'VT323',monospace;font-size:17px;color:var(--accent-warn);word-break:break-all;line-height:1.5;"></p>
      </div>
      <div id="sha256-badge" style="display:none;flex-shrink:0;background:#1a2e1a;border:2px solid var(--role-doctor);padding:6px 10px;">
        <span style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--role-doctor);">256 bits ✓</span>
      </div>
    </div>
  </div>

  <!-- ③ Carga de llave privada -->
  <div style="background:#1a1a0d;border:3px solid var(--accent-warn);box-shadow:4px 4px 0 var(--accent-warn-d);padding:20px;display:flex;flex-direction:column;gap:14px;">
    <div style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--accent-warn);">
      ③ CARGAR LLAVE PRIVADA — ECDSA P-256
    </div>

    <!-- Botón usar llave de demo -->
    <div style="background:#12110a;border:2px solid var(--border-default);padding:12px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
      <div>
        <p style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--text-dim);margin-bottom:4px;">MODO DEMO — @noble/curves P-256</p>
        <p style="font-family:'VT323',monospace;font-size:18px;color:var(--text-muted);">Usa la llave de prueba del médico (testData.ts)</p>
      </div>
      <button type="button" id="use-demo-btn" onclick="useDemoKey()"
              style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--role-patient);background:#0a1525;border:3px solid var(--role-patient);padding:8px 12px;cursor:pointer;white-space:nowrap;">
        ⚙ USAR LLAVE DEMO
      </button>
    </div>

    <div style="display:flex;align-items:center;gap:12px;">
      <div style="flex:1;height:2px;background:#29366f;"></div>
      <span style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--text-subtle);">O CARGAR ARCHIVO</span>
      <div style="flex:1;height:2px;background:#29366f;"></div>
    </div>

    <!-- Drop zone -->
    <div id="drop-zone"
         style="border:3px dashed var(--accent-warn);background:#12110a;padding:24px 16px;text-align:center;cursor:pointer;transition:border-color .1s,background .1s;"
         ondragover="handleDragOver(event)" ondragleave="handleDragLeave(event)"
         ondrop="handleDrop(event)" onclick="document.getElementById('key-file-input').click()">
      <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--accent-warn);line-height:2;margin-bottom:4px;">
        ARRASTRA TU ARCHIVO<br/>O HAZ CLIC AQUÍ
      </p>
      <p style="font-family:'VT323',monospace;font-size:18px;color:var(--text-dim);">Formatos: .pem · .key · .p12 · .pfx</p>
      <input type="file" id="key-file-input" accept=".pem,.key,.p12,.pfx,.der" style="display:none;" onchange="handleFileSelect(event)"/>
    </div>

    <!-- Archivo cargado -->
    <div id="file-loaded" style="display:none;background:#1a2e1a;border:3px solid var(--role-doctor);padding:14px;align-items:center;justify-content:space-between;gap:12px;">
      <div>
        <p id="file-name" style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--role-doctor);"></p>
        <p id="file-meta" style="font-family:'VT323',monospace;font-size:17px;color:var(--text-muted);margin-top:3px;"></p>
      </div>
      <button type="button" onclick="resetKey()" style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--role-pharmacy);background:none;border:2px solid var(--role-pharmacy);padding:4px 8px;cursor:pointer;flex-shrink:0;">✕</button>
    </div>

    <!-- Errores -->
    <div id="err-format" style="display:none;background:#2a0d0d;border:3px solid var(--role-pharmacy);padding:14px;">
      <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--role-pharmacy);margin-bottom:8px;">⛔ FORMATO INVÁLIDO</p>
      <p style="font-family:'VT323',monospace;font-size:19px;color:var(--text-muted);line-height:1.5;">Usa un archivo .pem o .key generado con ECDSA P-256.</p>
      <button type="button" onclick="resetKey()" style="margin-top:10px;font-family:'Press Start 2P',monospace;font-size:7px;color:var(--role-pharmacy);background:none;border:2px solid var(--role-pharmacy);padding:5px 10px;cursor:pointer;">REINTENTAR</button>
    </div>
    <div id="err-corrupt" style="display:none;background:#2a0d0d;border:3px solid var(--role-pharmacy);padding:14px;">
      <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--role-pharmacy);margin-bottom:8px;">⛔ LLAVE CORRUPTA</p>
      <p style="font-family:'VT323',monospace;font-size:19px;color:var(--text-muted);line-height:1.5;">El archivo está dañado o incompleto.</p>
      <button type="button" onclick="resetKey()" style="margin-top:10px;font-family:'Press Start 2P',monospace;font-size:7px;color:var(--role-pharmacy);background:none;border:2px solid var(--role-pharmacy);padding:5px 10px;cursor:pointer;">REINTENTAR</button>
    </div>
    <div id="err-mismatch" style="display:none;background:#1a0d00;border:3px solid var(--accent-warn);padding:14px;">
      <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--accent-warn);margin-bottom:8px;">⚠ LLAVE NO COINCIDE</p>
      <p style="font-family:'VT323',monospace;font-size:19px;color:var(--text-muted);line-height:1.5;">La llave no corresponde a la cédula 4892103.</p>
      <button type="button" onclick="resetKey()" style="margin-top:10px;font-family:'Press Start 2P',monospace;font-size:7px;color:var(--accent-warn);background:none;border:2px solid var(--accent-warn);padding:5px 10px;cursor:pointer;">CARGAR OTRA LLAVE</button>
    </div>

    <!-- Llave pública derivada -->
    <div id="pubkey-panel" style="display:none;background:var(--surface-inset);border:2px solid var(--border-default);padding:12px;">
      <p style="font-family:'Press Start 2P',monospace;font-size:6px;color:var(--text-dim);margin-bottom:5px;">LLAVE PÚBLICA DERIVADA — getPublicKey()</p>
      <p id="pubkey-output" style="font-family:'VT323',monospace;font-size:14px;color:var(--role-patient);word-break:break-all;line-height:1.5;"></p>
    </div>

    <!-- Key OK -->
    <div id="key-ok" style="display:none;background:#1a2e1a;border:3px solid var(--role-doctor);padding:12px;align-items:center;gap:10px;">
      <svg width="18" height="14" viewBox="0 0 20 16" style="image-rendering:pixelated;color:var(--role-doctor);flex-shrink:0;"><use href="#ico-checkmark"/></svg>
      <div>
        <p style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--role-doctor);">LLAVE VERIFICADA · LISTA PARA FIRMAR</p>
        <p style="font-family:'VT323',monospace;font-size:17px;color:var(--text-muted);margin-top:3px;">ECDSA P-256 · @noble/curves · La llave nunca abandona este dispositivo.</p>
      </div>
    </div>
  </div>

  <!-- ④ Firma generada -->
  <div id="sig-panel" style="display:none;background:var(--surface-inset);border:3px solid var(--role-doctor);box-shadow:4px 4px 0 var(--role-doctor-d);overflow:hidden;">
    <div style="background:var(--role-doctor-d);padding:10px 16px;display:flex;align-items:center;justify-content:space-between;">
      <span style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--text-primary);">④ FIRMA ECDSA P-256 — FIPS 186-4</span>
      <span style="font-family:'VT323',monospace;font-size:16px;color:var(--text-muted);">p256.sign() · @noble/curves</span>
    </div>
    <div style="padding:14px;">
      <p style="font-family:'Press Start 2P',monospace;font-size:6px;color:var(--text-dim);margin-bottom:6px;">FIRMA HEX (DER-encoded, ~70 bytes)</p>
      <p id="sig-output" style="font-family:'VT323',monospace;font-size:15px;color:var(--role-doctor);word-break:break-all;line-height:1.6;"></p>
    </div>
  </div>

  <!-- Errores de backend -->
  <div id="api-error" style="display:none;background:#2a0d0d;border:3px solid var(--role-pharmacy);padding:14px;">
    <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--role-pharmacy);margin-bottom:8px;">⛔ ERROR AL EMITIR</p>
    <p id="api-error-msg" style="font-family:'VT323',monospace;font-size:19px;color:var(--text-muted);line-height:1.5;"></p>
  </div>

  <!-- CTA -->
  <button type="button" id="sign-btn" onclick="doSign()" disabled
          class="px-btn px-btn-yellow px-btn-lg"
          style="width:100%;justify-content:center;font-size:12px;opacity:.4;cursor:not-allowed;">
    🔑 FIRMAR Y EMITIR RECETA
  </button>

  <div style="display:flex;justify-content:center;gap:24px;">
    <a href="/doctor/patient"    style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--text-subtle);text-decoration:none;" onmouseover="this.style.color='#c0cbdc'" onmouseout="this.style.color='#29366f'">◄ EDITAR PACIENTE</a>
    <a href="/doctor/medication" style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--text-subtle);text-decoration:none;" onmouseover="this.style.color='#c0cbdc'" onmouseout="this.style.color='#29366f'">◄ EDITAR MEDICAMENTO</a>
  </div>
</div>
</FlowLayout>

<script>
  import { canonicalizeJSON, signData, getPublicKey } from '../../utils/cryptoFlow.ts'
  import { sha256 } from '@noble/hashes/sha2.js'
  import { utf8ToBytes, bytesToHex } from '@noble/hashes/utils.js'
  import { testKeys, recetaPrueba } from '../../utils/testData.ts'
  import { CryptoEngine } from '../../crypto/index.ts'
  import { Api, ApiError, getSession } from '../../utils/api.ts'
  import { requireSession } from '../../utils/sessionGuard.ts'
  requireSession('Medico', '/doctor')

  /* ══ ESTADO GLOBAL ══ */
  let activePrivKeyHex: string | null = null
  let canonicalStr = ''
  let digestHex    = ''

  /* ══ HIDRATAR DESDE SESIÓN ══ */
  //  - rxpro_paciente : { curp, id_paciente, name, dob, sex }
  //  - rxpro_receta   : { medicamentos[], fecha_emision, vigencia_dias }
  //  - rxpro_token    : JWT del médico
  const sessionDoc     = getSession()
  const storedPaciente = JSON.parse(sessionStorage.getItem('rxpro_paciente') || '{}')
  const storedReceta   = JSON.parse(sessionStorage.getItem('rxpro_receta')   || '{}')

  // Si hay una sesión de médico real, usa su id; si no, cae a un placeholder
  const ID_MEDICO   = sessionDoc && sessionDoc.role === 'Medico'
    ? sessionDoc.id
    : 1
  const ID_PACIENTE = Number(storedPaciente.id_paciente) || 0
  const VIGENCIA    = Number(storedReceta.vigencia_dias) || 30
  const FECHA_EMI   = (storedReceta.fecha_emision || new Date().toISOString().split('T')[0]) + 'T00:00:00Z'
  const FECHA_VENC  = new Date(Date.now() + VIGENCIA * 86400000).toISOString()
  const MEDS        = Array.isArray(storedReceta.medicamentos) && storedReceta.medicamentos.length
    ? storedReceta.medicamentos
    : [{ nombre: 'Amoxicilina 500 mg', forma: 'CÁPSULA', dosis: '500 mg', frecuencia: 'c/8h', duracion: '7 días' }]

  /* ══ RECETA BASE (alineada con DatosMedicos de crypto/interfaces) ══ */
  const RECETA_ID = (globalThis.crypto?.randomUUID?.() || `rx-${Date.now()}`)
  const RECETA = {
    datos: {
      id_receta:        RECETA_ID,
      id_medico:        `USR-${ID_MEDICO}`,
      id_paciente:      `USR-${ID_PACIENTE || '?'}`,
      fecha_emision:    FECHA_EMI,
      fecha_vencimiento: FECHA_VENC,
      medicamentos:     MEDS,
      instrucciones_extra: storedPaciente.name ? `Paciente: ${storedPaciente.name}` : undefined,
    },
    dispensacion: null,
  }

  /* ══ INIT — JCS + SHA-256 al cargar ══ */
  function init() {
    canonicalStr = canonicalizeJSON(RECETA)

    // Mostrar JCS pretty-printed
    ;(document.getElementById('jcs-output') as HTMLPreElement).textContent =
      JSON.stringify(JSON.parse(canonicalStr), null, 2)

    // SHA-256 del canónico con @noble/hashes
    const digestBytes = sha256(utf8ToBytes(canonicalStr))
    digestHex = bytesToHex(digestBytes)
    ;(document.getElementById('sha256-output') as HTMLParagraphElement).textContent = digestHex
    ;(document.getElementById('sha256-badge') as HTMLDivElement).style.display = 'flex'
  }

  init()

  /* ══ USAR LLAVE DEMO (testData.ts) ══ */
  function useDemoKey() {
    const btn = document.getElementById('use-demo-btn') as HTMLButtonElement
    btn.textContent  = '⏳ CARGANDO...'
    btn.disabled     = true

    try {
      activePrivKeyHex = testKeys.medico

      // Derivar y mostrar llave pública
      const pubHex = getPublicKey(activePrivKeyHex)
      sessionStorage.setItem('rxflow_pubkey', pubHex)
      ;(document.getElementById('pubkey-output') as HTMLParagraphElement).textContent = pubHex
      ;(document.getElementById('pubkey-panel') as HTMLDivElement).style.display = 'block'

      // Ocultar drop zone, mostrar key OK
      ;(document.getElementById('drop-zone') as HTMLDivElement).style.display = 'none'
      ;(document.getElementById('key-ok') as HTMLDivElement).style.display    = 'flex'
      ;(document.getElementById('file-name') as HTMLParagraphElement).textContent = 'testKeys.medico (demo)'
      ;(document.getElementById('file-meta') as HTMLParagraphElement).textContent = '32 bytes · ECDSA P-256 · @noble/curves'
      ;(document.getElementById('file-loaded') as HTMLDivElement).style.display = 'flex'

      btn.textContent       = '✓ LLAVE CARGADA'
      btn.style.color       = '#38b764'
      btn.style.borderColor = '#38b764'

      setSignBtn(true)
    } catch(e) {
      btn.textContent = '⛔ ERROR'
      btn.style.color = '#e8003d'
      console.error(e)
    }
  }

  /* ══ DRAG & DROP ══ */
  const VALID_EXTS  = ['.pem', '.key', '.p12', '.pfx', '.der']
  const PEM_HEADERS = [
    '-----BEGIN EC PRIVATE KEY-----',
    '-----BEGIN PRIVATE KEY-----',
    '-----BEGIN ENCRYPTED PRIVATE KEY-----',
  ]
  const KEY_ATTEMPT = 'rxflow_key_attempt'

  function handleDragOver(e: DragEvent)  { e.preventDefault(); (e.currentTarget as HTMLElement).style.borderColor='#fff'; (e.currentTarget as HTMLElement).style.background='#1e1c00' }
  function handleDragLeave(e: DragEvent) { (e.currentTarget as HTMLElement).style.borderColor='#ffcd75'; (e.currentTarget as HTMLElement).style.background='#12110a' }
  function handleDrop(e: DragEvent)      { e.preventDefault(); handleDragLeave(e); const f=e.dataTransfer?.files?.[0]; if(f) processFile(f) }
  function handleFileSelect(e: Event)    { const f=(e.target as HTMLInputElement).files?.[0]; if(f) processFile(f) }

  function hideErrors() {
    ;['err-format','err-corrupt','err-mismatch','file-loaded','key-ok','pubkey-panel'].forEach(id => {
      const el = document.getElementById(id)
      if (el) el.style.display = 'none'
    })
  }

  function resetKey() {
    hideErrors()
    ;(document.getElementById('key-file-input') as HTMLInputElement).value = ''
    ;(document.getElementById('drop-zone') as HTMLDivElement).style.display = 'block'
    ;(document.getElementById('sig-panel') as HTMLDivElement).style.display = 'none'
    activePrivKeyHex = null
    setSignBtn(false)
  }

  async function processFile(file: File) {
    const name = file.name.toLowerCase()
    const ext  = VALID_EXTS.find(e => name.endsWith(e))
    ;(document.getElementById('drop-zone') as HTMLDivElement).style.display = 'none'
    hideErrors()

    if (!ext) { (document.getElementById('err-format') as HTMLDivElement).style.display = 'block'; return }

    let text = ''
    try { text = await file.text() } catch { (document.getElementById('err-corrupt') as HTMLDivElement).style.display = 'block'; return }

    const trimmed   = text.trim()
    const hasHeader = PEM_HEADERS.some(h => trimmed.startsWith(h))

    if (!hasHeader && !['.p12','.pfx','.der'].includes(ext)) {
      ;(document.getElementById(trimmed.startsWith('-----') ? 'err-format' : 'err-corrupt') as HTMLDivElement).style.display = 'block'
      return
    }

    // Simulación: primer intento → mismatch, segundo → OK con llave demo
    const attempts = parseInt(sessionStorage.getItem(KEY_ATTEMPT) || '0')
    if (attempts === 0) {
      sessionStorage.setItem(KEY_ATTEMPT, '1')
      ;(document.getElementById('err-mismatch') as HTMLDivElement).style.display = 'block'
      return
    }
    sessionStorage.removeItem(KEY_ATTEMPT)

    // Usar llave demo como fallback
    activePrivKeyHex = testKeys.medico
    const pubHex = getPublicKey(activePrivKeyHex)
    sessionStorage.setItem('rxflow_pubkey', pubHex)
    ;(document.getElementById('pubkey-output') as HTMLParagraphElement).textContent = pubHex
    ;(document.getElementById('pubkey-panel') as HTMLDivElement).style.display = 'block'

    const size = file.size < 1024 ? file.size + ' B' : (file.size/1024).toFixed(1) + ' KB'
    ;(document.getElementById('file-name') as HTMLParagraphElement).textContent = file.name.length > 30 ? file.name.slice(0,28)+'…' : file.name
    ;(document.getElementById('file-meta') as HTMLParagraphElement).textContent = size + ' · ECDSA P-256'
    ;(document.getElementById('file-loaded') as HTMLDivElement).style.display = 'flex'
    ;(document.getElementById('key-ok') as HTMLDivElement).style.display      = 'flex'
    setSignBtn(true)
  }

  /* ══ FIRMAR con @noble/curves ══ */
  function setSignBtn(enabled: boolean) {
    const btn = document.getElementById('sign-btn') as HTMLButtonElement
    btn.disabled      = !enabled
    btn.style.opacity = enabled ? '1' : '.4'
    btn.style.cursor  = enabled ? 'pointer' : 'not-allowed'
  }

  function showApiError(msg: string) {
    const box = document.getElementById('api-error') as HTMLDivElement
    const m   = document.getElementById('api-error-msg') as HTMLParagraphElement
    m.textContent = msg
    box.style.display = 'block'
  }
  function hideApiError() {
    const box = document.getElementById('api-error') as HTMLDivElement
    box.style.display = 'none'
  }

  async function doSign() {
    if (!activePrivKeyHex) return
    hideApiError()
    const btn = document.getElementById('sign-btn') as HTMLButtonElement
    btn.disabled     = true
    btn.textContent  = '⏳ FIRMANDO CON @noble/curves...'
    btn.style.opacity = '.7'

    try {
      // ── 1) Firma clásica (mostrada en UI) ──────────────────────────────
      const sigHex = signData(canonicalStr, activePrivKeyHex)
      sessionStorage.setItem('rxflow_signature', sigHex)
      sessionStorage.setItem('rxflow_canonical',  canonicalStr)
      sessionStorage.setItem('rxflow_digest',     digestHex)
      ;(document.getElementById('sig-output') as HTMLParagraphElement).textContent = sigHex
      ;(document.getElementById('sig-panel') as HTMLDivElement).style.display = 'block'

      // ── 2) Validaciones para POST al backend ────────────────────────────
      if (!ID_PACIENTE) {
        throw new Error('Falta el ID del paciente (regresa al paso PACIENTE).')
      }

      // ── 3) Construir cápsula cifrada E2E con CryptoEngine ───────────────
      // Las llaves públicas de destinatarios son las de demo mientras no haya
      // endpoint de directorio; el backend sólo persiste blobs opacos.
      const pacientePub     = getPublicKey(testKeys.paciente)
      const farmaceuticoPub = getPublicKey(testKeys.farmaceutico)
      const doctorPub       = getPublicKey(activePrivKeyHex)

      btn.textContent = '⏳ CIFRANDO CÁPSULA E2E...'
      const cifrada = CryptoEngine.emitirRecetaGlobal(
        RECETA.datos as any,
        activePrivKeyHex,
        activePrivKeyHex,     // mismo par para firma y cifrado en este prototipo
        pacientePub,
        farmaceuticoPub,
        doctorPub,
      )

      // ── 4) POST /api/v1/recetas ─────────────────────────────────────────
      btn.textContent = '⏳ ENVIANDO AL BACKEND...'
      const created = await Api.crearReceta({
        id_medico:       ID_MEDICO,
        id_paciente:     ID_PACIENTE,
        expira_en:       FECHA_VENC,
        capsula_cifrada: cifrada.capsula_cifrada,
        iv_aes_gcm:      cifrada.iv_aes_gcm,
        accesos:         cifrada.accesos,
      })

      // Persistir id real devuelto por el backend para la pantalla "done"
      sessionStorage.setItem('rxpro_last_receta', JSON.stringify(created))

      btn.textContent  = '✓ RECETA EMITIDA #' + created.id_receta
      btn.style.color  = '#38b764'
      btn.style.borderColor = '#38b764'
      btn.style.opacity = '1'

      setTimeout(() => { window.location.href = '/doctor/done' }, 900)
    } catch (e: any) {
      const msg = e instanceof ApiError
        ? `Backend ${e.status}: ${e.detail}`
        : (e?.message || 'Error desconocido al firmar/emitir.')
      showApiError(msg)
      btn.disabled     = false
      btn.textContent  = '🔑 FIRMAR Y EMITIR RECETA'
      btn.style.opacity = '1'
      btn.style.cursor  = 'pointer'
      console.error('Emisión fallida:', e)
    }
  }

  // Exponer funciones al scope global para los onclick del HTML
  ;(window as any).useDemoKey      = useDemoKey
  ;(window as any).handleDragOver  = handleDragOver
  ;(window as any).handleDragLeave = handleDragLeave
  ;(window as any).handleDrop      = handleDrop
  ;(window as any).handleFileSelect= handleFileSelect
  ;(window as any).resetKey        = resetKey
  ;(window as any).doSign          = doSign
</script>
