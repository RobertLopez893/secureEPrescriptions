---
import FlowLayout from '../../layouts/FlowLayout.astro'
const steps=[{label:'LOGIN',href:'/doctor'},{label:'PACIENTE',href:'/doctor/patient'},{label:'MEDICAMENTO',href:'/doctor/medication'},{label:'FIRMA',href:'/doctor/sign'}]
---
<FlowLayout title="Médico — Paciente" role="doctor" steps={steps} currentStep={1} back="/doctor">
<div class="anim-slide" style="display:flex;flex-direction:column;gap:20px;">
  <div>
    <h1 style="font-family:'Press Start 2P',monospace;font-size:13px;color:var(--text-primary);margin-bottom:6px;">DATOS DEL PACIENTE</h1>
    <p style="font-family:'VT323',monospace;font-size:22px;color:var(--text-muted);">¿A quién va dirigida la receta?</p>
  </div>

  <div class="px-card" style="padding:24px;background:var(--surface-card);border-color:var(--role-doctor);box-shadow:4px 4px 0 var(--role-doctor-d);">
    <form id="patient-form" style="display:flex;flex-direction:column;gap:18px;">
      
      <div style="display:flex; flex-direction:column; gap:14px;">
        <div style="display:flex; gap:14px;">
          <div style="flex: 1;">
            <label class="px-label" style="color:var(--role-doctor);">MÉTODO</label>
            <select id="search-type" class="px-input green" style="cursor: pointer;">
              <option value="curp">CURP</option>
              <option value="id">ID PACIENTE</option>
            </select>
          </div>
          <div style="flex: 2;">
            <label class="px-label" style="color:var(--role-doctor);">DATO A BUSCAR *</label>
            <input type="text" id="search-value" placeholder="Ingresa el valor..." class="px-input green" style="text-transform:uppercase; letter-spacing: 0.05em;" />
          </div>
        </div>
        
        <button type="button" id="btn-search" class="px-btn px-btn-green" style="width: 100%; height: 48px; justify-content: center;">
          🔍 BUSCAR PACIENTE EN EL SISTEMA
        </button>
      </div>

      <input type="hidden" name="curp" id="hidden-curp" />
      <input type="hidden" name="id_paciente" id="hidden-id" />

      <div style="height:2px;background:#29366f; margin: 4px 0;"></div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div style="grid-column:1/-1;">
          <label class="px-label" style="color:var(--role-doctor);">NOMBRE COMPLETO *</label>
          <input type="text" name="name" placeholder="Nombre del paciente" class="px-input green" required readonly/>
        </div>
        <div>
          <label class="px-label" style="color:var(--role-doctor);">FECHA NACIMIENTO *</label>
          <input type="date" name="dob" class="px-input green" required readonly/>
        </div>
        <div>
          <label class="px-label" style="color:var(--role-doctor);">SEXO</label>
          <select name="sex" class="px-input green" style="pointer-events: none;">
            <option value="">SELECCIONAR</option>
            <option>MASCULINO</option>
            <option>FEMENINO</option>
          </select>
        </div>
      </div>

      <button type="submit" id="btn-submit" class="px-btn px-btn-green px-btn-lg" style="width:100%;justify-content:center; margin-top: 10px;" disabled>
        ► CONTINUAR AL MEDICAMENTO
      </button>
    </form>
  </div>
</div>
</FlowLayout>

<script>
  import { requireSession } from '../../utils/sessionGuard.ts'
  import { Api } from '../../utils/api.ts'
  requireSession('Medico', '/doctor')

  const form = document.getElementById('patient-form') as HTMLFormElement;
  const searchType = document.getElementById('search-type') as HTMLSelectElement;
  const searchValue = document.getElementById('search-value') as HTMLInputElement;
  const btnSearch = document.getElementById('btn-search') as HTMLButtonElement;

  const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;

  const hiddenCurp = document.getElementById('hidden-curp') as HTMLInputElement;
  const hiddenId = document.getElementById('hidden-id') as HTMLInputElement;
  const nameInput = form.querySelector('[name="name"]') as HTMLInputElement;
  const dobInput = form.querySelector('[name="dob"]') as HTMLInputElement;
  const sexInput = form.querySelector('[name="sex"]') as HTMLSelectElement;



  btnSearch.addEventListener('click', async () => {
    const type = searchType.value;
    const val = searchValue.value.trim().toUpperCase();

    if (!val) {
      window.showToast?.('Ingresa un valor para buscar', 'var(--accent-warn)');
      return;
    }

    try {
      // Búsqueda RESTful: ID en el path o CURP en query param
      const params = type === 'curp' ? { curp: val } : { id_usuario: Number(val) };
      const paciente = await Api.buscarPaciente(params);

      if (paciente) {
        hiddenCurp.value = paciente.curp || '';
        hiddenId.value = String(paciente.id_usuario);
        nameInput.value = `${paciente.nombre} ${paciente.paterno} ${paciente.materno || ''}`.trim();
        dobInput.value = paciente.nacimiento || '';
        
        if (paciente.sexo) {
          const sexoInicial = paciente.sexo.toUpperCase().charAt(0);
          sexInput.value = sexoInicial === 'M' ? 'MASCULINO' : 'FEMENINO';
        }
        btnSubmit.disabled = false
        window.showToast?.('Paciente cargado', "var(--role-doctor)");
      }
    } catch (error) {
      hiddenId.value = '';
      nameInput.value = '';
      dobInput.value = '';
      sexInput.value = '';
      btnSubmit.disabled = true;
      window.showToast?.('No se encontró el paciente', 'var(--accent-warn)');
    }
  });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!hiddenId.value) {
      window.showToast?.('Busca a un paciente primero', 'var(--accent-warn)');
      return;
    }
    const data = {
      curp: hiddenCurp.value,
      id_paciente: Number(hiddenId.value),
      name: nameInput.value,
      dob: dobInput.value,
      sex: sexInput.value,
    };
    sessionStorage.setItem('rxpro_paciente', JSON.stringify(data));
    window.location.href = '/doctor/medication';
  });
</script>
