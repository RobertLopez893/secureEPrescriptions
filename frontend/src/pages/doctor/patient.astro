---
import FlowLayout from '../../layouts/FlowLayout.astro'
const steps=[{label:'LOGIN',href:'/doctor'},{label:'PACIENTE',href:'/doctor/patient'},{label:'MEDICAMENTO',href:'/doctor/medication'},{label:'FIRMA',href:'/doctor/sign'}]
---
<FlowLayout title="Médico — Paciente" role="doctor" steps={steps} currentStep={1} back="/doctor">
<div class="anim-slide" style="display:flex;flex-direction:column;gap:20px;">
  <div>
    <h1 style="font-family:'Press Start 2P',monospace;font-size:13px;color:var(--text-primary);margin-bottom:6px;">DATOS DEL PACIENTE</h1>
    <p style="font-family:'VT323',monospace;font-size:22px;color:var(--text-muted);">¿A quién va dirigida la receta?</p>
  </div>

  <div class="px-card" style="padding:24px;background:var(--surface-card);border-color:var(--role-doctor);box-shadow:4px 4px 0 var(--role-doctor-d);">
    <form id="patient-form" style="display:flex;flex-direction:column;gap:18px;">
      <div style="display:grid;grid-template-columns:2fr 1fr;gap:14px;">
        <div>
          <label class="px-label" style="color:var(--role-doctor);">CURP DEL PACIENTE *</label>
          <input type="text" name="curp" placeholder="RAEG920315HMCRND07"
                 class="px-input green" style="text-align:center;letter-spacing:.15em;font-size:22px;text-transform:uppercase;"
                 maxlength="18" required/>
        </div>
        <div>
          <label class="px-label" style="color:var(--role-doctor);">ID PACIENTE *</label>
          <input type="number" name="id_paciente" placeholder="42" min="1"
                 class="px-input green" style="text-align:center;font-size:22px;" required/>
        </div>
      </div>
      <p style="font-family:'VT323',monospace;font-size:18px;color:var(--text-dim);margin-top:-6px;text-align:center;">
        El ID paciente es el id_usuario emitido por el backend al registrarlo.
      </p>

      <div style="height:2px;background:#29366f;"></div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
        <div style="grid-column:1/-1;">
          <label class="px-label" style="color:var(--role-doctor);">NOMBRE COMPLETO *</label>
          <input type="text" name="name" placeholder="Nombre del paciente" class="px-input green" required/>
        </div>
        <div>
          <label class="px-label" style="color:var(--role-doctor);">FECHA NACIMIENTO *</label>
          <input type="date" name="dob" class="px-input green" required/>
        </div>
        <div>
          <label class="px-label" style="color:var(--role-doctor);">SEXO</label>
          <select name="sex" class="px-input green">
            <option value="">SELECCIONAR</option>
            <option>MASCULINO</option>
            <option>FEMENINO</option>
          </select>
        </div>
      </div>

      <!-- Info box -->
      <div style="background:#1a2e1a;border:3px solid var(--role-doctor);padding:14px;display:flex;gap:12px;align-items:flex-start;">
        <span style="font-size:20px;flex-shrink:0;">💡</span>
        <div>
          <p style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--role-doctor);margin-bottom:6px;">BÚSQUEDA AUTOMÁTICA</p>
          <p style="font-family:'VT323',monospace;font-size:19px;color:var(--text-muted);line-height:1.5;">Al ingresar el CURP, el sistema busca al paciente. Si existe, los datos se llenan solos.</p>
        </div>
      </div>

      <button type="submit" class="px-btn px-btn-green px-btn-lg" style="width:100%;justify-content:center;">
        ► CONTINUAR AL MEDICAMENTO
      </button>
    </form>
  </div>
</div>
</FlowLayout>

<script>
  import { requireSession } from '../../utils/sessionGuard.ts'
  import { decodificarCURP } from '../../utils/curpUtils.ts' // Tu utilidad

  requireSession('Medico', '/doctor')

  const form = document.getElementById('patient-form') as HTMLFormElement

  // Referencias a los inputs
  const curpInput = form.querySelector('[name="curp"]') as HTMLInputElement
  const idInput = form.querySelector('[name="id_paciente"]') as HTMLInputElement
  const nameInput = form.querySelector('[name="name"]') as HTMLInputElement
  const dobInput = form.querySelector('[name="dob"]') as HTMLInputElement
  const sexSelect = form.querySelector('[name="sex"]') as HTMLSelectElement

  // Rehidratar si ya hay datos guardados (tu lógica original)
  const existing = sessionStorage.getItem('rxpro_paciente')
  if (existing) {
    try {
      const data = JSON.parse(existing)
      for (const [k, v] of Object.entries(data)) {
        const el = form.querySelector(`[name="${k}"]`) as HTMLInputElement | HTMLSelectElement | null
        if (el) el.value = String(v ?? '')
      }
    } catch { /* noop */ }
  }

  // Lógica de Autocompletado + Fetch
  if (curpInput) {
    curpInput.addEventListener('input', async () => {
      let curpVal = curpInput.value.toUpperCase()
      curpInput.value = curpVal

      if (curpVal.length === 18) {
        // 1. Autocompletado local instantáneo (Fecha y Género)
        const datosLocales = decodificarCURP(curpVal)
        if (datosLocales) {
          if (dobInput) dobInput.value = datosLocales.fechaNacimiento
          if (sexSelect) {
            sexSelect.value = datosLocales.genero === 'Hombre' ? 'MASCULINO' : 'FEMENINO'
          }
        }

        // 2. Fetch al backend para traer el ID y Nombre Completo
        try {
          // Asumiendo que guardas tu JWT en sessionStorage con alguna llave
          // (Ajusta 'rxpro_jwt' a como lo estés guardando en tu authFlow.ts)
          const token = sessionStorage.getItem('rxpro_jwt') || localStorage.getItem('rxpro_jwt')
          
          // Usa tu URL base de la API
          const res = await fetch(`http://localhost:8000/api/v1/usuarios/pacientes/buscar/${curpVal}`, {
            headers: {
              'Authorization': `Bearer ${token}`
            }
          })

          if (res.ok) {
            const pacienteDB = await res.json()
            if (idInput) idInput.value = pacienteDB.id_paciente
            if (nameInput) nameInput.value = pacienteDB.nombre_completo
            
            window.showToast?.('Paciente encontrado en la base de datos', '#38b764')
          } else if (res.status === 404) {
            window.showToast?.('Paciente no registrado. Completa los datos manualmente.', '#ffcd75')
            // Limpiamos ID y Nombre si es un paciente nuevo
            if (idInput) idInput.value = ''
            if (nameInput) nameInput.value = ''
          }
        } catch (error) {
          console.error("Error buscando paciente:", error)
        }
      }
    })
  }

  // Manejo del Submit original
  form.addEventListener('submit', (e) => {
    e.preventDefault()
    const fd = new FormData(form)
    const data = {
      curp:          String(fd.get('curp') || '').trim().toUpperCase(),
      id_paciente:   Number(fd.get('id_paciente') || 0),
      name:          String(fd.get('name') || '').trim(),
      dob:           String(fd.get('dob') || ''),
      sex:           String(fd.get('sex') || ''),
    }
    if (!data.id_paciente) {
      window.showToast?.('Ingresa el ID del paciente', '#e8003d')
      return
    }
    sessionStorage.setItem('rxpro_paciente', JSON.stringify(data))
    window.location.href = '/doctor/medication'
  })
</script>
