---
import FlowLayout from '../../layouts/FlowLayout.astro'
const steps=[{label:'LOGIN',href:'/doctor'},{label:'PACIENTE',href:'/doctor/patient'},{label:'MEDICAMENTOS',href:'/doctor/medication'},{label:'FIRMA',href:'/doctor/sign'}]
---
<FlowLayout title="Médico — Acceso" role="doctor" steps={steps} currentStep={0}>
<div class="anim-slide" style="display:flex;flex-direction:column;gap:20px;">

  <!-- Header -->
  <div style="text-align:center;">
    <div class="anim-bounce" style="display:flex;justify-content:center;margin-bottom:14px;">
      <svg width="60" height="70" viewBox="0 0 24 28" style="image-rendering:pixelated;"><use href="#ico-doctor"/></svg>
    </div>
    <h1 style="font-family:'Press Start 2P',monospace;font-size:13px;color:#f4f4f4;margin-bottom:8px;line-height:1.7;">ACCESO MÉDICO</h1>
    <p style="font-family:'VT323',monospace;font-size:22px;color:#c0cbdc;">Escanea tu tarjeta médica para iniciar sesión</p>
  </div>

  <!-- QR CARD READER — verde médico -->
  <div style="background:#222639;border:3px solid #38b764;box-shadow:4px 4px 0 #257a43;padding:20px;">

    <div style="font-family:'Press Start 2P',monospace;font-size:8px;color:#38b764;margin-bottom:14px;display:flex;align-items:center;gap:8px;">
      <span class="anim-blink" style="display:inline-block;width:8px;height:8px;background:#38b764;"></span>
      LECTOR QR — TARJETA MÉDICO
    </div>

    <!-- Scanner viewport -->
    <div id="qr-viewport"
         style="background:#040e08;border:3px solid #38b764;position:relative;overflow:hidden;margin-bottom:18px;height:240px;">

      <!-- QR grid -->
      <div class="qr-grid" style="--grid-color:rgba(56,183,100,.12);"></div>

      <!-- Scan line verde -->
      <div class="qr-scan-line" id="qr-scan-line"
           style="background:linear-gradient(90deg,transparent,#38b764,transparent);box-shadow:0 0 14px #38b764;"></div>

      <!-- Corner brackets -->
      <div style="position:absolute;top:10px;left:10px;width:28px;height:28px;border-top:4px solid #38b764;border-left:4px solid #38b764;z-index:2;"></div>
      <div style="position:absolute;top:10px;right:10px;width:28px;height:28px;border-top:4px solid #38b764;border-right:4px solid #38b764;z-index:2;"></div>
      <div style="position:absolute;bottom:10px;left:10px;width:28px;height:28px;border-bottom:4px solid #38b764;border-left:4px solid #38b764;z-index:2;"></div>
      <div style="position:absolute;bottom:10px;right:10px;width:28px;height:28px;border-bottom:4px solid #38b764;border-right:4px solid #38b764;z-index:2;"></div>

      <!-- Tarjeta médico idle -->
      <div id="card-idle" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:14px;">
        <svg width="188" height="120" viewBox="0 0 188 120" style="image-rendering:pixelated;filter:drop-shadow(0 0 10px rgba(56,183,100,.4));" class="anim-float">
          <!-- Card body -->
          <rect width="188" height="120" rx="5" fill="#071409"/>
          <rect width="188" height="120" rx="5" fill="none" stroke="#38b764" stroke-width="2"/>
          <!-- Shimmer -->
          <rect y="0" width="188" height="40" rx="5" fill="rgba(56,183,100,.07)"/>
          <!-- Cross icon (medicine) -->
          <rect x="14" y="50" width="30" height="8"  fill="#38b764"/>
          <rect x="25" y="39" width="8"  height="30" fill="#38b764"/>
          <!-- QR pixel art finder patterns -->
          <g fill="#38b764">
            <rect x="108" y="36" width="20" height="20" fill="none" stroke="#38b764" stroke-width="2"/>
            <rect x="112" y="40" width="12" height="12"/>
            <rect x="136" y="36" width="20" height="20" fill="none" stroke="#38b764" stroke-width="2"/>
            <rect x="140" y="40" width="12" height="12"/>
            <rect x="108" y="64" width="20" height="20" fill="none" stroke="#38b764" stroke-width="2"/>
            <rect x="112" y="68" width="12" height="12"/>
            <!-- Data pixels -->
            <rect x="130" y="58" width="4" height="4"/>
            <rect x="136" y="60" width="4" height="2"/>
            <rect x="142" y="64" width="2" height="6"/>
            <rect x="148" y="66" width="6" height="2"/>
            <rect x="148" y="70" width="4" height="4"/>
            <rect x="136" y="70" width="8" height="2"/>
          </g>
          <!-- Name + title -->
          <text x="14" y="24" fill="#f4f4f4" style="font-family:monospace;font-size:12px;font-weight:bold;letter-spacing:1px;">RxPro</text>
          <text x="14" y="37" fill="#38b764" style="font-family:monospace;font-size:7px;letter-spacing:2px;">TARJETA MÉDICO</text>
          <!-- Dr info -->
          <text x="14" y="100" fill="#38b764" style="font-family:monospace;font-size:8px;letter-spacing:2px;">DR. ████████████</text>
          <text x="14" y="113" fill="#257a43" style="font-family:monospace;font-size:5px;letter-spacing:1px;">CÉD. ███████ · ECDSA P-256</text>
        </svg>
        <p id="qr-status" style="font-family:'Press Start 2P',monospace;font-size:8px;color:#38b764;letter-spacing:.08em;" class="anim-blink">
          ACERQUE TARJETA MÉDICO
        </p>
      </div>

      <!-- Panel de procesamiento -->
      <div id="card-scanning" style="display:none;position:absolute;inset:0;align-items:center;justify-content:center;flex-direction:column;gap:16px;">
        <div style="position:relative;width:72px;height:72px;">
          <div style="position:absolute;inset:0;border:4px solid #1a3020;border-top-color:#38b764;animation:spinnerRot .6s steps(8,end) infinite;"></div>
          <div style="position:absolute;inset:8px;display:flex;align-items:center;justify-content:center;">
            <svg width="28" height="20" viewBox="0 0 28 16" style="image-rendering:pixelated;color:#38b764;">
              <use href="#ico-key"/>
            </svg>
          </div>
        </div>
        <p id="derive-status" style="font-family:'Press Start 2P',monospace;font-size:8px;color:#38b764;letter-spacing:.06em;text-align:center;max-width:220px;line-height:1.8;" class="anim-blink">
          LEYENDO QR...
        </p>
      </div>

      <!-- Panel de éxito -->
      <div id="card-success" style="display:none;position:absolute;inset:0;align-items:center;justify-content:center;flex-direction:column;gap:12px;padding:16px;">
        <svg width="40" height="46" viewBox="0 0 24 28" style="image-rendering:pixelated;color:#38b764;">
          <use href="#ico-shield"/>
        </svg>
        <p style="font-family:'Press Start 2P',monospace;font-size:9px;color:#38b764;">MÉDICO VERIFICADO</p>
        <div style="background:#041008;border:2px solid #38b764;padding:8px 12px;width:100%;text-align:center;">
          <span style="font-family:'VT323',monospace;font-size:16px;color:#38b764;letter-spacing:.1em;">
            CÉDULA ••••••• · ECDSA OK
          </span>
        </div>
        <p style="font-family:'Press Start 2P',monospace;font-size:6px;color:#257a43;line-height:1.8;">ACCEDIENDO AL SISTEMA...</p>
      </div>

      <!-- Progress bar -->
      <div id="scan-progress-track" style="display:none;position:absolute;bottom:10px;left:16px;right:16px;height:6px;border:2px solid #38b764;background:#0d0e1a;z-index:3;">
        <div id="scan-progress-fill" style="height:100%;width:0%;background:repeating-linear-gradient(90deg,#38b764 0px,#38b764 6px,#257a43 6px,#257a43 12px);"></div>
      </div>
    </div>

    <!-- Tech badges -->
    <div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;">
      {['QR SEED','HKDF-SHA256','ECDSA P-256','FIPS 186-5'].map(t => (
        <span style="font-family:'Press Start 2P',monospace;font-size:6px;padding:3px 6px;border:2px solid #29366f;color:#38b764;background:#29366f22;">{t}</span>
      ))}
    </div>

    <!-- Scan button -->
    <button type="button" id="scan-btn"
            style="width:100%;padding:14px;background:#061208;border:3px solid #38b764;box-shadow:4px 4px 0 #257a43;font-family:'Press Start 2P',monospace;font-size:9px;color:#38b764;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:16px;">
      <svg width="20" height="20" viewBox="0 0 20 20" style="image-rendering:pixelated;flex-shrink:0;">
        <rect x="0"  y="0"  width="8" height="8" fill="none" stroke="#38b764" stroke-width="1.5"/>
        <rect x="2"  y="2"  width="4" height="4" fill="#38b764"/>
        <rect x="12" y="0"  width="8" height="8" fill="none" stroke="#38b764" stroke-width="1.5"/>
        <rect x="14" y="2"  width="4" height="4" fill="#38b764"/>
        <rect x="0"  y="12" width="8" height="8" fill="none" stroke="#38b764" stroke-width="1.5"/>
        <rect x="2"  y="14" width="4" height="4" fill="#38b764"/>
        <rect x="12" y="12" width="2" height="2" fill="#38b764"/>
        <rect x="16" y="12" width="2" height="4" fill="#38b764"/>
        <rect x="12" y="16" width="6" height="2" fill="#38b764"/>
        <rect x="10" y="10" width="2" height="2" fill="#38b764"/>
        <rect x="10" y="4"  width="2" height="4" fill="#38b764"/>
      </svg>
      ESCANEAR TARJETA MÉDICA
    </button>

    <!-- Error del escaneo (cámara / firma inválida) -->
    <p id="scan-error" style="display:none;font-family:'Press Start 2P',monospace;font-size:7px;color:#a53030;background:#2a1018;border:2px solid #a53030;padding:10px;line-height:1.8;"></p>
  </div>

  <!-- Security notice -->
  <div style="display:flex;align-items:flex-start;gap:10px;padding:12px 14px;border:2px solid #29366f;background:#29366f18;">
    <svg width="14" height="18" viewBox="0 0 20 24" style="image-rendering:pixelated;color:#29366f;flex-shrink:0;margin-top:2px;">
      <use href="#ico-lock"/>
    </svg>
    <p style="font-family:'Press Start 2P',monospace;font-size:6px;color:#29366f;line-height:2;">
      LLAVE PRIVADA DERIVADA EN MEMORIA · NUNCA SE ALMACENA · SESIÓN CIFRADA E2E
    </p>
  </div>
</div>
</FlowLayout>

<script>
  import { Api, ApiError } from '../../utils/api.ts'

  const btn          = document.getElementById('scan-btn')      as HTMLButtonElement
  const viewport     = document.getElementById('qr-viewport')   as HTMLDivElement
  const scanLine     = document.getElementById('qr-scan-line')  as HTMLDivElement
  const cardIdle     = document.getElementById('card-idle')     as HTMLDivElement
  const cardScanning = document.getElementById('card-scanning') as HTMLDivElement
  const cardSuccess  = document.getElementById('card-success')  as HTMLDivElement
  const deriveStatus = document.getElementById('derive-status') as HTMLParagraphElement
  const progTrack    = document.getElementById('scan-progress-track') as HTMLDivElement
  const progFill     = document.getElementById('scan-progress-fill')  as HTMLDivElement

  const phases = [
    { msg: 'LEYENDO QR...',          color: '#38b764', dur: 700  },
    { msg: 'EXTRAYENDO CÉDULA...',   color: '#38b764', dur: 900  },
    { msg: 'DERIVANDO LLAVE...',     color: '#ffcd75', dur: 900  },
    { msg: 'VERIFICANDO FIRMA...',   color: '#ffcd75', dur: 700  },
    { msg: 'MÉDICO VERIFICADO ✓',    color: '#38b764', dur: 500  },
  ]
  const totalDur = phases.reduce((s, p) => s + p.dur, 0)

  function showPanel(panel: 'idle' | 'scanning' | 'success') {
    cardIdle.style.display     = panel === 'idle'     ? 'flex' : 'none'
    cardScanning.style.display = panel === 'scanning' ? 'flex' : 'none'
    cardSuccess.style.display  = panel === 'success'  ? 'flex' : 'none'
  }

  btn.addEventListener('click', () => {
    btn.disabled = true
    btn.textContent = 'ESCANEANDO...'
    btn.style.color = '#ffcd75'
    btn.style.borderColor = '#ffcd75'

    showPanel('scanning')
    progTrack.style.display = 'block'

    let elapsed = 0
    const pti = setInterval(() => {
      elapsed += 40
      const pct = Math.min(100, Math.round((elapsed / totalDur) * 100))
      progFill.style.width = pct + '%'
      if (pct >= 100) clearInterval(pti)
    }, 40)

    let delay = 0
    phases.forEach((ph, i) => {
      setTimeout(() => {
        deriveStatus.textContent   = ph.msg
        deriveStatus.style.color   = ph.color
        scanLine.style.boxShadow   = `0 0 12px ${ph.color}`
        scanLine.style.background  = `linear-gradient(90deg,transparent,${ph.color},transparent)`
        viewport.style.borderColor = ph.color

        if (i === phases.length - 1) {
          setTimeout(() => {
            showPanel('success')
            viewport.style.borderColor = '#38b764'
            viewport.style.background  = '#031007'
            sessionStorage.setItem('rxpro_doctor_auth', 'qr_card')
            setTimeout(() => { window.location.href = '/doctor/patient' }, 900)
          }, ph.dur * 0.5)
        }
      }, delay)
      delay += ph.dur
    })
  })

</script>
