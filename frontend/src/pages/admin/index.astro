---
// Panel de administración. Un Admin autenticado (rol "Administrador")
// puede dar de alta clínicas y emitir tarjetas QR para médicos,
// pacientes y farmacéuticos. Al crear un usuario se genera una semilla
// aleatoria de 32 bytes, se deriva su llave pública P-256 y se envía al
// backend junto con el registro. La semilla solo se muestra UNA vez en
// forma de tarjeta QR para imprimir o descargar — no se guarda en BD.
import '../../styles/global.css'
import Icons from '../../components/Icons.astro'
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>RxPro — Panel de Administración</title>
  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem('rxpro_theme') || 'dark';
        if (t !== 'light' && t !== 'dark') t = 'dark';
        document.documentElement.setAttribute('data-theme', t);
      } catch (_) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>
  <style>
    .admin-tab {
      font-family:'Press Start 2P',monospace;font-size:8px;
      padding:10px 14px;border:3px solid var(--border-default);
      background:var(--surface-card);color:var(--text-muted);cursor:pointer;
      transition:all .05s;letter-spacing:.05em;
    }
    .admin-tab:hover { border-color:var(--role-doctor);color:var(--text-primary); }
    .rxpro-theme-toggle {
      display:inline-flex;align-items:center;gap:6px;padding:6px 10px;
      border:2px solid var(--border-default);background:transparent;color:var(--text-muted);
      font-family:'Press Start 2P',monospace;font-size:7px;letter-spacing:.08em;cursor:pointer;
      transition:all .05s;
    }
    .rxpro-theme-toggle:hover { border-color:var(--role-doctor);color:var(--role-doctor); }
    .rxpro-theme-toggle .ico-sun  { display:none; }
    .rxpro-theme-toggle .ico-moon { display:inline-block; }
    :root[data-theme="light"] .rxpro-theme-toggle .ico-sun  { display:inline-block; }
    :root[data-theme="light"] .rxpro-theme-toggle .ico-moon { display:none; }
    .admin-tab.active {
      background:var(--role-doctor);color:#1a1c2c;border-color:var(--role-doctor);
      box-shadow:3px 3px 0 var(--role-doctor-d);
    }
    .admin-input {
      font-family:'VT323',monospace;font-size:18px;padding:8px 10px;
      background:var(--surface-inset);border:2px solid var(--border-default);
      color:var(--text-primary);width:100%;
    }
    .admin-label {
      font-family:'Press Start 2P',monospace;font-size:7px;
      color:var(--text-muted);margin-bottom:5px;display:block;letter-spacing:.04em;
    }
    @media print {
      body:not(.printing-constancia) > *:not(#print-card) { display:none !important; }
      body:not(.printing-constancia) #print-card { position:static !important; background:white !important; }
      body:not(.printing-constancia) #print-card .card-overlay { display:none !important; }
      body.printing-constancia > *:not(#constancia-modal) { display:none !important; }
      body.printing-constancia #constancia-modal { position:static !important; background:white !important; padding:0 !important; }
      body.printing-constancia #constancia-modal .modal-chrome { display:none !important; }
    }
  </style>
</head>
<body style="min-height:100vh;background:var(--surface-page);color:var(--text-primary);padding:0;">

<Icons/>

<!-- TOPBAR -->
<header class="topbar" style="padding:14px 20px;display:flex;align-items:center;justify-content:space-between;background:var(--surface-topbar);border-bottom:4px solid var(--surface-topbar-border);position:sticky;top:0;z-index:50;">
  <div style="display:flex;align-items:center;gap:12px;">
    <svg width="28" height="14" viewBox="0 0 32 16" style="image-rendering:pixelated;">
      <rect x="1" y="3" width="14" height="10" rx="5" fill="#e8003d"/>
      <rect x="17" y="3" width="14" height="10" rx="5" fill="#f4f4f4"/>
      <rect x="15" y="3" width="2" height="10" fill="#1a1c2c"/>
    </svg>
    <span class="rxpro-wordmark" style="font-family:'Press Start 2P',monospace;font-size:12px;letter-spacing:.1em;">RXPRO</span>
    <span style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--role-doctor);padding:4px 8px;border:2px solid var(--role-doctor);margin-left:8px;">ADMIN</span>
  </div>
  <div style="display:flex;align-items:center;gap:10px;">
    <span id="admin-name" style="font-family:'VT323',monospace;font-size:18px;color:var(--text-muted);"></span>
    <button id="rxpro-theme-toggle" type="button" title="Cambiar tema" class="rxpro-theme-toggle">
      <svg class="ico-moon" width="11" height="11" viewBox="0 0 14 14" style="image-rendering:pixelated;">
        <rect x="6" y="0" width="6" height="2" fill="currentColor"/><rect x="3" y="2" width="7" height="2" fill="currentColor"/><rect x="1" y="4" width="7" height="2" fill="currentColor"/><rect x="0" y="6" width="7" height="2" fill="currentColor"/><rect x="1" y="8" width="7" height="2" fill="currentColor"/><rect x="3" y="10" width="7" height="2" fill="currentColor"/><rect x="6" y="12" width="6" height="2" fill="currentColor"/>
      </svg>
      <svg class="ico-sun" width="11" height="11" viewBox="0 0 14 14" style="image-rendering:pixelated;">
        <rect x="6" y="0" width="2" height="3" fill="currentColor"/><rect x="6" y="11" width="2" height="3" fill="currentColor"/><rect x="0" y="6" width="3" height="2" fill="currentColor"/><rect x="11" y="6" width="3" height="2" fill="currentColor"/><rect x="2" y="2" width="2" height="2" fill="currentColor"/><rect x="10" y="2" width="2" height="2" fill="currentColor"/><rect x="2" y="10" width="2" height="2" fill="currentColor"/><rect x="10" y="10" width="2" height="2" fill="currentColor"/><rect x="5" y="4" width="4" height="6" fill="currentColor"/><rect x="4" y="5" width="6" height="4" fill="currentColor"/>
      </svg>
      <span id="rxpro-theme-label">MODO</span>
    </button>
    <button id="logout-btn" class="px-btn px-btn-ghost" style="font-size:7px;padding:6px 10px;">CERRAR SESIÓN</button>
  </div>
</header>

<main style="max-width:1100px;margin:24px auto;padding:0 20px;display:flex;flex-direction:column;gap:20px;">

  <!-- Tabs -->
  <nav id="tabs" style="display:flex;gap:8px;flex-wrap:wrap;">
    <button class="admin-tab active" data-tab="medico" style="display:inline-flex;align-items:center;gap:8px;"><svg width="14" height="16" viewBox="0 0 24 28" style="image-rendering:pixelated;flex-shrink:0;"><use href="#ico-doctor"/></svg>MÉDICO</button>
    <button class="admin-tab" data-tab="paciente" style="display:inline-flex;align-items:center;gap:8px;"><svg width="14" height="16" viewBox="0 0 24 28" style="image-rendering:pixelated;flex-shrink:0;"><use href="#ico-patient"/></svg>PACIENTE</button>
    <button class="admin-tab" data-tab="farmaceutico" style="display:inline-flex;align-items:center;gap:8px;"><svg width="18" height="9" viewBox="0 0 32 16" style="image-rendering:pixelated;flex-shrink:0;"><use href="#ico-pill"/></svg>FARMACÉUTICO</button>
    <button class="admin-tab" data-tab="clinica">CLÍNICA</button>
    <button class="admin-tab" data-tab="auditoria" style="display:inline-flex;align-items:center;gap:8px;"><svg width="14" height="16" viewBox="0 0 20 24" style="image-rendering:pixelated;flex-shrink:0;"><use href="#ico-lock"/></svg>AUDITORÍA</button>
    <button class="admin-tab" data-tab="invalidas" style="display:inline-flex;align-items:center;gap:8px;"><svg width="14" height="14" viewBox="0 0 16 16" style="image-rendering:pixelated;flex-shrink:0;"><use href="#ico-x"/></svg>INVÁLIDAS</button>
  </nav>

  <!-- ------------- FORM: MÉDICO ------------- -->
  <section id="panel-medico" class="admin-panel" style="background:var(--surface-card);border:3px solid var(--border-default);box-shadow:var(--shadow-base);padding:24px;">
    <h2 style="font-family:'Press Start 2P',monospace;font-size:10px;color:var(--role-doctor);margin-bottom:12px;">DAR DE ALTA — MÉDICO</h2>
    <form id="form-medico" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;">
      <label><span class="admin-label">NOMBRE</span><input class="admin-input" name="nombre" required/></label>
      <label><span class="admin-label">APELLIDO PATERNO</span><input class="admin-input" name="paterno" required/></label>
      <label><span class="admin-label">APELLIDO MATERNO</span><input class="admin-input" name="materno"/></label>
      <label><span class="admin-label">CORREO</span><input class="admin-input" type="email" name="correo" required/></label>
      <label><span class="admin-label">CONTRASEÑA INICIAL</span><input class="admin-input" type="text" name="contrasena" required minlength="6"/></label>
      <label><span class="admin-label">CÉDULA PROFESIONAL</span><input class="admin-input" name="cedula" required/></label>
      <label><span class="admin-label">ESPECIALIDAD</span><input class="admin-input" name="especialidad" required/></label>
      <label><span class="admin-label">UNIVERSIDAD</span><input class="admin-input" name="universidad" required/></label>
      <label style="grid-column:1/-1;">
        <span class="admin-label">CLÍNICA</span>
        <select class="admin-input" name="id_clinica" required>
          <option value="">— Selecciona —</option>
        </select>
      </label>
      <button type="submit" class="px-btn px-btn-green px-btn-lg" style="grid-column:1/-1;justify-content:center;">
        GENERAR TARJETA + REGISTRAR
      </button>
    </form>
  </section>

  <!-- ------------- FORM: PACIENTE ------------- -->
  <section id="panel-paciente" class="admin-panel" style="display:none;background:var(--surface-card);border:3px solid var(--border-default);box-shadow:var(--shadow-base);padding:24px;">
    <h2 style="font-family:'Press Start 2P',monospace;font-size:10px;color:var(--role-patient);margin-bottom:12px;">DAR DE ALTA — PACIENTE</h2>
    <form id="form-paciente" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;">
      <label><span class="admin-label">NOMBRE</span><input class="admin-input" name="nombre" required/></label>
      <label><span class="admin-label">APELLIDO PATERNO</span><input class="admin-input" name="paterno" required/></label>
      <label><span class="admin-label">APELLIDO MATERNO</span><input class="admin-input" name="materno"/></label>
      <label><span class="admin-label">CORREO</span><input class="admin-input" type="email" name="correo" required/></label>
      <label><span class="admin-label">CONTRASEÑA INICIAL</span><input class="admin-input" type="text" name="contrasena" required minlength="6"/></label>
      <label><span class="admin-label">CURP</span><input class="admin-input" name="curp" required minlength="18" maxlength="18" style="text-transform:uppercase;"/></label>
      <label><span class="admin-label">FECHA NACIMIENTO</span><input class="admin-input" type="date" name="nacimiento" required/></label>
      <label><span class="admin-label">SEXO</span>
        <select class="admin-input" name="sexo" required>
          <option value="">—</option><option value="M">M</option><option value="F">F</option><option value="O">O</option>
        </select>
      </label>
      <label><span class="admin-label">TELÉFONO DE EMERGENCIA</span><input class="admin-input" name="tel_emergencia" required/></label>
      <label><span class="admin-label">CLÍNICA (OPCIONAL)</span>
        <select class="admin-input" name="id_clinica">
          <option value="">— Ninguna —</option>
        </select>
      </label>
      <button type="submit" class="px-btn px-btn-red px-btn-lg" style="grid-column:1/-1;justify-content:center;background:var(--role-patient);border-color:var(--role-patient);box-shadow:4px 4px 0 var(--role-patient-d);">
        GENERAR TARJETA + REGISTRAR
      </button>
    </form>
  </section>

  <!-- ------------- FORM: FARMACEUTICO ------------- -->
  <section id="panel-farmaceutico" class="admin-panel" style="display:none;background:var(--surface-card);border:3px solid var(--border-default);box-shadow:var(--shadow-base);padding:24px;">
    <h2 style="font-family:'Press Start 2P',monospace;font-size:10px;color:var(--role-pharmacy);margin-bottom:12px;">DAR DE ALTA — FARMACÉUTICO</h2>
    <form id="form-farmaceutico" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;">
      <label><span class="admin-label">NOMBRE</span><input class="admin-input" name="nombre" required/></label>
      <label><span class="admin-label">APELLIDO PATERNO</span><input class="admin-input" name="paterno" required/></label>
      <label><span class="admin-label">APELLIDO MATERNO</span><input class="admin-input" name="materno"/></label>
      <label><span class="admin-label">CORREO</span><input class="admin-input" type="email" name="correo" required/></label>
      <label><span class="admin-label">CONTRASEÑA INICIAL</span><input class="admin-input" type="text" name="contrasena" required minlength="6"/></label>
      <label><span class="admin-label">LICENCIA</span><input class="admin-input" name="licencia" required/></label>
      <label><span class="admin-label">TURNO</span>
        <select class="admin-input" name="turno" required>
          <option value="">—</option>
          <option value="Matutino">Matutino</option>
          <option value="Vespertino">Vespertino</option>
          <option value="Nocturno">Nocturno</option>
        </select>
      </label>
      <label><span class="admin-label">CLÍNICA (OPCIONAL)</span>
        <select class="admin-input" name="id_clinica">
          <option value="">— Ninguna —</option>
        </select>
      </label>
      <button type="submit" class="px-btn px-btn-red px-btn-lg" style="grid-column:1/-1;justify-content:center;">
        GENERAR TARJETA + REGISTRAR
      </button>
    </form>
  </section>

  <!-- ------------- FORM: CLINICA ------------- -->
  <section id="panel-clinica" class="admin-panel" style="display:none;background:var(--surface-card);border:3px solid var(--border-default);box-shadow:var(--shadow-base);padding:24px;">
    <h2 style="font-family:'Press Start 2P',monospace;font-size:10px;color:var(--text-primary);margin-bottom:12px;">DAR DE ALTA — CLÍNICA</h2>
    <form id="form-clinica" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;">
      <label><span class="admin-label">NOMBRE</span><input class="admin-input" name="nombre" required/></label>
      <label><span class="admin-label">CLUES</span><input class="admin-input" name="clues" required/></label>
      <label><span class="admin-label">CALLE</span><input class="admin-input" name="calle" required/></label>
      <label><span class="admin-label">COLONIA</span><input class="admin-input" name="colonia" required/></label>
      <label><span class="admin-label">MUNICIPIO</span><input class="admin-input" name="municipio" required/></label>
      <label><span class="admin-label">ESTADO</span><input class="admin-input" name="estado" required/></label>
      <label><span class="admin-label">CP</span><input class="admin-input" name="cp" required/></label>
      <label><span class="admin-label">TIPO</span>
        <select class="admin-input" name="tipo" required>
          <option value="">—</option>
          <option value="Centro Medico">Centro Médico</option>
          <option value="Hospital">Hospital</option>
        </select>
      </label>
      <button type="submit" class="px-btn px-btn-green px-btn-lg" style="grid-column:1/-1;justify-content:center;">
        REGISTRAR CLÍNICA
      </button>
    </form>
  </section>

  <!-- ------------- AUDITORÍA / REPORTES ------------- -->
  <section id="panel-auditoria" class="admin-panel" style="display:none;background:var(--surface-card);border:3px solid var(--border-default);box-shadow:var(--shadow-base);padding:24px;">
    <h2 style="font-family:'Press Start 2P',monospace;font-size:10px;color:var(--text-primary);margin-bottom:6px;">AUDITORÍA DE RECETAS</h2>
    <p style="font-family:'VT323',monospace;font-size:17px;color:var(--text-muted);margin-bottom:16px;line-height:1.4;">
      Bitácora de transacciones. El admin ve los bloques criptográficos públicos (cápsula, nonce, sobres ECDH); el contenido clínico y la firma del médico permanecen cifrados.
    </p>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:14px;">
      <label><span class="admin-label">ESTADO</span>
        <select id="aud-estado" class="admin-input">
          <option value="">Todos</option>
          <option value="activa">Activa</option>
          <option value="surtida">Surtida</option>
          <option value="expirada">Expirada</option>
        </select>
      </label>
      <label><span class="admin-label">ID MÉDICO (OPC.)</span><input id="aud-medico" class="admin-input" type="number" min="1" placeholder="—"/></label>
      <label><span class="admin-label">ID PACIENTE (OPC.)</span><input id="aud-paciente" class="admin-input" type="number" min="1" placeholder="—"/></label>
      <label><span class="admin-label">FOLIO (OPC.)</span><input id="aud-folio" class="admin-input" placeholder="RX-..."/></label>
      <label><span class="admin-label">DESDE (EMISIÓN)</span><input id="aud-desde" class="admin-input" type="date"/></label>
      <label><span class="admin-label">HASTA (EMISIÓN)</span><input id="aud-hasta" class="admin-input" type="date"/></label>
      <label><span class="admin-label">LÍMITE</span>
        <select id="aud-limit" class="admin-input">
          <option value="50">50</option>
          <option value="100">100</option>
          <option value="200">200</option>
        </select>
      </label>
      <button id="aud-buscar" class="px-btn px-btn-green" style="grid-column:1/-1;justify-content:center;">BUSCAR / ACTUALIZAR</button>
    </div>

    <p id="aud-summary" style="font-family:'VT323',monospace;font-size:18px;color:var(--text-muted);margin-bottom:10px;"></p>

    <div style="overflow-x:auto;border:2px solid var(--border-default);">
      <table style="width:100%;border-collapse:collapse;font-family:'VT323',monospace;font-size:17px;">
        <thead>
          <tr style="background:var(--surface-stepbar);color:var(--text-muted);text-align:left;">
            <th style="padding:8px 10px;font-family:'Press Start 2P',monospace;font-size:7px;">FOLIO</th>
            <th style="padding:8px 10px;font-family:'Press Start 2P',monospace;font-size:7px;">EMISIÓN</th>
            <th style="padding:8px 10px;font-family:'Press Start 2P',monospace;font-size:7px;">ESTADO</th>
            <th style="padding:8px 10px;font-family:'Press Start 2P',monospace;font-size:7px;">MÉDICO</th>
            <th style="padding:8px 10px;font-family:'Press Start 2P',monospace;font-size:7px;">PACIENTE</th>
            <th style="padding:8px 10px;font-family:'Press Start 2P',monospace;font-size:7px;">CONSTANCIA</th>
          </tr>
        </thead>
        <tbody id="aud-tbody">
          <tr><td colspan="6" style="padding:14px;color:var(--text-subtle);">Pulsa BUSCAR para cargar la bitácora.</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ------------- INVÁLIDAS (generador de QR de prueba) ------------- -->
  <section id="panel-invalidas" class="admin-panel" style="display:none;background:var(--surface-card);border:3px solid var(--border-default);box-shadow:var(--shadow-base);padding:24px;">
    <h2 style="font-family:'Press Start 2P',monospace;font-size:13px;color:var(--role-pharmacy);margin-bottom:8px;">GENERAR RECETAS INVÁLIDAS (DEMO)</h2>
    <p style="font-family:'VT323',monospace;font-size:18px;color:var(--text-muted);line-height:1.4;margin-bottom:18px;">
      Genera un código QR que, al ser escaneado por un farmacéutico, simula una receta rechazada. No toca la base de datos: el panel de verificación reconoce el flag <code style="background:var(--surface-inset);padding:1px 6px;">demo_invalid</code> y muestra el error correspondiente.
    </p>

    <div style="display:grid;grid-template-columns:140px 1fr;gap:14px;margin-bottom:18px;align-items:end;">
      <label>
        <span class="admin-label">ID DE RECETA</span>
        <input id="inv-id" class="admin-input" type="number" min="1" value="9999"/>
      </label>
      <p style="font-family:'VT323',monospace;font-size:16px;color:var(--text-subtle);line-height:1.4;">
        Cualquier número sirve para la demo (el verificador corta el flujo antes de consultar el backend cuando viene <code>demo_invalid</code>).
      </p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;margin-bottom:18px;">
      <button type="button" class="px-btn px-btn-red" data-inv="signature"   style="width:100%;justify-content:center;">FIRMA INVÁLIDA</button>
      <button type="button" class="px-btn px-btn-red" data-inv="manipulated" style="width:100%;justify-content:center;">RECETA MANIPULADA</button>
      <button type="button" class="px-btn px-btn-red" data-inv="no_cert"     style="width:100%;justify-content:center;">MÉDICO NO CERTIFICADO</button>
    </div>

    <!-- Resultado: QR + payload + botones -->
    <div id="inv-result" style="display:none;background:var(--surface-inset);border:2px solid var(--border-default);padding:18px;flex-direction:column;align-items:center;gap:12px;">
      <p id="inv-kind-label" style="font-family:'Press Start 2P',monospace;font-size:10px;color:var(--role-pharmacy);">—</p>
      <div style="background:#fff;padding:12px;border:3px solid var(--border-strong);">
        <canvas id="inv-qr" style="image-rendering:pixelated;"></canvas>
      </div>
      <p id="inv-payload" style="font-family:'VT323',monospace;font-size:15px;color:var(--text-muted);word-break:break-all;text-align:center;max-width:520px;"></p>
      <div style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;">
        <button type="button" id="inv-print"    class="px-btn px-btn-ghost" style="justify-content:center;">IMPRIMIR</button>
        <button type="button" id="inv-download" class="px-btn px-btn-ghost" style="justify-content:center;">DESCARGAR PNG</button>
      </div>
    </div>
  </section>

  <!-- ------------- RESULTADOS ------------- -->
  <div id="result-box" style="display:none;background:var(--surface-card);border:3px solid var(--role-doctor);padding:16px;">
    <p id="result-msg" style="font-family:'VT323',monospace;font-size:20px;color:var(--role-doctor);line-height:1.4;"></p>
  </div>

</main>

<!-- ------------- TARJETA IMPRIMIBLE (modal) ------------- -->
<div id="print-card" style="display:none;position:fixed;inset:0;background:rgba(6,7,16,.85);z-index:9999;align-items:center;justify-content:center;padding:20px;">
  <div class="card-overlay" style="background:white;color:#1a1c2c;max-width:500px;width:100%;padding:28px;border:6px solid #1a1c2c;box-shadow:8px 8px 0 #333;display:flex;flex-direction:column;gap:14px;">
    <div id="card-header" style="text-align:center;padding:10px;background:#38b764;color:white;border:3px solid #1a1c2c;">
      <p style="font-family:'Press Start 2P',monospace;font-size:14px;" id="card-role-label">MÉDICO</p>
      <p style="font-family:'VT323',monospace;font-size:18px;margin-top:4px;">RXPRO — TARJETA DE IDENTIDAD</p>
    </div>
    <div style="text-align:center;">
      <p style="font-family:'Press Start 2P',monospace;font-size:9px;color:#333;" id="card-name">NOMBRE COMPLETO</p>
      <p style="font-family:'VT323',monospace;font-size:20px;margin-top:4px;" id="card-identifier">IDENTIFICADOR</p>
    </div>
    <div id="card-qr-container" style="display:flex;justify-content:center;padding:12px;background:white;border:3px solid #1a1c2c;">
      <canvas id="card-qr" style="image-rendering:pixelated;"></canvas>
    </div>
    <p style="font-family:'VT323',monospace;font-size:14px;color:#b13e53;text-align:center;line-height:1.4;">
      <svg width="12" height="12" viewBox="0 0 16 16" style="image-rendering:pixelated;color:#b13e53;vertical-align:middle;"><use href="#ico-x"/></svg> ESTA TARJETA ES LA ÚNICA COPIA.<br/>
      SI SE PIERDE, HAY QUE RE-EMITIRLA.
    </p>
    <div class="card-overlay" style="display:flex;gap:8px;">
      <button id="btn-print" class="px-btn px-btn-green" style="flex:1;justify-content:center;">IMPRIMIR</button>
      <button id="btn-download" class="px-btn px-btn-ghost" style="flex:1;justify-content:center;">DESCARGAR PNG</button>
      <button id="btn-close-card" class="px-btn px-btn-ghost" style="flex:1;justify-content:center;">CERRAR</button>
    </div>
  </div>
</div>

<!-- ------------- CONSTANCIA (modal auditoría) ------------- -->
<div id="constancia-modal" style="display:none;position:fixed;inset:0;background:rgba(6,7,16,.85);z-index:9999;overflow-y:auto;padding:24px;">
  <div style="max-width:768px;margin:0 auto;">
    <div class="modal-chrome" style="display:flex;gap:8px;margin-bottom:12px;justify-content:flex-end;">
      <button id="btn-print-constancia" class="px-btn px-btn-green" style="justify-content:center;">IMPRIMIR / PDF</button>
      <button id="btn-close-constancia" class="px-btn px-btn-ghost" style="justify-content:center;">CERRAR</button>
    </div>
    <div id="constancia-body"></div>
  </div>
</div>

<script>
  import { Api, ApiError, getSession, clearSession } from '../../utils/api.ts'
  import { renderConstanciaAdminHTML } from '../../utils/constanciaAdmin.ts'
  import type { RecetaDetailDTO } from '../../utils/api.ts'
  import type {
    ClinicaPublicDTO, MedicoCreateDTO, PacienteCreateDTO, FarmaceuticoCreateDTO,
  } from '../../utils/api.ts'
  import { generateCardSeed, deriveKeysFromSeed } from '../../crypto/seedDerivation.ts'
  import { encodeCardQr, type CardRol } from '../../utils/cardQr.ts'
  import QRCode from 'qrcode'

  // Guard: solo admin pasa.
  const session = getSession()
  if (!session || session.role !== 'Administrador') {
    window.location.replace('/admin/login')
  } else {
    const adminName = document.getElementById('admin-name') as HTMLSpanElement
    if (adminName) adminName.textContent = session.correo
  }

  // ── Tabs ──
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.admin-tab'))
  const panels = Array.from(document.querySelectorAll<HTMLElement>('.admin-panel'))
  tabs.forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.tab || ''
      tabs.forEach(b => b.classList.toggle('active', b === btn))
      panels.forEach(p => {
        p.style.display = p.id === 'panel-' + id ? 'block' : 'none'
      })
    })
  })

  // ── Logout ──
  ;(document.getElementById('logout-btn') as HTMLButtonElement).addEventListener('click', () => {
    clearSession()
    window.location.replace('/admin/login')
  })

  // ── Theme toggle (claro ⇄ oscuro, persistido) ──
  try {
    const toggleBtn = document.getElementById('rxpro-theme-toggle')
    const toggleLbl = document.getElementById('rxpro-theme-label')
    const applyLabel = () => {
      const t = document.documentElement.getAttribute('data-theme') || 'dark'
      if (toggleLbl) toggleLbl.textContent = t === 'light' ? 'CLARO' : 'OSCURO'
    }
    applyLabel()
    toggleBtn?.addEventListener('click', () => {
      const cur = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark'
      const next = cur === 'light' ? 'dark' : 'light'
      document.documentElement.setAttribute('data-theme', next)
      try { localStorage.setItem('rxpro_theme', next) } catch {}
      applyLabel()
    })
  } catch { /* noop */ }

  // ── Cargar clínicas en los selects ──
  async function cargarClinicas() {
    try {
      const list: ClinicaPublicDTO[] = await Api.listarClinicas()
      const selects = document.querySelectorAll<HTMLSelectElement>('select[name="id_clinica"]')
      selects.forEach(sel => {
        const required = sel.required
        const placeholder = required ? '— Selecciona —' : '— Ninguna —'
        sel.innerHTML = `<option value="">${placeholder}</option>`
        for (const c of list) {
          const opt = document.createElement('option')
          opt.value = String(c.id_clinica)
          opt.textContent = `${c.nombre} (${c.clues})`
          sel.appendChild(opt)
        }
      })
    } catch (err) {
      console.warn('No se pudieron cargar las clínicas:', err)
    }
  }
  cargarClinicas()

  // ── Helpers de UI ──
  const resultBox = document.getElementById('result-box') as HTMLDivElement
  const resultMsg = document.getElementById('result-msg') as HTMLParagraphElement

  function showResult(msg: string, isError = false) {
    resultMsg.textContent = msg
    resultBox.style.borderColor = isError ? 'var(--role-pharmacy)' : 'var(--role-doctor)'
    resultMsg.style.color         = isError ? 'var(--role-pharmacy)' : 'var(--role-doctor)'
    resultBox.style.display = 'block'
  }

  function errMsg(err: unknown): string {
    if (err instanceof ApiError) return `Error ${err.status}: ${err.detail}`
    return (err as any)?.message || 'Error desconocido.'
  }

  function formToObject(form: HTMLFormElement): Record<string, any> {
    const fd = new FormData(form)
    const out: Record<string, any> = {}
    fd.forEach((v, k) => { out[k] = typeof v === 'string' ? v.trim() : v })
    // id_clinica: pasar a number | null
    if ('id_clinica' in out) {
      out.id_clinica = out.id_clinica ? Number(out.id_clinica) : null
    }
    return out
  }

  // ── Modal de tarjeta ──
  const cardModal = document.getElementById('print-card') as HTMLDivElement
  const cardCanvas = document.getElementById('card-qr') as HTMLCanvasElement
  const cardRoleLabel = document.getElementById('card-role-label') as HTMLParagraphElement
  const cardName = document.getElementById('card-name') as HTMLParagraphElement
  const cardId = document.getElementById('card-identifier') as HTMLParagraphElement
  const cardHeader = document.getElementById('card-header') as HTMLDivElement

  const roleColor: Record<CardRol, string> = {
    Medico: '#38b764',
    Paciente: '#41a6f6',
    Farmaceutico: '#e8003d',
  }
  const roleLabelES: Record<CardRol, string> = {
    Medico: 'MÉDICO', Paciente: 'PACIENTE', Farmaceutico: 'FARMACÉUTICO',
  }

  async function showCard(rol: CardRol, nombre: string, identificador: string, seedHex: string) {
    const payload = encodeCardQr({ rol, identificador, seedHex })
    cardHeader.style.background = roleColor[rol]
    cardRoleLabel.textContent = roleLabelES[rol]
    cardName.textContent = nombre
    cardId.textContent = identificador
    await QRCode.toCanvas(cardCanvas, payload, {
      errorCorrectionLevel: 'M',
      margin: 1,
      width: 320,
      color: { dark: '#1a1c2c', light: '#ffffff' },
    })
    cardModal.style.display = 'flex'
  }

  ;(document.getElementById('btn-close-card') as HTMLButtonElement).addEventListener('click', () => {
    cardModal.style.display = 'none'
  })
  ;(document.getElementById('btn-print') as HTMLButtonElement).addEventListener('click', () => {
    window.print()
  })
  ;(document.getElementById('btn-download') as HTMLButtonElement).addEventListener('click', () => {
    const link = document.createElement('a')
    link.download = `tarjeta-rxpro-${cardId.textContent}.png`
    link.href = cardCanvas.toDataURL('image/png')
    link.click()
  })

  // ── Autocompletado de CURP en Formulario Paciente ──
  import { decodificarCURP } from '../../utils/curpUtils.ts'

  const formPaciente = document.getElementById('form-paciente') as HTMLFormElement
  if (formPaciente) {
    const curpInput = formPaciente.querySelector('[name="curp"]') as HTMLInputElement
    const nacimientoInput = formPaciente.querySelector('[name="nacimiento"]') as HTMLInputElement
    const sexoSelect = formPaciente.querySelector('[name="sexo"]') as HTMLSelectElement

    curpInput?.addEventListener('input', () => {
      let curpVal = curpInput.value.toUpperCase()
      curpInput.value = curpVal // Fuerza a mayúsculas mientras el admin teclea

      if (curpVal.length === 18) {
        // Extrae los datos usando tu utilidad local
        const datos = decodificarCURP(curpVal)
        
        if (datos) {
          // Llena la fecha
          if (nacimientoInput) nacimientoInput.value = datos.fechaNacimiento
          
          // Mapea el género a los values exactos de tu select ('M' o 'F')
          if (sexoSelect) {
            if (datos.genero === 'Hombre') sexoSelect.value = 'M'
            else if (datos.genero === 'Mujer') sexoSelect.value = 'F'
          }
        }
      }
    })
  }

  // ── Submits ──
  async function handleCreateUser(
    form: HTMLFormElement,
    rol: CardRol,
    identifierField: 'cedula' | 'curp' | 'licencia',
    createFn: (body: any) => Promise<any>,
  ) {
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement
    const original = btn.textContent || ''
    btn.disabled = true
    btn.textContent = 'GENERANDO...'
    try {
      const data = formToObject(form)
      // 1) Generar semilla y derivar llave pública
      const seedHex = generateCardSeed()
      const { publicKeyHex } = deriveKeysFromSeed(seedHex,"sign")
      // 2) Registrar en backend con la pública ya derivada
      const body = { ...data, llave_publica: publicKeyHex }
      const user = await createFn(body)
      // 3) Mostrar tarjeta imprimible con la semilla recién creada
      const identificador = (data[identifierField] || '').toString().toUpperCase()
      const nombre = `${data.nombre} ${data.paterno}${data.materno ? ' ' + data.materno : ''}`.toUpperCase()
      await showCard(rol, nombre, identificador, seedHex)
      showResult(`${roleLabelES[rol]} creado (id=${user.id_usuario}, ${identificador}). Tarjeta lista para imprimir.`)
      form.reset()
    } catch (err) {
      showResult(errMsg(err), true)
    } finally {
      btn.disabled = false
      btn.textContent = original
    }
  }

  ;(document.getElementById('form-medico') as HTMLFormElement).addEventListener('submit', (e) => {
    e.preventDefault()
    handleCreateUser(e.currentTarget as HTMLFormElement, 'Medico', 'cedula', (body) => Api.registerMedico(body as MedicoCreateDTO))
  })
  ;(document.getElementById('form-paciente') as HTMLFormElement).addEventListener('submit', (e) => {
    e.preventDefault()
    handleCreateUser(e.currentTarget as HTMLFormElement, 'Paciente', 'curp', (body) => Api.registerPaciente(body as PacienteCreateDTO))
  })
  ;(document.getElementById('form-farmaceutico') as HTMLFormElement).addEventListener('submit', (e) => {
    e.preventDefault()
    handleCreateUser(e.currentTarget as HTMLFormElement, 'Farmaceutico', 'licencia', (body) => Api.registerFarmaceutico(body as FarmaceuticoCreateDTO))
  })

  ;(document.getElementById('form-clinica') as HTMLFormElement).addEventListener('submit', async (e) => {
    e.preventDefault()
    const form = e.currentTarget as HTMLFormElement
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement
    const original = btn.textContent || ''
    btn.disabled = true
    btn.textContent = 'REGISTRANDO...'
    try {
      const data = formToObject(form)
      // id_clinica no aplica aquí
      delete data.id_clinica
      const c = await Api.crearClinica(data as any)
      showResult(`Clínica creada (id=${c.id_clinica}, ${c.nombre}).`)
      form.reset()
      cargarClinicas()
    } catch (err) {
      showResult(errMsg(err), true)
    } finally {
      btn.disabled = false
      btn.textContent = original
    }
  })

  // ── Auditoría / constancias ──
  const audTbody = document.getElementById('aud-tbody') as HTMLTableSectionElement
  const audSummary = document.getElementById('aud-summary') as HTMLParagraphElement
  const constanciaModal = document.getElementById('constancia-modal') as HTMLDivElement
  const constanciaBody = document.getElementById('constancia-body') as HTMLDivElement

  function fechaCorta(iso: string): string {
    const d = new Date(iso)
    return isNaN(d.getTime()) ? iso : d.toISOString().slice(0, 16).replace('T', ' ')
  }
  function estadoTxt(r: RecetaDetailDTO): string {
    if (r.estado === 'surtida') return 'SURTIDA'
    if (r.vencida) return 'VENCIDA'
    return r.estado.toUpperCase()
  }

  let audCache: RecetaDetailDTO[] = []

  async function buscarAuditoria() {
    const btn = document.getElementById('aud-buscar') as HTMLButtonElement
    const original = btn.textContent || ''
    btn.disabled = true
    btn.textContent = 'CONSULTANDO...'
    try {
      const estado = (document.getElementById('aud-estado') as HTMLSelectElement).value
      const medico = (document.getElementById('aud-medico') as HTMLInputElement).value
      const paciente = (document.getElementById('aud-paciente') as HTMLInputElement).value
      const folio = (document.getElementById('aud-folio') as HTMLInputElement).value.trim()
      const limit = Number((document.getElementById('aud-limit') as HTMLSelectElement).value)
      const desde = (document.getElementById('aud-desde') as HTMLInputElement).value
      const hasta = (document.getElementById('aud-hasta') as HTMLInputElement).value

      const filters: any = { limit }
      if (estado) filters.estado = estado
      if (medico) filters.id_medico = Number(medico)
      if (paciente) filters.id_paciente = Number(paciente)
      if (folio) filters.folio = folio

      let list = await Api.listarRecetas(filters)

      // El backend no filtra por rango de fechas: se aplica en cliente
      // sobre la fecha de emisión (creada_en).
      if (desde) list = list.filter(r => r.creada_en >= desde)
      if (hasta) list = list.filter(r => r.creada_en <= hasta + 'T23:59:59.999Z')

      audCache = list
      renderTabla(list)
    } catch (err) {
      audTbody.innerHTML = `<tr><td colspan="6" style="padding:14px;color:var(--role-pharmacy);">${errMsg(err)}</td></tr>`
      audSummary.textContent = ''
    } finally {
      btn.disabled = false
      btn.textContent = original
    }
  }

  function renderTabla(list: RecetaDetailDTO[]) {
    if (!list.length) {
      audTbody.innerHTML = `<tr><td colspan="6" style="padding:14px;color:var(--text-subtle);">Sin recetas para los filtros dados.</td></tr>`
      audSummary.textContent = '0 recetas.'
      return
    }
    const surtidas = list.filter(r => r.estado === 'surtida').length
    const vencidas = list.filter(r => r.vencida).length
    const activas = list.length - surtidas - vencidas
    audSummary.textContent = `${list.length} recetas · ${activas} activas · ${surtidas} surtidas · ${vencidas} vencidas.`

    audTbody.innerHTML = list.map(r => `
      <tr style="border-top:2px solid var(--border-default);">
        <td style="padding:8px 10px;font-family:'VT323',monospace;color:var(--text-primary);">${r.folio}</td>
        <td style="padding:8px 10px;color:var(--text-muted);">${fechaCorta(r.creada_en)}</td>
        <td style="padding:8px 10px;color:var(--text-primary);">${estadoTxt(r)}</td>
        <td style="padding:8px 10px;color:var(--text-muted);">${r.medico?.nombre_completo ?? '—'}</td>
        <td style="padding:8px 10px;color:var(--text-muted);">${r.paciente?.nombre_completo ?? '—'}</td>
        <td style="padding:8px 10px;"><button class="px-btn px-btn-ghost aud-ver" data-id="${r.id_receta}" style="font-size:7px;padding:5px 8px;">VER</button></td>
      </tr>`).join('')

    audTbody.querySelectorAll<HTMLButtonElement>('.aud-ver').forEach(b => {
      b.addEventListener('click', () => verConstancia(Number(b.dataset.id)))
    })
  }

  async function verConstancia(idReceta: number) {
    const receta = audCache.find(r => r.id_receta === idReceta)
    if (!receta) return
    constanciaBody.innerHTML = `<div style="background:#fff;color:#374151;padding:24px;font-family:system-ui,Arial,sans-serif;font-size:13px;">Generando constancia…</div>`
    constanciaModal.style.display = 'block'
    try {
      const cripto = await Api.obtenerRecetaCripto(idReceta)
      constanciaBody.innerHTML = renderConstanciaAdminHTML(receta, cripto)
    } catch (err) {
      constanciaBody.innerHTML = `<div style="background:#fff;color:#b91c1c;padding:24px;font-family:system-ui,Arial,sans-serif;font-size:13px;">No se pudo cargar el sobre criptográfico: ${errMsg(err)}</div>`
    }
  }

  ;(document.getElementById('aud-buscar') as HTMLButtonElement).addEventListener('click', buscarAuditoria)
  ;(document.getElementById('btn-close-constancia') as HTMLButtonElement).addEventListener('click', () => {
    constanciaModal.style.display = 'none'
  })
  ;(document.getElementById('btn-print-constancia') as HTMLButtonElement).addEventListener('click', () => {
    document.body.classList.add('printing-constancia')
    window.print()
    document.body.classList.remove('printing-constancia')
  })

  // ── Generador de recetas inválidas (demo) ─────────────────────────────
  const KIND_LABELS: Record<string, string> = {
    signature:   'FIRMA INVÁLIDA',
    manipulated: 'RECETA MANIPULADA',
    no_cert:     'MÉDICO NO CERTIFICADO',
  }
  const invIdInput   = document.getElementById('inv-id')        as HTMLInputElement
  const invResult    = document.getElementById('inv-result')    as HTMLDivElement
  const invCanvas    = document.getElementById('inv-qr')        as HTMLCanvasElement
  const invPayload   = document.getElementById('inv-payload')   as HTMLParagraphElement
  const invKindLabel = document.getElementById('inv-kind-label') as HTMLParagraphElement

  let invLastKind = ''
  let invLastId   = 0

  async function generateInvalid(kind: string) {
    const id = Number(invIdInput?.value || 9999)
    if (!Number.isFinite(id) || id <= 0) return
    invLastKind = kind
    invLastId   = id
    const payload = `rxpro://receta?id=${id}&demo_invalid=${kind}`
    invKindLabel.textContent = `${KIND_LABELS[kind] || kind} · ID ${id}`
    invKindLabel.style.color = 'var(--role-pharmacy)'
    invPayload.textContent   = payload
    await QRCode.toCanvas(invCanvas, payload, {
      width: 280,
      margin: 1,
      errorCorrectionLevel: 'M',
      color: { dark: '#1a1c2c', light: '#ffffff' },
    })
    invResult.style.display = 'flex'
  }

  document.querySelectorAll<HTMLButtonElement>('[data-inv]').forEach(btn => {
    btn.addEventListener('click', () => generateInvalid(btn.dataset.inv || ''))
  })

  ;(document.getElementById('inv-download') as HTMLButtonElement | null)?.addEventListener('click', () => {
    if (!invLastKind) return
    const link = document.createElement('a')
    link.download = `qr-demo-${invLastKind}-${invLastId}.png`
    link.href = invCanvas.toDataURL('image/png')
    link.click()
  })

  ;(document.getElementById('inv-print') as HTMLButtonElement | null)?.addEventListener('click', () => {
    window.print()
  })
</script>
</body>
</html>
