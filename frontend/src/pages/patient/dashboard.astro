---
import FlowLayout from '../../layouts/FlowLayout.astro'
const steps=[{label:'ACCESO',href:'/patient'},{label:'MIS RECETAS',href:'/patient/dashboard'},{label:'DETALLE',href:'/patient/detail'}]
---
<FlowLayout title="Mis Recetas" role="patient" steps={steps} currentStep={1} back="/patient" wide={true}>
<div class="anim-slide" style="display:flex;flex-direction:column;gap:14px;">

  <!-- Patient header (sin QR — la tarjeta de identidad ya fue mostrada al ingresar) -->
  <div style="background:var(--surface-card);border:3px solid var(--role-patient);box-shadow:var(--shadow-blue);padding:14px 16px;display:flex;align-items:center;gap:14px;">
    <svg width="32" height="38" viewBox="0 0 24 28" style="image-rendering:pixelated;flex-shrink:0;"><use href="#ico-patient"/></svg>
    <div>
      <p id="patient-header-name" style="font-family:'Press Start 2P',monospace;font-size:11px;color:var(--role-patient);">PACIENTE</p>
      <p id="patient-header-sub"  style="font-family:'VT323',monospace;font-size:18px;color:var(--text-muted);margin-top:2px;">—</p>
    </div>
  </div>

  <!-- Búsqueda por folio (API real) -->
  <div style="background:var(--surface-card);border:3px solid var(--role-patient);box-shadow:4px 4px 0 var(--role-patient-d);padding:16px;">
    <p style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--role-patient);margin-bottom:12px;">BUSCAR POR FOLIO</p>
    <form id="search-folio-form" style="display:flex;gap:12px;">
      <input type="text" id="search-folio-input" name="folio" placeholder="rx-1-2026..." class="px-input blue" style="flex:1;text-transform:uppercase;"/>
      <button type="button" id="btn-clear-folio" class="px-btn px-btn-blue" style="display:none; padding: 0 12px; font-size: 10px;">
        MOSTRAR TODO
      </button>
      <button type="button" id="btn-search-folio" class="px-btn px-btn-blue">BUSCAR</button>
    </form>
  </div>

  <!-- Stats (se llenan tras fetch) -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
    <div class="px-stat"><span class="px-stat-num" style="color:var(--text-primary);" id="stat-total">—</span><span class="px-stat-label">TOTAL</span></div>
    <div class="px-stat"><span class="px-stat-num" style="color:var(--role-doctor);" id="stat-surtida">—</span><span class="px-stat-label">SURTIDAS</span></div>
    <div class="px-stat"><span class="px-stat-num" style="color:var(--accent-warn);" id="stat-pendiente">—</span><span class="px-stat-label">ACTIVAS</span></div>
  </div>

  <!-- Loader -->
  <div id="rx-loading" style="background:var(--surface-card);border:3px solid var(--role-patient);padding:18px;display:flex;flex-direction:column;align-items:center;gap:12px;">
    <div class="px-spinner" style="border-top-color:var(--role-patient);"></div>
    <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--role-patient);" class="anim-blink">
      CONSULTANDO RECETAS...
    </p>
  </div>

  <!-- Error del listado -->
  <div id="rx-error" style="display:none;background:rgba(232,0,61,.12);box-shadow:var(--shadow-red);border:3px solid var(--role-pharmacy);padding:14px;">
    <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--role-pharmacy);margin-bottom:8px;display:flex;align-items:center;gap:8px;"><svg width="14" height="14" viewBox="0 0 16 16" style="image-rendering:pixelated;color:var(--role-pharmacy);flex-shrink:0;"><use href="#ico-x"/></svg>NO FUE POSIBLE CARGAR TUS RECETAS</p>
    <p id="rx-error-msg" style="font-family:'VT323',monospace;font-size:19px;color:var(--text-muted);line-height:1.5;"></p>
  </div>

  <!-- Empty state -->
  <div id="rx-empty" style="display:none;background:var(--surface-card);border:3px dashed var(--border-default);padding:30px 18px;text-align:center;">
    <p style="font-family:'Press Start 2P',monospace;font-size:9px;color:var(--text-dim);margin-bottom:8px;">SIN RECETAS TODAVÍA</p>
    <p style="font-family:'VT323',monospace;font-size:20px;color:var(--text-muted);">Cuando un médico te emita una receta aparecerá aquí automáticamente.</p>
  </div>

  <!-- Prescription list -->
  <div id="rx-list" style="display:flex;flex-direction:column;gap:4px;"></div>

</div>
</FlowLayout>

<script>
  import { Api, ApiError, getSession } from '../../utils/api.ts'
  import { requireSession } from '../../utils/sessionGuard.ts'
  requireSession('Paciente', '/patient')

  // --- Cabecera con el correo / nombre real si hay sesión ---
  const session = getSession()
  const headerName = document.getElementById('patient-header-name') as HTMLParagraphElement
  const headerSub  = document.getElementById('patient-header-sub')  as HTMLParagraphElement
  if (session) {
    headerName.textContent = (session.nombre || session.correo || 'PACIENTE').toUpperCase()
    headerSub.textContent  = `ID USUARIO: ${session.id}`
  }


  // --- Cargar el listado real desde el backend ---
  const loading  = document.getElementById('rx-loading')  as HTMLDivElement
  const errPanel = document.getElementById('rx-error')    as HTMLDivElement
  const errMsg   = document.getElementById('rx-error-msg')as HTMLParagraphElement
  const empty    = document.getElementById('rx-empty')    as HTMLDivElement
  const listEl   = document.getElementById('rx-list')     as HTMLDivElement
  const statTotal     = document.getElementById('stat-total')     as HTMLSpanElement
  const statSurtida   = document.getElementById('stat-surtida')   as HTMLSpanElement
  const statPendiente = document.getElementById('stat-pendiente') as HTMLSpanElement

  const searchForm = document.getElementById('search-folio-form') as HTMLFormElement
  const searchInput = document.getElementById('search-folio-input') as HTMLInputElement
  const searchBtn = document.getElementById('btn-search-folio') as HTMLButtonElement
  const clearBtn = document.getElementById('btn-clear-folio') as HTMLButtonElement

  // 1. Evitamos que la tecla "Enter" recargue la página y forzamos el clic del botón
  searchForm?.addEventListener('submit', (e) => {
    e.preventDefault()
    searchBtn.click() // Simulamos un clic en el botón para que ejecute la búsqueda
  })

  // 2. Escuchamos el clic directo en el botón (ya no el submit del form)
  
  searchBtn?.addEventListener('click', async () => {
    const folio = searchInput.value.trim().toUpperCase()
    const id_paciente = session?.id
    if (!id_paciente)
      return
    if (!folio) {
      window.showToast?.('Ingresa un folio para buscar', 'var(--accent-warn)')
      return
    }

    // Iniciamos estado de carga
    searchBtn.disabled = true
    searchBtn.textContent = '...'

    try {
      // Realizamos la búsqueda
      const results = await Api.listarRecetas({ folio,id_paciente } as any)
      console.log("Resultados: ",results)
      if (results && results.length > 0) {
        renderList(results)
        window.showToast?.('Receta encontrada', "var(--role-patient)")
      } else {
        renderList([]) 
        window.showToast?.('No se encontró ninguna receta con ese folio', 'var(--accent-warn)')
      }
      clearBtn.style.display = 'block'
    } catch (error) {
      console.error('Error en búsqueda por folio:', error)
      renderList([])
      window.showToast?.('No se encontró el folio solicitado', 'var(--accent-warn)')
    } finally {
      // Restauramos el botón sin importar qué pase
      searchBtn.disabled = false
      searchBtn.textContent = 'BUSCAR'
    }
  })
  clearBtn?.addEventListener('click', () => {
    searchInput.value = ''           // 1. Vaciamos la barra de búsqueda
    clearBtn.style.display = 'none'  // 2. Volvemos a ocultar el botón de limpiar
    loadRecetas()                    // 3. Re-ejecutamos tu función original que trae todo el listado
  })


  function formatFecha(iso: string): string {
    try {
      const d = new Date(iso)
      const months = ['ENE','FEB','MAR','ABR','MAY','JUN','JUL','AGO','SEP','OCT','NOV','DIC']
      return `${String(d.getDate()).padStart(2,'0')} ${months[d.getMonth()]}`
    } catch { return iso.slice(0,10) }
  }

  function makeBadge(kind: 'red' | 'yellow' | 'green', text: string): HTMLSpanElement {
    const s = document.createElement('span')
    s.className = `px-badge px-badge-${kind}`
    s.textContent = text
    return s
  }

  function renderList(rxs: Array<any>, highlightId?: number) {
    // Se construye con DOM API (no innerHTML) porque los campos provienen
    // del backend (folio, nombre del médico, nombre del paciente) y no
    // deben poder interpretarse como HTML/JS.
    listEl.replaceChildren()
    for (const [idx, rx] of rxs.entries()) {
      const isNew       = highlightId === rx.id_receta
      const isVencida   = !!rx.vencida && rx.estado !== 'surtida'
      const isPendiente = rx.estado === 'activa' && !isVencida
      const rxBorder = isVencida ? '#a53030' : (isNew ? '#ffcd75' : (isPendiente ? '#ffcd75' : '#29366f'))
      const rxShadow = isVencida ? 'var(--shadow-red)' : (isNew ? '4px 4px 0 var(--accent-warn-d)' : (isPendiente ? '4px 4px 0 var(--accent-warn-d)' : 'var(--shadow-base)'))
      const bg       = isNew ? 'rgba(56,183,100,.12)' : 'var(--surface-card)'
      const folio = (rx.folio).toUpperCase()
      const medLabel = `DR. ${String(rx.medico?.nombre_completo || '—').toUpperCase()}`
      const fecha    = formatFecha(rx.creada_en)
      const pacNombre = rx.paciente?.nombre_completo || ''

      const a = document.createElement('a')
      a.href = `/patient/detail?id=${rx.id_receta}`
      a.className = 'anim-slide d' + (idx+1)
      a.style.cssText =
        'text-decoration:none;display:flex;align-items:center;gap:14px;padding:16px;' +
        `background:${bg};border:3px solid ${rxBorder};box-shadow:${rxShadow};position:relative;transition:transform .08s;`
      a.onmouseover = () => { a.style.transform = 'translateX(4px)' }
      a.onmouseout  = () => { a.style.transform = '' }

      if (isNew) {
        const chip = document.createElement('div')
        chip.style.cssText = "position:absolute;top:0;right:0;background:#ffcd75;color:#1a1c2c;font-family:'Press Start 2P',monospace;font-size:7px;padding:4px 8px;"
        chip.textContent = 'NEW!'
        a.appendChild(chip)
      }

      const icon = document.createElement('span')
      icon.style.cssText = 'flex-shrink:0;display:inline-flex;'
      icon.innerHTML = '<svg width="34" height="17" viewBox="0 0 32 16" style="image-rendering:pixelated;"><use href="#ico-pill"/></svg>'
      a.appendChild(icon)

      const main = document.createElement('div')
      main.style.cssText = 'flex:1;min-width:0;'
      const pFolio = document.createElement('p')
      pFolio.style.cssText = "font-family:'Press Start 2P',monospace;font-size:9px;color:var(--text-primary);margin-bottom:6px;"
      pFolio.textContent = folio
      const pMed = document.createElement('p')
      pMed.style.cssText = "font-family:'VT323',monospace;font-size:19px;color:#c0cbdc;"
      pMed.textContent = medLabel
      const pFecha = document.createElement('p')
      pFecha.style.cssText = "font-family:'VT323',monospace;font-size:17px;color:#5b6ee1;"
      pFecha.textContent = `${fecha} · PACIENTE ${pacNombre}`
      main.append(pFolio, pMed, pFecha)
      a.appendChild(main)

      const right = document.createElement('div')
      right.style.cssText = 'display:flex;flex-direction:column;align-items:flex-end;gap:6px;'
      const badge = isVencida
        ? makeBadge('red', 'VENCIDA')
        : (isPendiente ? makeBadge('yellow', 'ACTIVA') : makeBadge('green', 'SURTIDA'))
      const arrow = document.createElement('span')
      arrow.style.cssText = "font-family:'Press Start 2P',monospace;font-size:9px;color:#5b6ee1;"
      arrow.textContent = '►'
      right.append(badge, arrow)
      a.appendChild(right)

      listEl.appendChild(a)
    }
  }

  async function loadRecetas() {
    loading.style.display = 'block'
    errPanel.style.display = 'none'
    empty.style.display = 'none'

    const idPaciente = session?.id && session.role === 'Paciente' ? session.id : null

    // Sin sesión de paciente no podemos llamar al listado (el backend exige filtro).
    // Todavía respetamos la receta recién emitida que haya quedado en sessionStorage.
    const lastRaw = sessionStorage.getItem('rxpro_last_receta')
    const last    = lastRaw ? (() => { try { return JSON.parse(lastRaw) } catch { return null } })() : null
    const highlightId: number | undefined = (last && typeof last.id_receta === 'number') ? last.id_receta : undefined

    if (!idPaciente) {
      loading.style.display = 'none'
      if (last && typeof last.id_receta === 'number') {
        // Renderizamos al menos la receta que acaba de emitirse.
        try {
          const info = await Api.obtenerRecetaInfo(last.id_receta)
          renderList([info], highlightId)
          statTotal.textContent     = '1'
          statSurtida.textContent   = info.estado === 'surtida' ? '1' : '0'
          statPendiente.textContent = info.estado === 'activa'  ? '1' : '0'
        } catch {
          empty.style.display = 'block'
        }
      } else {
        empty.style.display = 'block'
      }
      return
    }

    try {
      const recetas = await Api.listarRecetas({ id_paciente: idPaciente, limit: 100 })
      loading.style.display = 'none'
      if (recetas.length === 0) {
        empty.style.display = 'block'
        statTotal.textContent     = '0'
        statSurtida.textContent   = '0'
        statPendiente.textContent = '0'
        return
      }
      renderList(recetas, highlightId)
      statTotal.textContent     = String(recetas.length)
      statSurtida.textContent   = String(recetas.filter(r => r.estado === 'surtida').length)
      statPendiente.textContent = String(recetas.filter(r => r.estado === 'activa').length)
    } catch (err) {
      loading.style.display = 'none'
      errPanel.style.display = 'block'
      errMsg.textContent = err instanceof ApiError
        ? `Backend ${err.status}: ${err.detail}`
        : (err as any)?.message || 'Error desconocido'
    }
  }

  loadRecetas()
</script>
