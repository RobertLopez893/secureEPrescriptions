---
import FlowLayout from '../../layouts/FlowLayout.astro'
const steps=[{label:'ACCESO',href:'/patient'},{label:'MIS RECETAS',href:'/patient/dashboard'},{label:'DETALLE',href:'/patient/detail'}]
---
<FlowLayout title="Detalle de Receta" role="patient" steps={steps} currentStep={2} back="/patient/dashboard">
<div class="anim-slide" style="display:flex;flex-direction:column;gap:20px;">

  <!-- Status alert -->
  <div id="status-alert" style="background:rgba(255,205,117,.12);border:3px solid var(--accent-warn);box-shadow:4px 4px 0 var(--accent-warn-d);padding:14px;display:flex;align-items:center;gap:12px;">
    <span id="status-icon" style="display:inline-flex;flex-shrink:0;color:var(--accent-warn);" class="anim-bounce"></span>
    <div>
      <p id="status-title" style="font-family:'Press Start 2P',monospace;font-size:9px;color:var(--accent-warn);">LISTA PARA RECOGER</p>
      <p id="status-sub" style="font-family:'VT323',monospace;font-size:20px;color:var(--text-muted);margin-top:4px;">Muestra el código QR en la farmacia</p>
    </div>
  </div>

  <!-- Error inline -->
  <div id="detail-error" style="display:none;background:rgba(232,0,61,.12);box-shadow:var(--shadow-red);border:3px solid var(--role-pharmacy);padding:14px;">
    <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--role-pharmacy);margin-bottom:8px;display:flex;align-items:center;gap:8px;"><svg width="14" height="14" viewBox="0 0 16 16" style="image-rendering:pixelated;color:var(--role-pharmacy);flex-shrink:0;"><use href="#ico-x"/></svg>NO SE PUDO CARGAR</p>
    <p id="detail-error-msg" style="font-family:'VT323',monospace;font-size:19px;color:var(--text-muted);line-height:1.5;"></p>
  </div>

  <!-- BIG QR code -->
  <div style="background:#f4f4f4;border:4px solid var(--role-patient);box-shadow:6px 6px 0 var(--role-patient-d);padding:24px;text-align:center;">
    <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--text-subtle);margin-bottom:20px;letter-spacing:.1em;">CÓDIGO QR — FARMACIA</p>
    <div style="width:200px;height:200px;margin:0 auto;background:white;border:3px solid var(--border-strong);padding:12px;display:flex;align-items:center;justify-content:center;" class="anim-float">
      <svg width="176" height="176" viewBox="0 0 60 60" style="image-rendering:pixelated;">
        <rect width="60" height="60" fill="white"/>
        <!-- QR corners -->
        <rect x="2" y="2" width="20" height="20" rx="2" fill="none" stroke="#1a1c2c" stroke-width="2"/>
        <rect x="6" y="6" width="12" height="12" fill="#1a1c2c"/>
        <rect x="38" y="2" width="20" height="20" rx="2" fill="none" stroke="#1a1c2c" stroke-width="2"/>
        <rect x="42" y="6" width="12" height="12" fill="#1a1c2c"/>
        <rect x="2" y="38" width="20" height="20" rx="2" fill="none" stroke="#1a1c2c" stroke-width="2"/>
        <rect x="6" y="42" width="12" height="12" fill="#1a1c2c"/>
        <!-- Data modules -->
        <rect x="26" y="2" width="4" height="4" fill="#1a1c2c"/>
        <rect x="32" y="2" width="4" height="4" fill="#1a1c2c"/>
        <rect x="26" y="8" width="4" height="4" fill="#1a1c2c"/>
        <rect x="26" y="26" width="4" height="4" fill="#1a1c2c"/>
        <rect x="32" y="26" width="4" height="4" fill="#1a1c2c"/>
        <rect x="38" y="26" width="4" height="4" fill="#1a1c2c"/>
        <rect x="44" y="26" width="4" height="4" fill="#1a1c2c"/>
        <rect x="50" y="26" width="4" height="4" fill="#1a1c2c"/>
        <rect x="26" y="32" width="4" height="4" fill="#1a1c2c"/>
        <rect x="38" y="32" width="4" height="4" fill="#1a1c2c"/>
        <rect x="50" y="32" width="4" height="4" fill="#1a1c2c"/>
        <rect x="26" y="38" width="4" height="4" fill="#1a1c2c"/>
        <rect x="44" y="38" width="4" height="4" fill="#1a1c2c"/>
        <rect x="26" y="44" width="4" height="4" fill="#1a1c2c"/>
        <rect x="38" y="44" width="4" height="4" fill="#1a1c2c"/>
        <rect x="26" y="50" width="4" height="4" fill="#1a1c2c"/>
        <rect x="44" y="50" width="4" height="4" fill="#1a1c2c"/>
        <rect x="50" y="50" width="4" height="4" fill="#1a1c2c"/>
      </svg>
    </div>
    <p id="qr-folio"   style="font-family:'Press Start 2P',monospace;font-size:11px;color:#1a1c2c;margin-top:16px;">XYZ-123</p>
    <p id="qr-vigencia" style="font-family:'VT323',monospace;font-size:20px;color:var(--text-subtle);margin-top:4px;">VÁLIDO HASTA 19 ABR 2026</p>
  </div>

  <!-- Details -->
  <div style="background:var(--surface-card); border:3px solid var(--role-patient); box-shadow:4px 4px 0 var(--role-patient-d); padding:0; overflow:hidden;">
    <div style="background:var(--role-patient); padding:10px 16px;">
      <span style="font-family:'Press Start 2P',monospace; font-size:8px; color:#f4f4f4;display:inline-flex;align-items:center;gap:8px;"><svg width="13" height="17" viewBox="0 0 22 28" style="image-rendering:pixelated;color:#f4f4f4;flex-shrink:0;"><use href="#ico-clipboard"/></svg>DETALLE DE MI RECETA</span>
    </div>
    <div id="resumen-contenido-paciente" style="padding:20px;">
      <p style="font-family:'VT323',monospace; font-size:18px; color:var(--text-muted);" class="anim-blink">Descifrando contenido seguro...</p>
    </div>
  </div>

  <!-- Authentic note -->
  <div id="authentic-note" style="background:rgba(56,183,100,.12);box-shadow:var(--shadow-green);border:3px solid var(--role-doctor);padding:12px;display:flex;align-items:center;gap:10px;">
    <span style="flex-shrink:0;display:inline-flex;color:var(--role-doctor);"><svg width="18" height="14" viewBox="0 0 20 16" style="image-rendering:pixelated;"><use href="#ico-checkmark"/></svg></span>
    <p id="authentic-text" style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--role-doctor);line-height:1.8;">RECETA AUTÉNTICA · FIRMA DEL MÉDICO VERIFICADA</p>
  </div>
</div>
</FlowLayout>

<script>
  import { Api, ApiError } from '../../utils/api.ts'
  import { CryptoEngine, type RecetaCifrada, type RecetaContainer } from '../../crypto/index.ts'
  import { getUserPrivKeyHex, getUserPublicKeyHex } from '../../utils/userKeys.ts'
  import { requireSession } from '../../utils/sessionGuard.ts'

  requireSession('Paciente', '/patient')

  const params = new URLSearchParams(window.location.search)
  const idReceta = Number(params.get('id') || 0)

  const errorBox = document.getElementById('detail-error')       as HTMLDivElement
  const errorMsg = document.getElementById('detail-error-msg')   as HTMLParagraphElement
  const body     = document.getElementById('details-body')       as HTMLDivElement
  const folioEl  = document.getElementById('qr-folio')           as HTMLParagraphElement
  const vigEl    = document.getElementById('qr-vigencia')        as HTMLParagraphElement
  const statusT  = document.getElementById('status-title')       as HTMLParagraphElement
  const statusS  = document.getElementById('status-sub')         as HTMLParagraphElement
  const statusI  = document.getElementById('status-icon')        as HTMLSpanElement
  const authT    = document.getElementById('authentic-text')     as HTMLParagraphElement

  function showError(msg: string) {
    errorMsg.textContent = msg
    errorBox.style.display = 'block'
  }

  function renderRows(rows: Array<{l:string; v:string; big?:boolean}>) {
    // Se usa DOM API (no innerHTML) porque `f.v` proviene de contenido
    // descifrado del backend y no debe interpretarse como HTML.
    body.replaceChildren()
    for (const f of rows) {
      const row = document.createElement('div')
      row.style.cssText = 'display:flex;justify-content:space-between;align-items:flex-start;padding:10px 0;border-bottom:2px solid #29366f;gap:12px;'

      const label = document.createElement('span')
      label.style.cssText = "font-family:'Press Start 2P',monospace;font-size:7px;color:#5b6ee1;flex-shrink:0;width:90px;"
      label.textContent = f.l

      const value = document.createElement('span')
      const size = f.big ? '22px' : '20px'
      const color = f.big ? '#41a6f6' : '#f4f4f4'
      const weight = f.big ? 'font-weight:bold;' : ''
      value.style.cssText = `text-align:right;font-family:'VT323',monospace;font-size:${size};color:${color};${weight}`
      value.textContent = f.v

      row.appendChild(label)
      row.appendChild(value)
      body.appendChild(row)
    }
  }

  async function load() {
    if (!idReceta) return   // mantiene demo estática si no hay ?id=

    try {
      const [info, cripto] = await Promise.all([
        Api.obtenerRecetaInfo(idReceta),
        Api.obtenerRecetaCripto(idReceta),
      ])
      //console.log(info,cripto)
      folioEl.textContent = 'RX-' + String(info.id_receta).padStart(5, '0')
      vigEl.textContent   = 'VÁLIDO HASTA ' + new Date(info.expira_en).toLocaleDateString('es-MX',
        { day:'2-digit', month:'short', year:'numeric' }).toUpperCase()

      // Estado pill
      if (info.estado === 'surtida') {
        statusT.textContent = 'RECETA SURTIDA'
        statusS.textContent = 'Dispensada por la farmacia.'
        statusI.innerHTML = '<svg width="20" height="16" viewBox="0 0 20 16" style="image-rendering:pixelated;"><use href="#ico-checkmark"/></svg>'
        const alert = document.getElementById('status-alert')!
        alert.style.background = 'rgba(56,183,100,.12)'
        alert.style.borderColor = '#38b764'
        statusT.style.color = '#38b764'
        statusI.style.color = '#38b764'
      } else if (info.vencida) {
        statusT.textContent = 'RECETA VENCIDA'
        statusS.textContent = 'Esta receta pasó su fecha de expiración y no puede dispensarse.'
        statusI.innerHTML = '<svg width="20" height="16" viewBox="0 0 16 16" style="image-rendering:pixelated;"><use href="#ico-x"/></svg>'
        const alert = document.getElementById('status-alert')!
        alert.style.background = 'rgba(232,0,61,.12)'
        alert.style.borderColor = '#a53030'
        statusT.style.color = '#a53030'
        statusI.style.color = '#a53030'
      }

      // Descifrado E2E con la llave privada del paciente (derivada de la
      // semilla persistida al hacer login por tarjeta).
      const accesoPaciente = cripto.accesos.find(a => a.rol === 'paciente')
      if (!accesoPaciente) throw new Error('No hay acceso asignado a paciente en esta receta.')

      const privPaciente = getUserPrivKeyHex("paciente","recipes")
      console.log(getUserPublicKeyHex("paciente","recipes"))
      if (!privPaciente) {

        throw new Error('No hay llave privada en esta sesión. Vuelve a iniciar sesión con tu tarjeta QR.')
      }

      // Llave pública del médico: del directorio público del backend.
      const llaveDoctor = await Api.obtenerLlavePublica(cripto.id_medico,"firmas")
      const doctorPubHex = llaveDoctor.llave_publica
      const payload : RecetaCifrada = {capsula_cifrada: cripto.capsula_cifrada, nonce: cripto.nonce, accesos: cripto.accesos}
      //console.log('Payload recibido del backend:', payload)
      const { valido, contenido } = CryptoEngine.abrirReceta(
        payload,
        "paciente",
        privPaciente,
        doctorPubHex,
        'DOC-' + String(info.id_medico),
        'USR-' + String(info.id_paciente),
        'FAR-' + String(info.id_farmaceutico),
        info.folio,
      )
      console.log('Receta descifrada:', contenido)
      console.log('Firma válida:', valido)

      if (!valido) {
        authT.textContent = 'FIRMA NO VERIFICADA — CONSULTAR AL MÉDICO'
        ;(document.getElementById('authentic-note') as HTMLDivElement).style.borderColor = '#e8003d'
        authT.style.color = '#e8003d'
      }

      // ... después de CryptoEngine.abrirReceta ...
      
      const meds = contenido.datos.medicamentos || []
      const container = document.getElementById('resumen-contenido-paciente')
      if (!container) return

      // Construcción del HTML basado en el diseño de sign.astro
      let html = `
        <div style="display:flex; justify-content:space-between; padding:10px 0; border-bottom:2px solid var(--border-default);">
          <span style="font-family:'Press Start 2P',monospace; font-size:7px; color:var(--text-dim); width:100px;">MÉDICO</span>
          <span style="font-family:'VT323',monospace; font-size:21px; color:var(--role-doctor); text-align:right;">DR. ${info.medico.nombre_completo.toUpperCase()}</span>
        </div>
        <div style="display:flex; justify-content:space-between; padding:10px 0; border-bottom:2px solid var(--border-default);">
          <span style="font-family:'Press Start 2P',monospace; font-size:7px; color:var(--text-dim); width:100px;">EMISIÓN</span>
          <span style="font-family:'VT323',monospace; font-size:21px; color:var(--text-primary); text-align:right;">${info.creada_en.slice(0, 10)}</span>
        </div>
      `;

      // ITERACIÓN DE MEDICAMENTOS (Tarjetas individuales)
      meds.forEach((m: any, index: number) => {
        html += `
          <div style="margin-top:20px; padding: 14px; background: rgba(65, 166, 246, 0.05); border-left: 3px solid var(--role-patient);">
            <div style="display:flex; justify-content:space-between; padding-bottom:10px;">
              <span style="font-family:'Press Start 2P',monospace; font-size:7px; color:var(--role-patient);">MEDICAMENTO ${index + 1}</span>
              <span style="font-family:'Press Start 2P',monospace; font-size:10px; color:var(--text-primary); text-align:right;">${m.nombre}</span>
            </div>
            <div style="display:flex; justify-content:space-between; padding:5px 0;">
              <span style="font-family:'Press Start 2P',monospace; font-size:7px; color:var(--text-dim);">DOSIS</span>
              <span style="font-family:'VT323',monospace; font-size:20px; color:var(--text-primary); text-align:right;">${m.dosis} · ${m.forma}</span>
            </div>
            <div style="display:flex; justify-content:space-between; padding:5px 0;">
              <span style="font-family:'Press Start 2P',monospace; font-size:7px; color:var(--text-dim);">CANTIDAD</span>
              <span style="font-family:'VT323',monospace; font-size:20px; color:var(--text-primary); text-align:right;">${m.cantidad} unidades (Recargas: ${m.recargas || 0})</span>
            </div>
            <div style="display:flex; flex-direction:column; padding-top:10px;">
              <span style="font-family:'Press Start 2P',monospace; font-size:7px; color:var(--text-dim); margin-bottom:4px;">INSTRUCCIONES</span>
              <span style="font-family:'VT323',monospace; font-size:19px; color:var(--text-primary); line-height:1.4;">${m.instrucciones}</span>
            </div>
          </div>
        `;
      });

      container.innerHTML = html;
    } catch (e) {
      const msg = e instanceof ApiError ? `Backend ${e.status}: ${e.detail}`
        : (e as any)?.message || 'Error inesperado.'
      showError(msg)
    }
  }
  load()
</script>
