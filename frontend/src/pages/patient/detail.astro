---
import FlowLayout from '../../layouts/FlowLayout.astro'
const steps=[{label:'ACCESO',href:'/patient'},{label:'MIS RECETAS',href:'/patient/dashboard'},{label:'DETALLE',href:'/patient/detail'}]
---
<FlowLayout title="Detalle de Receta" role="patient" steps={steps} currentStep={2} back="/patient/dashboard">
<div class="anim-slide" style="display:flex;flex-direction:column;gap:20px;">

  <!-- Status alert -->
  <div style="background:#1a1500;border:3px solid #ffcd75;box-shadow:4px 4px 0 #c48c00;padding:14px;display:flex;align-items:center;gap:12px;">
    <span style="font-size:24px;" class="anim-bounce">⏳</span>
    <div>
      <p style="font-family:'Press Start 2P',monospace;font-size:9px;color:#ffcd75;">LISTA PARA RECOGER</p>
      <p style="font-family:'VT323',monospace;font-size:20px;color:#c0cbdc;margin-top:4px;">Muestra el código QR en la farmacia</p>
    </div>
  </div>

  <!-- BIG QR code -->
  <div style="background:#f4f4f4;border:4px solid #41a6f6;box-shadow:6px 6px 0 #1a6eb0;padding:24px;text-align:center;">
    <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:#29366f;margin-bottom:20px;letter-spacing:.1em;">CÓDIGO QR — FARMACIA</p>
    <div style="width:200px;height:200px;margin:0 auto;background:white;border:3px solid #1a1c2c;padding:12px;display:flex;align-items:center;justify-content:center;" class="anim-float">
      <svg width="176" height="176" viewBox="0 0 60 60" style="image-rendering:pixelated;">
        <rect width="60" height="60" fill="white"/>
        <!-- QR corners -->
        <rect x="2" y="2" width="20" height="20" rx="2" fill="none" stroke="#1a1c2c" stroke-width="2"/>
        <rect x="6" y="6" width="12" height="12" fill="#1a1c2c"/>
        <rect x="38" y="2" width="20" height="20" rx="2" fill="none" stroke="#1a1c2c" stroke-width="2"/>
        <rect x="42" y="6" width="12" height="12" fill="#1a1c2c"/>
        <rect x="2" y="38" width="20" height="20" rx="2" fill="none" stroke="#1a1c2c" stroke-width="2"/>
        <rect x="6" y="42" width="12" height="12" fill="#1a1c2c"/>
        <!-- Data modules -->
        <rect x="26" y="2" width="4" height="4" fill="#1a1c2c"/>
        <rect x="32" y="2" width="4" height="4" fill="#1a1c2c"/>
        <rect x="26" y="8" width="4" height="4" fill="#1a1c2c"/>
        <rect x="26" y="26" width="4" height="4" fill="#1a1c2c"/>
        <rect x="32" y="26" width="4" height="4" fill="#1a1c2c"/>
        <rect x="38" y="26" width="4" height="4" fill="#1a1c2c"/>
        <rect x="44" y="26" width="4" height="4" fill="#1a1c2c"/>
        <rect x="50" y="26" width="4" height="4" fill="#1a1c2c"/>
        <rect x="26" y="32" width="4" height="4" fill="#1a1c2c"/>
        <rect x="38" y="32" width="4" height="4" fill="#1a1c2c"/>
        <rect x="50" y="32" width="4" height="4" fill="#1a1c2c"/>
        <rect x="26" y="38" width="4" height="4" fill="#1a1c2c"/>
        <rect x="44" y="38" width="4" height="4" fill="#1a1c2c"/>
        <rect x="26" y="44" width="4" height="4" fill="#1a1c2c"/>
        <rect x="38" y="44" width="4" height="4" fill="#1a1c2c"/>
        <rect x="26" y="50" width="4" height="4" fill="#1a1c2c"/>
        <rect x="44" y="50" width="4" height="4" fill="#1a1c2c"/>
        <rect x="50" y="50" width="4" height="4" fill="#1a1c2c"/>
      </svg>
    </div>
    <p style="font-family:'Press Start 2P',monospace;font-size:11px;color:#1a1c2c;margin-top:16px;">XYZ-123</p>
    <p style="font-family:'VT323',monospace;font-size:20px;color:#29366f;margin-top:4px;">VÁLIDO HASTA 19 ABR 2026</p>
  </div>

  <!-- Details -->
  <div style="background:#222639;border:3px solid #29366f;box-shadow:4px 4px 0 #0d0e1a;overflow:hidden;">
    <div style="background:#29366f;padding:10px 16px;">
      <span style="font-family:'Press Start 2P',monospace;font-size:8px;color:#f4f4f4;">📋 DETALLES DE PRESCRIPCIÓN</span>
    </div>
    <div style="padding:16px;">
      {[
        {l:'MEDICAMENTO',v:'Amoxicilina',big:true},
        {l:'DOSIS',v:'500 mg · Cápsula',m:true},
        {l:'CANTIDAD',v:'21 cápsulas',m:true},
        {l:'INSTRUCCIONES',v:'1 cápsula c/8h con alimentos, 7 días.'},
        {l:'MÉDICO',v:'Dr. Eduardo Ramírez'},
        {l:'EMITIDA',v:'20 MAR 2026',m:true},
      ].map(f=>(
        <div style="display:flex;justify-content:space-between;align-items:flex-start;padding:10px 0;border-bottom:2px solid #29366f;gap:12px;">
          <span style="font-family:'Press Start 2P',monospace;font-size:7px;color:#5b6ee1;flex-shrink:0;width:90px;">{f.l}</span>
          <span style={'text-align:right;font-family:\'VT323\',monospace;font-size:'+(f.big?'22px':'20px')+';color:'+(f.big?'#41a6f6':'#f4f4f4')+';'+(f.big?'font-weight:bold;':'')}>{f.v}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Authentic note -->
  <div style="background:#1a2e1a;border:3px solid #38b764;padding:12px;display:flex;align-items:center;gap:10px;">
    <span style="font-size:18px;flex-shrink:0;">✅</span>
    <p style="font-family:'Press Start 2P',monospace;font-size:7px;color:#38b764;line-height:1.8;">RECETA AUTÉNTICA · FIRMA DEL MÉDICO VERIFICADA</p>
  </div>
</div>
</FlowLayout>
