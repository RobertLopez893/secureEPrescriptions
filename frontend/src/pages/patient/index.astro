---
import FlowLayout from '../../layouts/FlowLayout.astro'
const steps=[{label:'ACCESO',href:'/patient'},{label:'MIS RECETAS',href:'/patient/dashboard'},{label:'DETALLE',href:'/patient/detail'}]
---
<FlowLayout title="Paciente — Acceso" role="patient" steps={steps} currentStep={0}>
<div class="anim-slide" style="display:flex;flex-direction:column;gap:20px;">

  <!-- Header -->
  <div style="text-align:center;">
    <div class="anim-bounce" style="display:flex;justify-content:center;margin-bottom:14px;">
      <svg width="56" height="66" viewBox="0 0 24 28" style="image-rendering:pixelated;">
        <use href="#ico-patient"/>
      </svg>
    </div>
    <h1 style="font-family:'Press Start 2P',monospace;font-size:13px;color:var(--text-primary);margin-bottom:8px;line-height:1.7;">
      ACCESO PACIENTE
    </h1>
    <p style="font-family:'VT323',monospace;font-size:22px;color:var(--text-muted);">
      Escanea tu tarjeta digital para iniciar sesión
    </p>
  </div>

  <!-- QR CARD READER -->
  <div style="background:var(--surface-card);border:3px solid var(--role-patient);box-shadow:4px 4px 0 var(--role-patient-d);padding:20px;">

    <div style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--role-patient);margin-bottom:14px;display:flex;align-items:center;gap:8px;">
      <span class="anim-blink" style="display:inline-block;width:8px;height:8px;background:var(--role-patient);"></span>
      LECTOR QR — TARJETA DIGITAL
    </div>

    <!-- Scanner viewport -->
    <div id="qr-viewport"
         style="background:#040c18;border:3px solid var(--role-patient);position:relative;overflow:hidden;margin-bottom:18px;height:240px;">

      <!-- Live camera feed (se muestra sólo durante el escaneo) -->
      <video id="qr-video" playsinline muted
             style="display:none;position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:saturate(1.2) contrast(1.05);image-rendering:pixelated;"></video>

      <!-- QR grid pattern -->
      <div class="qr-grid"></div>

      <!-- Scan line -->
      <div class="qr-scan-line" id="qr-scan-line"></div>

      <!-- Corner brackets -->
      <div style="position:absolute;top:10px;left:10px;width:28px;height:28px;border-top:4px solid var(--role-patient);border-left:4px solid var(--role-patient);z-index:2;"></div>
      <div style="position:absolute;top:10px;right:10px;width:28px;height:28px;border-top:4px solid var(--role-patient);border-right:4px solid var(--role-patient);z-index:2;"></div>
      <div style="position:absolute;bottom:10px;left:10px;width:28px;height:28px;border-bottom:4px solid var(--role-patient);border-left:4px solid var(--role-patient);z-index:2;"></div>
      <div style="position:absolute;bottom:10px;right:10px;width:28px;height:28px;border-bottom:4px solid var(--role-patient);border-right:4px solid var(--role-patient);z-index:2;"></div>

      <!-- Pixel art tarjeta digital (idle state) -->
      <div id="card-idle" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:14px;">
        <!-- Pixel art credit card -->
        <svg width="170" height="108" viewBox="0 0 170 108" style="image-rendering:pixelated;filter:drop-shadow(0 0 8px rgba(65,166,246,.4));" class="anim-float">
          <!-- Card body -->
          <rect width="170" height="108" rx="5" fill="#0d1a2e"/>
          <rect width="170" height="108" rx="5" fill="none" stroke="#41a6f6" stroke-width="2"/>
          <!-- Shimmer stripe -->
          <rect y="0" width="170" height="36" rx="5" fill="rgba(65,166,246,.06)"/>
          <!-- Chip -->
          <rect x="12" y="42" width="32" height="24" rx="2" fill="#ffcd75"/>
          <rect x="16" y="46" width="24" height="16" rx="1" fill="#c48c00"/>
          <rect x="20" y="50" width="14" height="2" fill="#ffcd75"/>
          <rect x="20" y="54" width="14" height="2" fill="#ffcd75"/>
          <rect x="20" y="58" width="14" height="2" fill="#ffcd75"/>
          <!-- QR pixel art (right side) -->
          <g transform="translate(100,34)" fill="#41a6f6" opacity=".9">
            <!-- Finder top-left -->
            <rect x="0"  y="0"  width="18" height="18" fill="none" stroke="#41a6f6" stroke-width="2"/>
            <rect x="4"  y="4"  width="10" height="10"/>
            <!-- Finder top-right -->
            <rect x="26" y="0"  width="18" height="18" fill="none" stroke="#41a6f6" stroke-width="2"/>
            <rect x="30" y="4"  width="10" height="10"/>
            <!-- Finder bottom-left -->
            <rect x="0"  y="26" width="18" height="18" fill="none" stroke="#41a6f6" stroke-width="2"/>
            <rect x="4"  y="30" width="10" height="10"/>
            <!-- Data pixels -->
            <rect x="20" y="4"  width="4" height="4"/>
            <rect x="22" y="10" width="2" height="2"/>
            <rect x="20" y="14" width="2" height="4"/>
            <rect x="20" y="26" width="4" height="2"/>
            <rect x="26" y="20" width="2" height="4"/>
            <rect x="30" y="20" width="6" height="2"/>
            <rect x="36" y="22" width="2" height="6"/>
            <rect x="32" y="24" width="2" height="4"/>
          </g>
          <!-- Rx Logo text area -->
          <text x="12" y="22" fill="#f4f4f4" style="font-family:monospace;font-size:11px;font-weight:bold;letter-spacing:1px;">RxPro</text>
          <text x="12" y="34" fill="#41a6f6" style="font-family:monospace;font-size:6px;letter-spacing:2px;">TARJETA DIGITAL</text>
          <!-- Card number (masked) -->
          <text x="12" y="88" fill="#41a6f6" style="font-family:monospace;font-size:8px;letter-spacing:3px;">████ ████ ████ ••••</text>
          <!-- Bottom label -->
          <text x="12" y="100" fill="#29366f" style="font-family:monospace;font-size:5px;letter-spacing:1px;">SEMILLA CIFRADA • E2E</text>
        </svg>
        <p id="qr-status" style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--role-patient);letter-spacing:.08em;" class="anim-blink">
          ACERQUE TARJETA DIGITAL
        </p>
      </div>

      <!-- Processing state (shown during scan) -->
      <div id="card-scanning" style="display:none;position:absolute;inset:0;align-items:center;justify-content:center;flex-direction:column;gap:16px;">
        <!-- Spinning derivation ring -->
        <div style="position:relative;width:72px;height:72px;">
          <div id="spin-ring" style="position:absolute;inset:0;border:4px solid var(--border-default);border-top-color:var(--role-patient);animation:spinnerRot .6s steps(8,end) infinite;"></div>
          <div style="position:absolute;inset:8px;display:flex;align-items:center;justify-content:center;">
            <svg width="28" height="20" viewBox="0 0 28 16" style="image-rendering:pixelated;color:var(--role-patient);">
              <use href="#ico-key"/>
            </svg>
          </div>
        </div>
        <p id="derive-status" style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--role-patient);letter-spacing:.06em;text-align:center;max-width:220px;line-height:1.8;" class="anim-blink">
          LEYENDO QR...
        </p>
      </div>

      <!-- Key preview (shown after success) -->
      <div id="card-success" style="display:none;position:absolute;inset:0;align-items:center;justify-content:center;flex-direction:column;gap:12px;padding:16px;">
        <svg width="40" height="46" viewBox="0 0 24 28" style="image-rendering:pixelated;color:var(--role-doctor);">
          <use href="#ico-shield"/>
        </svg>
        <p style="font-family:'Press Start 2P',monospace;font-size:9px;color:var(--role-doctor);">LLAVE ACTIVA</p>
        <div style="background:#0a1a0a;border:2px solid var(--role-doctor);padding:8px 12px;width:100%;text-align:center;">
          <span id="key-preview" style="font-family:'VT323',monospace;font-size:16px;color:var(--role-doctor);letter-spacing:.1em;word-break:break-all;">
            ••••••••••••••••
          </span>
        </div>
        <p style="font-family:'Press Start 2P',monospace;font-size:6px;color:var(--role-doctor-d);line-height:1.8;text-align:center;">
          ACCEDIENDO...
        </p>
      </div>

      <!-- Progress bar inside viewport -->
      <div id="scan-progress-track" style="display:none;position:absolute;bottom:10px;left:16px;right:16px;height:6px;border:2px solid var(--role-patient);background:var(--surface-inset);z-index:3;">
        <div id="scan-progress-fill" style="height:100%;width:0%;background:repeating-linear-gradient(90deg,var(--role-patient) 0px,var(--role-patient) 6px,var(--role-patient-d) 6px,var(--role-patient-d) 12px);"></div>
      </div>
    </div>

    <!-- Info strip -->
    <div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;">
      {['QR SEED','HKDF-SHA256','P-256','E2E'].map(t => (
        <span style="font-family:'Press Start 2P',monospace;font-size:6px;padding:3px 6px;border:2px solid var(--border-default);color:var(--role-patient);background:#29366f22;">{t}</span>
      ))}
    </div>

    <!-- Scan button -->
    <button type="button" id="scan-btn"
            style="width:100%;padding:14px;background:#0a1525;border:3px solid var(--role-patient);box-shadow:4px 4px 0 var(--role-patient-d);font-family:'Press Start 2P',monospace;font-size:9px;color:var(--role-patient);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:16px;transition:background .1s;">
      <!-- QR icon pixel art -->
      <svg width="20" height="20" viewBox="0 0 20 20" style="image-rendering:pixelated;flex-shrink:0;">
        <rect x="0" y="0" width="8" height="8" fill="none" stroke="#41a6f6" stroke-width="1.5"/>
        <rect x="2" y="2" width="4" height="4" fill="#41a6f6"/>
        <rect x="12" y="0" width="8" height="8" fill="none" stroke="#41a6f6" stroke-width="1.5"/>
        <rect x="14" y="2" width="4" height="4" fill="#41a6f6"/>
        <rect x="0" y="12" width="8" height="8" fill="none" stroke="#41a6f6" stroke-width="1.5"/>
        <rect x="2" y="14" width="4" height="4" fill="#41a6f6"/>
        <rect x="12" y="12" width="2" height="2" fill="#41a6f6"/>
        <rect x="16" y="12" width="2" height="4" fill="#41a6f6"/>
        <rect x="12" y="16" width="6" height="2" fill="#41a6f6"/>
        <rect x="10" y="10" width="2" height="2" fill="#41a6f6"/>
        <rect x="10" y="4"  width="2" height="4" fill="#41a6f6"/>
      </svg>
      ESCANEAR TARJETA
    </button>

    <!-- Error del escaneo (cámara / firma inválida) -->
    <p id="scan-error" style="display:none;font-family:'Press Start 2P',monospace;font-size:7px;color:#a53030;background:#2a1018;border:2px solid #a53030;padding:10px;line-height:1.8;"></p>
  </div>

  <!-- Security notice -->
  <div style="display:flex;align-items:flex-start;gap:10px;padding:12px 14px;border:2px solid var(--border-default);background:#29366f18;">
    <svg width="16" height="20" viewBox="0 0 20 24" style="image-rendering:pixelated;color:var(--text-subtle);flex-shrink:0;margin-top:2px;">
      <use href="#ico-lock"/>
    </svg>
    <p style="font-family:'Press Start 2P',monospace;font-size:6px;color:var(--text-subtle);line-height:2;">
      LLAVE PRIVADA NUNCA SE ALMACENA · DERIVADA EN MEMORIA DESDE SEMILLA QR · CIFRADO E2E
    </p>
  </div>
</div>
</FlowLayout>

<script>
  import { ApiError } from '../../utils/api.ts'
  import { parseCardQr } from '../../utils/cardQr.ts'
  import { loginWithCard } from '../../utils/authFlow.ts'
  import { deriveKeysFromSeed } from '../../crypto/seedDerivation.ts'
  import { startQrScanner } from '../../utils/qrScanner.ts'

  // ── Elementos ─────────────────────────────────────────────────────────────
  const btn          = document.getElementById('scan-btn')     as HTMLButtonElement
  const video        = document.getElementById('qr-video')     as HTMLVideoElement
  const viewport     = document.getElementById('qr-viewport')  as HTMLDivElement
  const scanLine     = document.getElementById('qr-scan-line') as HTMLDivElement
  const cardIdle     = document.getElementById('card-idle')    as HTMLDivElement
  const cardScanning = document.getElementById('card-scanning')as HTMLDivElement
  const cardSuccess  = document.getElementById('card-success') as HTMLDivElement
  const deriveStatus = document.getElementById('derive-status')as HTMLParagraphElement
  const keyPreview   = document.getElementById('key-preview')  as HTMLSpanElement
  const progTrack    = document.getElementById('scan-progress-track') as HTMLDivElement
  const progFill     = document.getElementById('scan-progress-fill')  as HTMLDivElement
  const scanError    = document.getElementById('scan-error')   as HTMLParagraphElement | null

  function showPanel(panel: 'idle' | 'scanning' | 'success') {
    cardIdle.style.display     = panel === 'idle'     ? 'flex' : 'none'
    cardScanning.style.display = panel === 'scanning' ? 'flex' : 'none'
    cardSuccess.style.display  = panel === 'success'  ? 'flex' : 'none'
  }

  function setStatus(msg: string, color: string) {
    deriveStatus.textContent   = msg
    deriveStatus.style.color   = color
    scanLine.style.boxShadow   = `0 0 12px ${color}`
    scanLine.style.background  = `linear-gradient(90deg,transparent,${color},transparent)`
    viewport.style.borderColor = color
  }

  function showError(msg: string) {
    if (!scanError) return
    scanError.textContent = msg
    scanError.style.display = 'block'
  }
  function hideError() {
    if (!scanError) return
    scanError.style.display = 'none'
  }

  function maskKey(hex: string): string {
    return hex.slice(0, 8) + '••••••••••••••••••••••••••••••••••••••••••••••••' + hex.slice(-4)
  }

  btn.addEventListener('click', async () => {
    hideError()
    btn.disabled = true
    btn.textContent = 'INICIANDO CÁMARA...'
    btn.style.color = '#ffcd75'
    btn.style.borderColor = '#ffcd75'

    showPanel('scanning')
    progTrack.style.display = 'block'
    scanLine.style.display  = 'block'
    video.style.display     = 'block'

    // Barra de progreso indeterminada mientras buscamos el QR.
    progFill.style.animation = 'none'
    progFill.style.width = '0%'
    let pct = 0
    const pulse = setInterval(() => {
      pct = (pct + 6) % 100
      progFill.style.width = pct + '%'
    }, 90)

    setStatus('ABRIENDO CÁMARA...', '#41a6f6')

    const scanner = startQrScanner({ video, facingMode: 'environment' })

    // Feedback visual mientras no hay lectura
    setTimeout(() => setStatus('BUSCANDO CÓDIGO QR...', '#41a6f6'), 800)

    let raw = ''
    try {
      raw = await scanner.result
    } catch (err: any) {
      clearInterval(pulse)
      progFill.style.width = '0%'
      video.style.display = 'none'
      showPanel('idle')
      showError(err?.message || 'No se pudo leer el QR.')
      btn.disabled = false
      btn.textContent = 'ESCANEAR TARJETA'
      btn.style.color = '#41a6f6'
      btn.style.borderColor = '#41a6f6'
      return
    }

    clearInterval(pulse)
    progFill.style.width = '100%'
    setStatus('LLAVE DETECTADA · VERIFICANDO...', '#ffcd75')
    video.style.display = 'none'

    const card = parseCardQr(raw)
    if (card && card.rol === 'Paciente') {
      try {
        setStatus('FIRMANDO RETO ECDSA...', '#ffcd75')
        const { publicKeyHex } = deriveKeysFromSeed(card.seedHex,"sign")
        await loginWithCard(card)
        if (keyPreview) keyPreview.textContent = maskKey(publicKeyHex)
        sessionStorage.setItem('rxpro_auth_method', 'qr_card')
        sessionStorage.setItem('rxpro_seed_loaded', '1')
        showPanel('success')
        viewport.style.borderColor = '#38b764'
        viewport.style.background  = '#04100a'
        setTimeout(() => { window.location.href = '/patient/dashboard' }, 800)
        return
      } catch (err) {
        const msg = err instanceof ApiError ? err.detail : (err as any)?.message || 'Error al autenticar.'
        showError(msg)
      }
    } else if (card) {
      showError(`El QR pertenece al rol "${card.rol}", no a un paciente.`)
    } else {
      showError('El código leído no es una tarjeta RxPro válida.')
    }

    // Volver al estado idle para reintentar
    showPanel('idle')
    btn.disabled = false
    btn.textContent = 'ESCANEAR TARJETA'
    btn.style.color = '#41a6f6'
    btn.style.borderColor = '#41a6f6'
  })
</script>
