---
import FlowLayout from '../../layouts/FlowLayout.astro'
const steps=[{label:'ESCANEAR',href:'/pharmacy'},{label:'VERIFICAR',href:'/pharmacy/verify'},{label:'DISPENSAR',href:'/pharmacy/seal'}]
---
<FlowLayout title="Medicamento Sellado" role="pharmacy" steps={steps} currentStep={3}>
<div class="anim-pop" style="display:flex;flex-direction:column;align-items:center;text-align:center;gap:16px;">

  <div id="confetti" style="position:fixed;top:30%;left:50%;pointer-events:none;z-index:100;"></div>

  <div style="background:var(--surface-card);border:4px solid var(--role-pharmacy);box-shadow:var(--shadow-red);padding:22px 22px 18px;width:100%;">

    <div style="display:flex;justify-content:center;margin-bottom:10px;">
      <div class="anim-bounce" style="position:relative;">
        <svg width="44" height="51" viewBox="0 0 24 28" style="image-rendering:pixelated;color:var(--role-pharmacy);">
          <use href="#ico-shield"/>
        </svg>
        <div style="position:absolute;top:30%;left:50%;transform:translate(-50%,-50%);">
          <svg width="16" height="13" viewBox="0 0 20 16" style="image-rendering:pixelated;color:white;">
            <use href="#ico-checkmark"/>
          </svg>
        </div>
      </div>
    </div>

    <h1 style="font-family:'Press Start 2P',monospace;font-size:13px;color:var(--role-pharmacy);margin-bottom:4px;line-height:1.6;">RECETA SELLADA</h1>
    <p style="font-family:'VT323',monospace;font-size:20px;color:var(--text-muted);margin-bottom:12px;">Medicamento entregado y registrado</p>

    <div style="background:rgba(232,0,61,.12);box-shadow:var(--shadow-red);border:3px solid var(--role-pharmacy);padding:8px 16px;display:inline-block;margin-bottom:14px;" class="anim-score">
      <span style="font-family:'Press Start 2P',monospace;font-size:11px;color:var(--accent-warn);" id="seal-info">CARGANDO...</span>
    </div>

    <div style="display:flex;justify-content:center;gap:12px;margin-bottom:16px;">
      {[0,1,2].map(idx=>(
        <svg width="22" height="22" viewBox="0 0 20 20" style={'image-rendering:pixelated;color:var(--accent-warn);animation:px-bounce .6s ease-in-out infinite;animation-delay:'+(idx*.15)+'s;'}>
          <use href="#ico-star"/>
        </svg>
      ))}
    </div>

    <div style="text-align:left;border-top:3px solid var(--role-pharmacy);padding-top:14px;">
      {[
        {l:'PACIENTE',    v:'García Mendoza, Luis'},
        {l:'MEDICAMENTO', v:'Amoxicilina 500mg · 21 cápsulas'},
        {l:'FARMACÉUTICO',v:'Qfb. Laura Sánchez'},
        {l:'FARMACIA',    v:'Farmacia Central'},
        {l:'ESTADO',      v:'SELLADA'},
      ].map(r=>(
        <div style="display:flex;justify-content:space-between;gap:12px;padding:7px 0;border-bottom:2px solid var(--border-default);">
          <span style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--role-pharmacy);flex-shrink:0;letter-spacing:.04em;">{r.l}</span>
          <span style="font-family:'VT323',monospace;font-size:19px;color:var(--text-primary);text-align:right;">{r.v}</span>
        </div>
      ))}
    </div>
  </div>

  <div style="display:flex;flex-direction:column;gap:12px;width:100%;">
    <a href="/pharmacy" class="px-btn px-btn-red px-btn-lg" style="width:100%;justify-content:center;text-decoration:none;">
      <svg width="14" height="11" viewBox="0 0 16 12" style="image-rendering:pixelated;color:white;">
        <rect x="0" y="4" width="12" height="4" fill="currentColor"/>
        <rect x="8" y="0" width="4" height="4" fill="currentColor"/>
        <rect x="8" y="8" width="4" height="4" fill="currentColor"/>
        <rect x="12" y="2" width="2" height="2" fill="currentColor"/>
        <rect x="12" y="8" width="2" height="2" fill="currentColor"/>
        <rect x="14" y="4" width="2" height="4" fill="currentColor"/>
      </svg>
      ATENDER SIGUIENTE PACIENTE
    </a>
    <a href="/" class="px-btn px-btn-ghost" style="width:100%;justify-content:center;text-decoration:none;">VOLVER AL INICIO</a>
  </div>
</div>
</FlowLayout>

<script>
  import { requireSession } from '../../utils/sessionGuard.ts'
  requireSession('Farmaceutico', '/pharmacy/login')

  document.getElementById('seal-info').textContent = 'XYZ-123 · ' + new Date().toLocaleDateString('es-MX',{day:'2-digit',month:'short',year:'numeric'}).toUpperCase()
  const container = document.getElementById('confetti')
  const colors = ['#e8003d','#ffcd75','#41a6f6','#38b764','#f4f4f4']
  for (let i=0;i<20;i++) {
    const el = document.createElement('div')
    el.style.cssText = `position:absolute;width:6px;height:6px;background:${colors[i%5]};--tx:${(Math.random()-0.5)*200}px;animation:confettiFall ${.8+Math.random()*.8}s ease ${i*.05}s both;`
    container.appendChild(el)
  }
</script>
