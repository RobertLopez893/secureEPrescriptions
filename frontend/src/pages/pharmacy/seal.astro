---
import FlowLayout from '../../layouts/FlowLayout.astro'
const steps=[{label:'ESCANEAR',href:'/pharmacy'},{label:'VERIFICAR',href:'/pharmacy/verify'},{label:'DISPENSAR',href:'/pharmacy/seal'}]
---
<FlowLayout title="Farmacia — Dispensar" role="pharmacy" steps={steps} currentStep={2} back="/pharmacy/verify">
<div class="anim-slide" style="display:flex;flex-direction:column;gap:20px;">
  <div>
    <h1 style="font-family:'Press Start 2P',monospace;font-size:13px;color:var(--text-primary);margin-bottom:6px;">CONFIRMAR DESPACHO</h1>
    <p style="font-family:'VT323',monospace;font-size:22px;color:var(--text-muted);">Valida los ítems y aplica el sello digital</p>
  </div>

  <div id="seal-loading" class="px-card-dark" style="padding:30px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:14px;">
    <div class="px-spinner" style="border-top-color:var(--role-pharmacy);"></div>
    <p class="anim-blink" style="font-family:'Press Start 2P',monospace;font-size:9px;color:var(--text-subtle);">CARGANDO DETALLES PARA DISPENSACIÓN...</p>
  </div>

  <div id="med-display" style="display:none; background:var(--surface-card); border:3px solid var(--role-pharmacy); box-shadow:var(--shadow-red); padding:24px;">
    <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--role-pharmacy);margin-bottom:16px;">ÍTEMS A ENTREGAR:</p>
    <div id="med-list-container" style="display:flex; flex-direction:column; gap:12px;">
       </div>
  </div>

  <div id="checklist-card" style="display:none; background:var(--surface-card); border:3px solid var(--border-default); padding:20px;">
    <p style="font-family:'Press Start 2P',monospace;font-size:8px;color:var(--text-muted);margin-bottom:16px;">CHECKLIST DE SEGURIDAD:</p>
    <div id="checklist-items" style="display:flex;flex-direction:column;gap:14px;">
      </div>

    <button type="button" id="btn-execute-seal" disabled
            class="px-btn px-btn-blue" style="width:100%;margin-top:24px;justify-content:center;opacity:0.5;">
      APLICAR SELLO Y SURTIR
    </button>
  </div>
</div>
</FlowLayout>
<script>
  import { Api, getSession } from '../../utils/api.ts'
  import { CryptoEngine } from '../../crypto/index.ts'
  import { getUserPrivKeyHex, getUserPublicKeyHex } from '../../utils/userKeys.ts'
  import { requireSession } from '../../utils/sessionGuard.ts'
  import { cargarRecetaValidada, RecetaValidationError } from '../../utils/pharmacyReceta.ts'

  requireSession('Farmaceutico', '/pharmacy/login')

  let currentContainer: any = null // Contenedor descifrado (RecetaContainer)
  let recetaInfo: any = null
  // Llaves públicas 'recipes' de los 3 destinatarios para el re-wrap del sello.
  let pubKeys: { paciente: string, doctor: string, farmaceutico: string } | null = null

  async function init() {
    const params = new URLSearchParams(window.location.search)
    const idReceta = Number(params.get('id'))
    if (!idReceta) return window.location.href = '/pharmacy'

    try {
      // Defensa en profundidad: aunque se llegue aquí por URL directa, se
      // re-ejecutan TODAS las validaciones, incluida la firma del médico.
      const validada = await cargarRecetaValidada(idReceta)
      recetaInfo = validada.recetaInfo
      currentContainer = validada.contenedor

      const privSeal = getUserPrivKeyHex('farmaceutico', 'seal')
      const farmaPub = getUserPublicKeyHex('farmaceutico', 'recipes')
      if (!privSeal || !farmaPub) throw new RecetaValidationError('SIN_LLAVE', 'Llaves de sello no encontradas en la sesión.')

      // Llaves públicas 'recipes' de paciente y médico para re-cifrar el sello.
      const [pacPub, docPub] = await Promise.all([
        Api.obtenerLlavePublica(recetaInfo.id_paciente, 'recetas'),
        Api.obtenerLlavePublica(recetaInfo.id_medico, 'recetas')
      ])
      pubKeys = {
        paciente: pacPub.llave_publica,
        doctor: docPub.llave_publica,
        farmaceutico: farmaPub,
      }

      renderMedication(recetaInfo.medico.nombre_completo)
      setupChecklist()

      document.getElementById('seal-loading')!.style.display = 'none'
      document.getElementById('med-display')!.style.display = 'block'
      document.getElementById('checklist-card')!.style.display = 'block'

    } catch (err) {
      console.error("Dispensación bloqueada:", err)
      // Volvemos a verify, que mostrará el motivo exacto del bloqueo.
      window.location.href = `/pharmacy/verify?id=${idReceta}`
    }
  }

  function renderMedication(medico: string) {
    const list = document.getElementById('med-list-container')!
    // currentContainer.datos.medicamentos contiene la lista real descifrada
    currentContainer.datos.medicamentos.forEach((m: any) => {
      const div = document.createElement('div')
      div.style.cssText = "padding:12px; border-left:3px solid var(--role-pharmacy); background:rgba(232,0,61,0.05);"
      div.innerHTML = `
        <p style="font-family:'Press Start 2P',monospace; font-size:9px; color:var(--text-primary);">${m.nombre}</p>
        <p style="font-family:'VT323',monospace; font-size:18px; color:var(--text-muted); margin-top:4px;">
          ${m.dosis} · ${m.cantidad} UNIDADES
        </p>
      `
      list.appendChild(div)
    })
  }

  function setupChecklist() {
    const container = document.getElementById('checklist-items')!
    const items = [
      ...currentContainer.datos.medicamentos.map((m:any) => `ENTREGAR: ${m.nombre}`),
      "IDENTIDAD DEL PACIENTE VERIFICADA",
      "INSTRUCCIONES EXPLICADAS"
    ]

    items.forEach((text, i) => {
      const label = document.createElement('label')
      label.className = "px-checkbox-container" // Asumiendo que tienes esta clase en global.css
      label.style.cssText = "display:flex; align-items:center; gap:12px; cursor:pointer;"
      label.innerHTML = `
        <input type="checkbox" class="seal-check" style="width:20px;height:20px;accent-color:var(--role-pharmacy);">
        <span style="font-family:'VT323',monospace; font-size:20px; color:var(--text-primary);">${text}</span>
      `
      container.appendChild(label)
    })

    // Habilitar botón solo si todo está marcado
    const checks = document.querySelectorAll('.seal-check')
    const btn = document.getElementById('btn-execute-seal') as HTMLButtonElement
    
    container.addEventListener('change', () => {
      const allChecked = Array.from(checks).every((c: any) => c.checked)
      btn.disabled = !allChecked
      btn.style.opacity = allChecked ? '1' : '0.5'
    })

    btn.addEventListener('click', executeSeal)
  }

  async function executeSeal() {
    const btn = document.getElementById('btn-execute-seal') as HTMLButtonElement
    btn.disabled = true
    btn.textContent = "GENERANDO SELLO HMAC..."

    try {
      const session = getSession()
      const privSeal = getUserPrivKeyHex('farmaceutico', 'seal')!
      
      // 1. Ejecutar sellado criptográfico 
      // sellarRecetaGlobal realiza el HMAC, actualiza el contenedor y cifra de nuevo
      // Firma de sellar(): (Contenedor, keyPrivSello, sealInfo, pacientePub, doctorPub, farmaceuticoPub)
      const resCripto = CryptoEngine.sellar(
        currentContainer,
        privSeal,
        { estado: "surtida", id_clinica: "CLINICA-001" }, // En producción vendría de la sesión
        pubKeys!.paciente,
        pubKeys!.doctor,
        pubKeys!.farmaceutico,
      )

      // 2. Enviar al backend [cite: 20]
      await Api.sellarReceta(recetaInfo.id_receta, {
        id_farmaceutico: session?.id,
        capsula_cifrada: resCripto.capsula_cifrada,
        nonce: resCripto.nonce,
        accesos: resCripto.accesos
      })

      window.location.href = '/pharmacy/done'
    } catch (err) {
      console.error("Falla al sellar:", err)
      ;(window as any).showToast?.("Error crítico al generar el sello digital.", "#e8003d")
      btn.disabled = false
      btn.textContent = "APLICAR SELLO Y SURTIR"
    }
  }

  init()
</script>