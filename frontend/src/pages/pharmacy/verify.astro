---
import FlowLayout from '../../layouts/FlowLayout.astro'
const steps = [
  { label: 'ESCANEAR', href: '/pharmacy' },
  { label: 'VERIFICAR', href: '/pharmacy/verify' },
  { label: 'DISPENSAR', href: '/pharmacy/seal' },
]
---
<FlowLayout title="Farmacia — Verificar" role="pharmacy" steps={steps} currentStep={1} back="/pharmacy" wide={true}>
<div class="anim-slide" style="display:flex;flex-direction:column;gap:12px;">
  <div>
    <h1 style="font-family:'Press Start 2P',monospace;font-size:13px;color:var(--text-primary);margin-bottom:0;">VERIFICACIÓN DE RECETA</h1>
  </div>

  <div id="state-loading" class="px-card-dark" style="padding:22px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:12px;">
    <div class="px-spinner" style="border-top-color:var(--role-pharmacy);"></div>
    <p style="font-family:'Press Start 2P',monospace;font-size:9px;color:var(--text-subtle);" class="anim-blink">VERIFICANDO FIRMA Y DESCIFRANDO...</p>
  </div>

  <!-- Paciente en una sola fila (2 líneas internas) -->
  <div id="patient-card" style="display:none; background:var(--surface-card); border:3px solid var(--role-patient); box-shadow:var(--shadow-blue); padding:10px 14px;">
    <div style="display:flex; align-items:center; gap:14px;">
      <svg width="26" height="30" viewBox="0 0 24 28" style="image-rendering:pixelated;color:var(--role-patient);flex-shrink:0;"><use href="#ico-patient"/></svg>
      <div style="display:flex;flex-direction:column;gap:2px;flex:1;min-width:0;">
        <p style="font-family:'Press Start 2P',monospace; font-size:8px; color:var(--role-patient);">PACIENTE</p>
        <p id="p-name" style="font-family:'VT323',monospace; font-size:20px; color:var(--text-primary);">—</p>
      </div>
    </div>
  </div>

  <!-- Banner de firma válida y prescripción pegados (sin margin entre ellos) -->
  <div id="result-valid" style="display:none; background:rgba(56,183,100,.12); border:3px solid var(--role-doctor); border-bottom:none; box-shadow:none; padding:10px 14px; align-items:center; gap:12px;">
    <svg width="22" height="26" viewBox="0 0 24 28" style="image-rendering:pixelated;color:var(--role-doctor);flex-shrink:0;"><use href="#ico-shield"/></svg>
    <p style="font-family:'Press Start 2P',monospace; font-size:8px; color:var(--role-doctor); line-height:1.5;">FIRMA DIGITAL VÁLIDA · DOCUMENTO AUTÉNTICO</p>
  </div>

  <div id="result-error" style="display:none; background:rgba(232,0,61,.12); border:3px solid var(--role-pharmacy); box-shadow:var(--shadow-red); padding:12px; align-items:center; gap:12px;">
    <svg width="22" height="22" viewBox="0 0 16 16" style="image-rendering:pixelated;color:var(--role-pharmacy);flex-shrink:0;"><use href="#ico-x"/></svg>
    <p id="result-error-msg" style="font-family:'Press Start 2P',monospace; font-size:8px; color:var(--role-pharmacy); line-height:1.5;">ERROR: LA FIRMA NO COINCIDE O LOS DATOS FUERON ALTERADOS</p>
  </div>

  <div id="prescription-container" style="display:none; background:var(--surface-card); border:3px solid var(--role-doctor); border-top:none; box-shadow:var(--shadow-green); padding:0; overflow:hidden; margin-top:-12px;">
    <div id="prescription-body"></div>
  </div>

  <div id="action-valid" style="display:none; margin-top:10px;">
    <button id="btn-go-seal" class="px-btn px-btn-blue" style="width:100%; justify-content:center;">IR A DISPENSACIÓN ►</button>
  </div>
  <div id="action-error" style="display:none; margin-top:10px;">
    <a href="/pharmacy" class="px-btn px-btn-red" style="width:100%; justify-content:center; text-decoration:none;">VOLVER A ESCANEAR</a>
  </div>

</div>
</FlowLayout>

<script>
  import { requireSession } from '../../utils/sessionGuard.ts'
  import { cargarRecetaValidada, RecetaValidationError } from '../../utils/pharmacyReceta.ts'
  import { decryptReveal } from '../../utils/scrambleReveal.ts'

  requireSession('Farmaceutico', '/pharmacy/login')

  function bloquear(msg: string, err: unknown) {
    console.error('Verificación bloqueada:', err)
    document.getElementById('state-loading')!.style.display = 'none'
    // Compuerta dura: nunca se muestra el panel "válido" ni el botón de dispensar.
    document.getElementById('result-valid')!.style.display = 'none'
    document.getElementById('action-valid')!.style.display = 'none'
    document.getElementById('result-error-msg')!.textContent = msg
    document.getElementById('result-error')!.style.display = 'flex'
    document.getElementById('action-error')!.style.display = 'flex'
  }

  async function init() {
    const params = new URLSearchParams(window.location.search)
    const idReceta = Number(params.get('id'))
    const demoInvalid = params.get('demo_invalid')

    if (!idReceta) return window.location.href = '/pharmacy'

    // Modo demo: simula que la receta es inválida SIN tocar el backend.
    // Se usa desde el panel /admin (sección INVÁLIDAS) para que durante
    // una presentación se pueda mostrar qué ocurre cuando la firma no
    // cuadra, los datos fueron alterados o el médico no está certificado.
    if (demoInvalid) {
      const motivos: Record<string, string> = {
        signature:   'FIRMA INVÁLIDA · La firma ECDSA no coincide con la llave pública del médico.',
        manipulated: 'RECETA MANIPULADA · El contenido fue alterado después de firmar.',
        no_cert:     'MÉDICO NO CERTIFICADO · Cédula profesional no validada en el directorio.',
      }
      const motivo = motivos[demoInvalid] || 'RECETA INVÁLIDA · No se puede dispensar.'
      // Pequeño delay para que se vea el spinner antes del rechazo.
      setTimeout(() => bloquear(motivo, new Error(`demo_invalid=${demoInvalid}`)), 900)
      return
    }

    try {
      // Carga + descifrado + TODAS las validaciones (firma del médico incluida).
      const { recetaInfo, contenedor } = await cargarRecetaValidada(idReceta)

      document.getElementById('p-name')!.textContent = recetaInfo.paciente.nombre_completo.toUpperCase()
      document.getElementById('patient-card')!.style.display = 'block'

      document.getElementById('state-loading')!.style.display = 'none'
      document.getElementById('result-valid')!.style.display = 'flex'
      document.getElementById('action-valid')!.style.display = 'flex'

      renderPrescription(contenedor.datos, recetaInfo.medico.nombre_completo)

      document.getElementById('btn-go-seal')?.addEventListener('click', () => {
        window.location.href = `/pharmacy/seal?id=${idReceta}`
      })

    } catch (err) {
      const msg = err instanceof RecetaValidationError
        ? err.message
        : 'Error inesperado al verificar la receta.'
      bloquear(msg, err)
    }
  }

  function renderPrescription(datos: any, medicoName: string) {
    const container = document.getElementById('prescription-container')!
    const body = document.getElementById('prescription-body')!
    container.style.display = 'block'

    let html = `
      <div style="background:var(--role-doctor); padding:8px 14px;display:flex;align-items:center;gap:8px;">
        <svg width="22" height="11" viewBox="0 0 32 16" style="image-rendering:pixelated;"><use href="#ico-pill"/></svg>
        <span style="font-family:'Press Start 2P',monospace; font-size:8px; color:#fff;">DETALLE DE PRESCRIPCIÓN</span>
      </div>
      <div style="padding:14px 16px;">
      <div style="display:flex; justify-content:space-between; padding:6px 0; border-bottom:2px solid var(--border-default);gap:12px;">
        <span style="font-family:'Press Start 2P',monospace; font-size:7px; color:var(--text-dim);">MÉDICO EMISOR</span>
        <span class="rx-scramble" style="font-family:'VT323',monospace; font-size:20px; color:var(--role-doctor); text-align:right;">DR. ${medicoName.toUpperCase()}</span>
      </div>
    `

    datos.medicamentos.forEach((m: any, i: number) => {
      html += `
        <div style="margin-top:10px; padding:10px 12px; background: rgba(56, 183, 100, 0.06); border-left: 3px solid var(--role-doctor);">
          <div style="display:flex; justify-content:space-between; padding-bottom:6px;gap:12px;">
            <span style="font-family:'Press Start 2P',monospace; font-size:7px; color:var(--role-doctor);">ÍTEM ${i + 1}</span>
            <span class="rx-scramble" style="font-family:'Press Start 2P',monospace; font-size:10px; color:var(--text-primary); text-align:right;">${m.nombre}</span>
          </div>
          <div style="display:flex; justify-content:space-between; padding:3px 0;gap:12px;">
            <span style="font-family:'Press Start 2P',monospace; font-size:7px; color:var(--text-dim);">PRESENTACIÓN</span>
            <span class="rx-scramble" style="font-family:'VT323',monospace; font-size:19px; color:var(--text-primary); text-align:right;">${m.dosis} · ${m.forma}</span>
          </div>
          <div style="display:flex; justify-content:space-between; padding:3px 0;gap:12px;">
            <span style="font-family:'Press Start 2P',monospace; font-size:7px; color:var(--text-dim);">CANTIDAD</span>
            <span class="rx-scramble" style="font-family:'VT323',monospace; font-size:19px; color:var(--text-primary); text-align:right;">${m.cantidad} UNIDADES</span>
          </div>
          <div style="margin-top:6px; padding-top:6px; border-top:1px dashed var(--border-default);">
            <p style="font-family:'Press Start 2P',monospace; font-size:6px; color:var(--text-dim); margin-bottom:4px;">INDICACIONES</p>
            <p class="rx-scramble" style="font-family:'VT323',monospace; font-size:18px; color:var(--text-primary); line-height:1.4;">${m.instrucciones}</p>
          </div>
        </div>
      `
    })
    html += '</div>'
    
    body.innerHTML = html
    // Tras pasar las 3 validaciones cripto, la receta se "descifra" en
    // pantalla. Velocidad media: aprox 4-5s totales (legible para el
    // farmacéutico sin ser exagerado).
    decryptReveal(
      Array.from(body.querySelectorAll<HTMLElement>('.rx-scramble')),
      { mode: 'medium' },
    )
  }

  init()
</script>