---
// Astro 5: import via frontmatter so Vite/Tailwind can process it
import '../styles/global.css'
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>RxPro — Prescripciones Digitales</title>

  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem('rxpro_theme') || 'dark';
        if (t !== 'light' && t !== 'dark') t = 'dark';
        document.documentElement.setAttribute('data-theme', t);
      } catch (_) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>

  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 16'><rect x='1' y='3' width='14' height='10' rx='5' fill='%23e8003d'/><rect x='17' y='3' width='14' height='10' rx='5' fill='white'/></svg>"/>
  <style>
    .pill-bg{position:fixed;inset:0;pointer-events:none;overflow:hidden;z-index:0;}
    .pill-sprite{position:absolute;animation:pill-fall linear infinite;opacity:0;}
    .virus-ambient{position:absolute;animation:virus-wiggle ease-in-out infinite;opacity:.35;}
    body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:9998;background:repeating-linear-gradient(0deg,rgba(0,0,0,.035),rgba(0,0,0,.035) 1px,transparent 1px,transparent 3px);}

    /* Theme toggle */
    .rxpro-theme-toggle {
      display:inline-flex;align-items:center;gap:6px;margin-left:12px;padding:5px 8px;
      border:2px solid var(--border-default);background:transparent;color:var(--text-muted);
      font-family:'Press Start 2P',monospace;font-size:7px;letter-spacing:.08em;cursor:pointer;
      transition:all .05s;
    }
    .rxpro-theme-toggle:hover { border-color:var(--text-primary);color:var(--text-primary); }
    .rxpro-theme-toggle .ico-sun  { display:none; }
    .rxpro-theme-toggle .ico-moon { display:inline-block; }
    :root[data-theme="light"] .rxpro-theme-toggle .ico-sun  { display:inline-block; }
    :root[data-theme="light"] .rxpro-theme-toggle .ico-moon { display:none; }

    /* Zero-Knowledge Banner backgrounds */
    .zk-banner {
      background: linear-gradient(135deg, #0d1a0d 0%, var(--surface-inset) 50%, #0d1020 100%);
    }

    :root[data-theme="light"] .zk-banner {
      background: linear-gradient(135deg, #e6f2e8 0%, var(--surface-inset) 50%, #e6ebf2 100%);
    }
  </style>
</head>
<body style="min-height:100vh;display:flex;flex-direction:column;">

<svg xmlns="http://www.w3.org/2000/svg" style="display:none;" aria-hidden="true"><defs>
  <symbol id="ico-doctor" viewBox="0 0 24 28"><rect x="7" y="0" width="10" height="10" fill="#f4c87a"/><rect x="5" y="2" width="14" height="8" fill="#f4c87a"/><rect x="5" y="0" width="14" height="3" fill="#5c3a1e"/><rect x="8" y="4" width="2" height="2" fill="#1a1c2c"/><rect x="14" y="4" width="2" height="2" fill="#1a1c2c"/><rect x="9" y="7" width="6" height="1" fill="#c0724a"/><rect x="4" y="10" width="16" height="14" fill="white"/><rect x="4" y="10" width="4" height="10" fill="#e0e0e0"/><rect x="16" y="10" width="4" height="10" fill="#e0e0e0"/><rect x="10" y="13" width="4" height="2" fill="#38b764"/><rect x="11" y="12" width="2" height="4" fill="#38b764"/><rect x="0" y="11" width="4" height="10" fill="white"/><rect x="20" y="11" width="4" height="10" fill="white"/></symbol>
  <symbol id="ico-patient" viewBox="0 0 24 28"><rect x="7" y="0" width="10" height="10" fill="#f4c87a"/><rect x="5" y="2" width="14" height="8" fill="#f4c87a"/><rect x="5" y="0" width="14" height="4" fill="#3d2b1f"/><rect x="8" y="4" width="2" height="2" fill="#1a1c2c"/><rect x="14" y="4" width="2" height="2" fill="#1a1c2c"/><rect x="4" y="11" width="16" height="13" fill="#41a6f6"/><rect x="0" y="12" width="4" height="9" fill="#41a6f6"/><rect x="20" y="12" width="4" height="9" fill="#41a6f6"/><rect x="9" y="10" width="6" height="3" fill="#f4c87a"/></symbol>
  <symbol id="ico-pharmacist" viewBox="0 0 24 28"><rect x="7" y="0" width="10" height="10" fill="#f4a67a"/><rect x="5" y="2" width="14" height="8" fill="#f4a67a"/><rect x="6" y="0" width="12" height="3" fill="#8B4513"/><rect x="4" y="1" width="4" height="4" fill="#8B4513"/><rect x="16" y="1" width="4" height="4" fill="#8B4513"/><rect x="8" y="4" width="2" height="2" fill="#1a1c2c"/><rect x="14" y="4" width="2" height="2" fill="#1a1c2c"/><rect x="4" y="10" width="16" height="14" fill="white"/><rect x="4" y="10" width="4" height="10" fill="#ddd"/><rect x="16" y="10" width="4" height="10" fill="#ddd"/><rect x="10" y="12" width="2" height="6" fill="#e8003d"/><rect x="10" y="12" width="5" height="2" fill="#e8003d"/><rect x="13" y="14" width="2" height="2" fill="#e8003d"/><rect x="12" y="16" width="3" height="2" fill="#e8003d"/><rect x="0" y="11" width="4" height="10" fill="white"/><rect x="20" y="11" width="4" height="10" fill="white"/></symbol>
  <symbol id="ico-virus" viewBox="0 0 20 20"><rect x="3" y="0" width="14" height="2" fill="currentColor"/><rect x="1" y="2" width="18" height="14" fill="currentColor"/><rect x="3" y="16" width="14" height="2" fill="currentColor"/><rect x="5" y="18" width="10" height="2" fill="currentColor"/><rect x="8" y="0" width="4" height="2" fill="currentColor"/><rect x="8" y="18" width="4" height="2" fill="currentColor"/><rect x="0" y="8" width="2" height="4" fill="currentColor"/><rect x="18" y="8" width="2" height="4" fill="currentColor"/><rect x="3" y="5" width="6" height="6" fill="white"/><rect x="11" y="5" width="6" height="6" fill="white"/><rect x="4" y="6" width="4" height="4" fill="#1a1c2c"/><rect x="12" y="6" width="4" height="4" fill="#1a1c2c"/><rect x="5" y="12" width="10" height="2" fill="white"/><rect x="7" y="14" width="6" height="1" fill="white"/></symbol>
  <symbol id="ico-checkmark" viewBox="0 0 20 16"><rect x="0" y="8" width="4" height="4" fill="currentColor"/><rect x="4" y="11" width="4" height="4" fill="currentColor"/><rect x="8" y="7" width="4" height="4" fill="currentColor"/><rect x="12" y="3" width="4" height="4" fill="currentColor"/><rect x="16" y="0" width="4" height="3" fill="currentColor"/></symbol>
  <symbol id="ico-star" viewBox="0 0 20 20"><rect x="8" y="0" width="4" height="4" fill="currentColor"/><rect x="6" y="4" width="8" height="4" fill="currentColor"/><rect x="0" y="6" width="20" height="4" fill="currentColor"/><rect x="2" y="10" width="16" height="4" fill="currentColor"/><rect x="4" y="14" width="4" height="4" fill="currentColor"/><rect x="12" y="14" width="4" height="4" fill="currentColor"/><rect x="2" y="16" width="4" height="4" fill="currentColor"/><rect x="14" y="16" width="4" height="4" fill="currentColor"/></symbol>
  <symbol id="ico-heart" viewBox="0 0 22 20"><rect x="2" y="0" width="6" height="4" fill="currentColor"/><rect x="14" y="0" width="6" height="4" fill="currentColor"/><rect x="0" y="4" width="10" height="6" fill="currentColor"/><rect x="12" y="4" width="10" height="6" fill="currentColor"/><rect x="0" y="6" width="22" height="6" fill="currentColor"/><rect x="2" y="12" width="18" height="4" fill="currentColor"/><rect x="4" y="16" width="14" height="3" fill="currentColor"/><rect x="7" y="19" width="8" height="2" fill="currentColor"/></symbol>
  <symbol id="ico-shield" viewBox="0 0 24 28"><rect x="3" y="0" width="18" height="2" fill="currentColor"/><rect x="1" y="2" width="22" height="16" fill="currentColor"/><rect x="2" y="18" width="20" height="2" fill="currentColor"/><rect x="4" y="20" width="16" height="2" fill="currentColor"/><rect x="6" y="22" width="12" height="2" fill="currentColor"/><rect x="8" y="24" width="8" height="2" fill="currentColor"/><rect x="10" y="26" width="4" height="2" fill="currentColor"/><rect x="3" y="0" width="18" height="5" fill="rgba(255,255,255,.2)"/></symbol>
  <symbol id="ico-key" viewBox="0 0 28 16"><rect x="2" y="3" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2"/><rect x="4" y="5" width="6" height="6" rx="1" fill="#1a1c2c"/><rect x="12" y="7" width="16" height="2" fill="currentColor"/><rect x="22" y="9" width="2" height="3" fill="currentColor"/><rect x="25" y="9" width="2" height="2" fill="currentColor"/></symbol>
  <symbol id="ico-lock" viewBox="0 0 20 24"><rect x="4" y="8" width="12" height="14" fill="currentColor"/><rect x="2" y="10" width="16" height="12" fill="currentColor"/><rect x="6" y="0" width="8" height="2" fill="currentColor"/><rect x="4" y="2" width="2" height="8" fill="currentColor"/><rect x="14" y="2" width="2" height="8" fill="currentColor"/><rect x="6" y="2" width="8" height="2" fill="currentColor"/><rect x="8" y="13" width="4" height="2" fill="#1a1c2c"/><rect x="9" y="15" width="2" height="4" fill="#1a1c2c"/></symbol>
  <symbol id="ico-clipboard" viewBox="0 0 22 28"><rect x="0" y="4" width="22" height="22" fill="white"/><rect x="0" y="4" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"/><rect x="7" y="0" width="8" height="5" fill="currentColor"/><rect x="8" y="1" width="6" height="3" fill="#1a1c2c"/><rect x="3" y="10" width="16" height="2" fill="#c0cbdc"/><rect x="3" y="15" width="16" height="2" fill="#c0cbdc"/><rect x="3" y="20" width="10" height="2" fill="#c0cbdc"/><rect x="3" y="6" width="7" height="2" fill="currentColor"/></symbol>
</defs></svg>

<div id="px-loader" class="px-loader">
  <div style="animation:px-bounce .5s ease-in-out infinite;">
    <svg width="80" height="40" viewBox="0 0 32 16" style="image-rendering:pixelated;">
      <rect x="1" y="3" width="14" height="10" rx="5" fill="#e8003d"/>
      <rect x="17" y="3" width="14" height="10" rx="5" fill="#f4f4f4"/>
      <rect x="15" y="3" width="2" height="10" fill="#1a1c2c"/>
      <rect x="2" y="3" width="12" height="4" rx="3" fill="rgba(255,255,255,.25)"/>
    </svg>
  </div>
  <div style="font-family:'Press Start 2P',monospace;font-size:10px;color:var(--role-pharmacy,#e8003d);letter-spacing:.1em;" id="loader-msg">CARGANDO...</div>
  <div class="px-progress-track">
    <div class="px-progress-fill"></div>
  </div>
</div>

<div class="pill-bg" aria-hidden="true">
  {Array.from({length:16}).map((_,idx)=>{
    const pairs=[['#e8003d','#f4f4f4'],['#41a6f6','#29366f'],['#38b764','#ffcd75'],['#ffcd75','#e8003d'],['#f4f4f4','#41a6f6'],['#b13e53','#38b764']]
    const [a,b]=pairs[idx%6]
    const pL=((idx*6.2)%100),pD=(7+(idx*1.2)%11),pDel=((idx*0.9)%9),pR=((idx*53)%360)
    return <div class="pill-sprite" style={'left:'+pL+'%;animation-duration:'+pD+'s;animation-delay:'+pDel+'s;'}><svg width="14" height="28" viewBox="0 0 32 16" style={'image-rendering:pixelated;transform:rotate('+pR+'deg);'}><rect x="1" y="3" width="14" height="10" rx="5" fill={a}/><rect x="17" y="3" width="14" height="10" rx="5" fill={b}/><rect x="15" y="3" width="2" height="10" fill="#1a1c2c"/></svg></div>
  })}
  {[{t:'10%',l:'4%',c:'#e8003d',d:'0s',du:'1.5s'},{t:'35%',l:'93%',c:'#41a6f6',d:'.6s',du:'1.9s'},{t:'62%',l:'3%',c:'#38b764',d:'1.2s',du:'1.4s'},{t:'80%',l:'90%',c:'#ffcd75',d:'.3s',du:'2s'},{t:'22%',l:'88%',c:'#b13e53',d:'1s',du:'1.7s'}].map(v=>(
    <div class="virus-ambient" style={'top:'+v.t+';left:'+v.l+';animation-delay:'+v.d+';animation-duration:'+v.du+';color:'+v.c+';'}>
      <svg width="24" height="24" viewBox="0 0 20 20" style="image-rendering:pixelated;"><use href="#ico-virus"/></svg>
    </div>
  ))}
</div>

<header style="background:var(--surface-topbar);border-bottom:4px solid var(--surface-topbar-border);position:sticky;top:0;z-index:50;">
  <div style="max-width:1100px;margin:0 auto;padding:0 20px;height:52px;display:flex;align-items:center;justify-content:space-between;">
    <div style="display:flex;align-items:center;gap:10px;">
      <svg width="36" height="18" viewBox="0 0 32 16" style="image-rendering:pixelated;"><rect x="1" y="3" width="14" height="10" rx="5" fill="#e8003d"/><rect x="17" y="3" width="14" height="10" rx="5" fill="#f4f4f4"/><rect x="15" y="3" width="2" height="10" fill="#1a1c2c"/><rect x="2" y="3" width="12" height="4" rx="3" fill="rgba(255,255,255,.25)"/></svg>
      <span style="font-family:'Press Start 2P',monospace;font-size:13px;color:var(--text-primary);">RxPro</span>
    </div>
    <div style="display:flex;align-items:center;gap:8px;">
      <span class="anim-blink" style="display:inline-block;width:8px;height:8px;background:#38b764;"></span>
      <span style="font-family:'Press Start 2P',monospace;font-size:8px;color:#38b764;">SISTEMA ACTIVO</span>
    </div>
    <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:center;">
      <a href="/admin/login" title="Acceso administrador" aria-label="Acceso administrador"
         style="font-family:'Press Start 2P',monospace;font-size:7px;padding:5px 9px;border:2px solid var(--role-doctor);color:var(--role-doctor);text-decoration:none;letter-spacing:.08em;display:inline-flex;align-items:center;gap:6px;">
        <svg width="9" height="11" viewBox="0 0 20 24" style="image-rendering:pixelated;"><use href="#ico-lock"/></svg>
        ADMIN
      </a>

      <button id="rxpro-theme-toggle" type="button" title="Cambiar tema" class="rxpro-theme-toggle">
        <svg class="ico-moon" width="11" height="11" viewBox="0 0 14 14" style="image-rendering:pixelated;">
          <rect x="6" y="0" width="6" height="2" fill="currentColor"/>
          <rect x="3" y="2" width="7" height="2" fill="currentColor"/>
          <rect x="1" y="4" width="7" height="2" fill="currentColor"/>
          <rect x="0" y="6" width="7" height="2" fill="currentColor"/>
          <rect x="1" y="8" width="7" height="2" fill="currentColor"/>
          <rect x="3" y="10" width="7" height="2" fill="currentColor"/>
          <rect x="6" y="12" width="6" height="2" fill="currentColor"/>
        </svg>
        <svg class="ico-sun" width="11" height="11" viewBox="0 0 14 14" style="image-rendering:pixelated;">
          <rect x="6" y="0" width="2" height="3" fill="currentColor"/>
          <rect x="6" y="11" width="2" height="3" fill="currentColor"/>
          <rect x="0" y="6" width="3" height="2" fill="currentColor"/>
          <rect x="11" y="6" width="3" height="2" fill="currentColor"/>
          <rect x="2" y="2" width="2" height="2" fill="currentColor"/>
          <rect x="10" y="2" width="2" height="2" fill="currentColor"/>
          <rect x="2" y="10" width="2" height="2" fill="currentColor"/>
          <rect x="10" y="10" width="2" height="2" fill="currentColor"/>
          <rect x="5" y="4" width="4" height="6" fill="currentColor"/>
          <rect x="4" y="5" width="6" height="4" fill="currentColor"/>
        </svg>
        <span id="rxpro-theme-label">MODO</span>
      </button>
    </div>
  </div>
</header>

<main style="flex:1;position:relative;z-index:1;max-width:1180px;margin:0 auto;width:100%;padding:36px 20px;">

  <h1 class="anim-slide" style="font-family:'Press Start 2P',monospace;font-size:clamp(18px,3.4vw,32px);color:var(--text-primary);text-align:center;margin-bottom:8px;line-height:1.7;">
    PRESCRIPCIONES
  </h1>
  <h1 class="anim-slide d1" style="font-family:'Press Start 2P',monospace;font-size:clamp(18px,3.4vw,32px);color:#ffcd75;text-align:center;margin-bottom:36px;line-height:1.7;">
    DIGITALES
  </h1>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-bottom:0;">
    {[
      {href:'/doctor',   ico:'doctor',      title:'MÉDICO',       c:'#38b764',dark:'#257a43',features:['Emite recetas en minutos','Formulario paso a paso','Envío instantáneo'],btn:'px-btn-green',desc:'Prescribe medicamentos a tus pacientes desde una interfaz simple y rápida.'},
      {href:'/patient',  ico:'patient',     title:'PACIENTE',     c:'#41a6f6',dark:'#1a6eb0',features:['Acceso con tarjeta QR','Consulta tus recetas','Llévalas a cualquier farmacia'],  btn:'px-btn-blue', desc:'Escanea tu tarjeta para ver y mostrar tus recetas activas.'},
      {href:'/pharmacy', ico:'pharmacist',  title:'FARMACÉUTICO', c:'#e8003d',dark:'#8c0025',features:['Verifica autenticidad','Surte y registra','Historial permanente'],btn:'px-btn-red',desc:'Comprueba que la receta es auténtica y sella el despacho.'},
    ].map((card,idx)=>{
      const cs = 'text-decoration:none;display:block;background:var(--surface-card);border:3px solid '+card.c+';box-shadow:6px 6px 0 '+card.dark+';padding:26px;transition:transform .08s;'
      const bs = '8px 10px 0 '+card.dark
      const bs0= '6px 6px 0 '+card.dark
      return (
      <a href={card.href} style={cs}
         class={'anim-slide d'+(idx+1)}
         onmouseover={"this.style.transform='translateY(-4px)';this.style.boxShadow='"+bs+"'"}
         onmouseout={"this.style.transform='';this.style.boxShadow='"+bs0+"'"}>
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
          <div style={'width:48px;height:48px;display:flex;align-items:center;justify-content:center;border:3px solid '+card.c+';background:'+card.c+'22;'}>
            <svg width="28" height="33" viewBox="0 0 24 28" style="image-rendering:pixelated;"><use href={'#ico-'+card.ico}/></svg>
          </div>
          <span style={"font-family:'Press Start 2P',monospace;font-size:11px;color:"+card.c+';'}>{card.title}</span>
        </div>
        <p style="font-family:'VT323',monospace;font-size:20px;color:var(--text-muted);margin-bottom:16px;line-height:1.5;">{card.desc}</p>
        <div style="margin-bottom:20px;">
          {card.features.map(f=>(
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:7px;">
              <svg width="14" height="11" viewBox="0 0 20 16" style={'image-rendering:pixelated;color:'+card.c+';flex-shrink:0;'}><use href="#ico-checkmark"/></svg>
              <span style="font-family:'VT323',monospace;font-size:19px;color:var(--text-primary);">{f}</span>
            </div>
          ))}
        </div>
        <div class={'px-btn '+card.btn} style="width:100%;justify-content:center;font-size:9px;">
          ENTRAR
          <svg width="12" height="9" viewBox="0 0 16 12" style="image-rendering:pixelated;color:currentColor;"><rect x="0" y="4" width="12" height="4" fill="currentColor"/><rect x="8" y="0" width="4" height="4" fill="currentColor"/><rect x="8" y="8" width="4" height="4" fill="currentColor"/><rect x="12" y="2" width="2" height="2" fill="currentColor"/><rect x="12" y="8" width="2" height="2" fill="currentColor"/><rect x="14" y="4" width="2" height="4" fill="currentColor"/></svg>
        </div>
      </a>
      )
    })}
  </div>

</main>

<footer style="background:var(--surface-topbar);border-top:3px solid var(--surface-stepbar);padding:12px 20px;position:relative;z-index:1;">
  <div style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:10px;">
    <span style="font-family:'Press Start 2P',monospace;font-size:7px;color:var(--text-subtle);">RxPro · CRYPTOGRAPHY PROJECT 2026</span>
  </div>
</footer>

<script>
  // Loader messages
  const msgs=['CARGANDO...','INICIANDO...','CIFRANDO...','LISTO...']
  const el=document.getElementById('loader-msg')
  let mi=0
  if(el){const iv=setInterval(()=>{el.textContent=msgs[++mi%msgs.length]},180);setTimeout(()=>clearInterval(iv),780)}


  // Theme toggle (dark ⇄ light, persistido en localStorage)
  try {
    const toggleBtn = document.getElementById('rxpro-theme-toggle')
    const toggleLbl = document.getElementById('rxpro-theme-label')
    const applyLabel = () => {
      const t = document.documentElement.getAttribute('data-theme') || 'dark'
      if (toggleLbl) toggleLbl.textContent = t === 'light' ? 'CLARO' : 'OSCURO'
    }
    applyLabel()
    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        const cur = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark'
        const next = cur === 'light' ? 'dark' : 'light'
        document.documentElement.setAttribute('data-theme', next)
        try { localStorage.setItem('rxpro_theme', next) } catch {}
        applyLabel()
      })
    }
  } catch { /* noop */ }
</script>
</body>
</html>
