    </div>
  ))}
    <!-- Ambient viruses -->
  {[
    {t:'12%',l:'4%', c:'#e8003d',d:'0s',  dur:'1.5s'},
    {t:'38%',l:'93%',c:'#41a6f6',d:'.6s', dur:'1.9s'},
    {t:'65%',l:'3%', c:'#38b764',d:'1.2s',dur:'1.4s'},
    {t:'78%',l:'90%',c:'#ffcd75',d:'.3s', dur:'2.1s'},
    {t:'22%',l:'87%',c:'#b13e53',d:'1s',  dur:'1.7s'},
    {t:'50%',l:'97%',c:'#38b764',d:'1.5s',dur:'1.3s'},
  ].map(v=>{
    const vs = 'top:'+v.t+';left:'+v.l+';animation-delay:'+v.d+';animation-duration:'+v.dur+';color:'+v.c+';'
    return (
      <div class="virus-ambient" style={vs}>
        <svg width="24" height="24" viewBox="0 0 20 20" style="image-rendering:pixelated;"><use href="#ico-virus"/></svg>
      </div>
    )
  })}
</div>

<!-- ═══ TOP BAR ══════════════════════════════════════════════════ -->
<header class="topbar">
  <div style="max-width:1100px;margin:0 auto;padding:0 20px;height:52px;display:flex;align-items:center;justify-content:space-between;gap:12px;">

    <!-- Logo -->
    <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0;">
      <svg width="36" height="18" viewBox="0 0 32 16" style="image-rendering:pixelated;">
        <rect x="1" y="3" width="14" height="10" rx="5" fill="#e8003d"/>
        <rect x="17" y="3" width="14" height="10" rx="5" fill="#f4f4f4"/>
        <rect x="15" y="3" width="2" height="10" fill="#1a1c2c"/>
        <rect x="2" y="3" width="12" height="4" rx="3" fill="rgba(255,255,255,.25)"/>
      </svg>
      <span class="rxpro-wordmark" style="font-family:'Press Start 2P',monospace;font-size:12px;">RxPro</span>
    </a>

    <!-- Role badge with icon -->
    <div style={roleBadgeStyle}>
      <svg width="18" height="20" viewBox="0 0 24 28" style="image-rendering:pixelated;">
        <use href={'#ico-'+rc.ico}/>
      </svg>
      <span style={roleLabelStyle}>{rc.label}</span>
    </div>

    <!-- Nav with role icons -->
    <nav style="display:flex;gap:3px;align-items:center;">
      {navLinks.map((r) => (
        <a href={r.href}
           title={r.label}
           style={r.style}
           onmouseover={r.onOver}
           onmouseout={r.onOut}>
          <svg width="14" height="17" viewBox="0 0 24 28" style="image-rendering:pixelated;">
            <use href={'#ico-'+r.ico}/>
          </svg>
          <span style={r.spanStyle} class="sm:inline">{r.label}</span>
        </a>
      ))}

      <!-- Theme toggle (claro/oscuro) -->
      <button id="rxpro-theme-toggle" type="button" title="Cambiar tema" class="rxpro-theme-toggle">
        <svg class="ico-moon" width="11" height="11" viewBox="0 0 14 14" style="image-rendering:pixelated;">
          <rect x="6" y="0" width="6" height="2" fill="currentColor"/>
          <rect x="3" y="2" width="7" height="2" fill="currentColor"/>
          <rect x="1" y="4" width="7" height="2" fill="currentColor"/>
          <rect x="0" y="6" width="7" height="2" fill="currentColor"/>
          <rect x="1" y="8" width="7" height="2" fill="currentColor"/>
          <rect x="3" y="10" width="7" height="2" fill="currentColor"/>
          <rect x="6" y="12" width="6" height="2" fill="currentColor"/>
        </svg>
        <svg class="ico-sun" width="11" height="11" viewBox="0 0 14 14" style="image-rendering:pixelated;">
          <rect x="6" y="0" width="2" height="3" fill="currentColor"/>
          <rect x="6" y="11" width="2" height="3" fill="currentColor"/>
          <rect x="0" y="6" width="3" height="2" fill="currentColor"/>
          <rect x="11" y="6" width="3" height="2" fill="currentColor"/>
          <rect x="2" y="2" width="2" height="2" fill="currentColor"/>
          <rect x="10" y="2" width="2" height="2" fill="currentColor"/>
          <rect x="2" y="10" width="2" height="2" fill="currentColor"/>
          <rect x="10" y="10" width="2" height="2" fill="currentColor"/>
          <rect x="5" y="4" width="4" height="6" fill="currentColor"/>
          <rect x="4" y="5" width="6" height="4" fill="currentColor"/>
        </svg>
        <span id="rxpro-theme-label">MODO</span>
      </button>

      <!-- Logout: visible solo cuando hay sesión (ver script al final). -->
      <button id="rxpro-logout" type="button" title="Cerrar sesión"
              style="display:none;margin-left:6px;padding:5px 8px;border:2px solid var(--border-default);background:transparent;color:var(--text-muted);box-shadow:none;cursor:pointer;font-family:'Press Start 2P',monospace;font-size:7px;letter-spacing:.08em;align-items:center;gap:6px;transition:all .05s;"
              onmouseover="this.style.borderColor='var(--role-pharmacy)';this.style.color='var(--role-pharmacy)';this.style.background='color-mix(in srgb, var(--role-pharmacy) 12%, transparent)'"
              onmouseout="this.style.borderColor='var(--border-default)';this.style.color='var(--text-muted)';this.style.background='transparent'">
        <svg width="12" height="12" viewBox="0 0 16 16" style="image-rendering:pixelated;">
          <rect x="0" y="0" width="4" height="4" fill="currentColor"/>
          <rect x="12" y="0" width="4" height="4" fill="currentColor"/>
          <rect x="4" y="4" width="4" height="4" fill="currentColor"/>
          <rect x="8" y="4" width="4" height="4" fill="currentColor"/>
          <rect x="4" y="8" width="4" height="4" fill="currentColor"/>
          <rect x="8" y="8" width="4" height="4" fill="currentColor"/>
          <rect x="0" y="12" width="4" height="4" fill="currentColor"/>
          <rect x="12" y="12" width="4" height="4" fill="currentColor"/>
        </svg>
        SALIR
      </button>
    </nav>
  </div>
</header>

<!-- ═══ STEPPER ═══════════════════════════════════════════════════ -->
<div class="stepbar">
  <div style="max-width:640px;margin:0 auto;padding:16px 20px;">
    <div style="display:flex;align-items:center;gap:3px;">
      {stepData.map((sd) => (
        <>
          <div style="display:flex;flex-direction:column;align-items:center;gap:5px;flex-shrink:0;">
            {sd.isDone ? (
              <a href={sd.href} style={sd.aStyle} title={sd.label}>
                <svg width="16" height="13" viewBox="0 0 20 16" style="image-rendering:pixelated;color:white;"><use href="#ico-checkmark"/></svg>
              </a>
            ) : sd.isActive ? (
              <div style={sd.curStyle}>{sd.num}</div>
            ) : (
              <div class="rxpro-step-wait">{sd.num}</div>
            )}
            <span style={sd.spanStyle}>{sd.label}</span>
          </div>
          {!sd.isLast && (
            <div style={sd.lineStyle}></div>
          )}
        </>
      ))}
    </div>
  </div>
</div>

<!-- ═══ MAIN ════════════════════════════════════════════════════ -->
<main class="flow-main">
  <div style={mainWidth}>
    {back && (
      <a href={back} class="rxpro-back"
         style="display:inline-flex;align-items:center;gap:8px;font-family:'Press Start 2P',monospace;font-size:8px;text-decoration:none;margin-bottom:24px;padding:8px 12px;">
        <svg width="12" height="10" viewBox="0 0 16 12" style="image-rendering:pixelated;color:currentColor;">
          <rect x="4" y="4" width="12" height="4" fill="currentColor"/>
          <rect x="4" y="0" width="4" height="4" fill="currentColor"/>
          <rect x="4" y="8" width="4" height="4" fill="currentColor"/>
          <rect x="0" y="4" width="4" height="4" fill="currentColor"/>
        </svg>
        ATRÁS
      </a>
    )}
    <slot/>
  </div>
</main>

<!-- ═══ FOOTER ═══════════════════════════════════════════════════ -->
<footer class="rxpro-footer" style="padding:12px 20px;position:relative;z-index:1;">
  <div style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:10px;">
    <div style="display:flex;align-items:center;gap:8px;">
      <svg width="20" height="10" viewBox="0 0 32 16" style="image-rendering:pixelated;opacity:.5;">
        <rect x="1" y="3" width="14" height="10" rx="5" fill="#e8003d"/>
        <rect x="17" y="3" width="14" height="10" rx="5" fill="#f4f4f4"/>
        <rect x="15" y="3" width="2" height="10" fill="#1a1c2c"/>
      </svg>
      <span class="dim" style="font-family:'Press Start 2P',monospace;font-size:7px;">RxPro · CRYPTOGRAPHY 2026</span>
    </div>
    <div style="display:flex;gap:5px;flex-wrap:wrap;">
      {['ECDSA','AES-GCM','HMAC','RFC8785'].map(t=>(
        <span class="chip" style="font-family:'Press Start 2P',monospace;font-size:6px;padding:3px 7px;">{t}</span>
      ))}
    </div>
  </div>
</footer>

<!-- ═══ BACKEND OFFLINE BANNER ═══════════════════════════════════ -->
<!--
  Se muestra cuando cualquier llamada fetch dentro de utils/api.ts lanza
  por "failed to fetch" (backend caído, DNS malo, CORS bloqueando, etc).
  Se oculta automáticamente cuando el siguiente request vuelve a
  contestar. El botón "reintentar" simplemente recarga la página.
-->
<div id="api-offline-banner"
     style="display:none;position:fixed;top:52px;left:0;right:0;z-index:60;
            background:#2a1018;border-bottom:3px solid #a53030;color:#f4c4c4;
            padding:10px 20px;font-family:'Press Start 2P',monospace;font-size:8px;
            letter-spacing:.08em;display:none;align-items:center;gap:14px;
            justify-content:center;flex-wrap:wrap;">
  <span style="display:inline-flex;align-items:center;gap:8px;">
    <span class="anim-blink" style="display:inline-block;width:8px;height:8px;background:#e8003d;"></span>
    BACKEND NO RESPONDE
  </span>
  <span id="api-offline-detail" style="font-family:'VT323',monospace;font-size:16px;color:#f4a4a4;letter-spacing:normal;"></span>
  <button id="api-offline-retry" type="button"
          style="background:#1a0a0a;border:2px solid #e8003d;color:#e8003d;
                 padding:6px 10px;font-family:'Press Start 2P',monospace;
                 font-size:8px;cursor:pointer;letter-spacing:.08em;">
    REINTENTAR
  </button>
</div>

<!-- ═══ TOAST NOTIFICATION SLOT ══════════════════════════════════ -->
<div id="toast-container"></div>

<script>
  // ── Loader messages cycling ──────────────────────────────────
  const msgs = ['CARGANDO...','CONECTANDO...','CIFRANDO...','LISTO...']
  const el = document.getElementById('loader-msg')
  let mi = 0
  if (el) {
    const iv = setInterval(()=>{ el.textContent = msgs[++mi % msgs.length] }, 180)
    setTimeout(()=> clearInterval(iv), 780)
  }

  // ── Button loading state ─────────────────────────────────────
  document.querySelectorAll('form').forEach(form => {
    form.addEventListener('submit', e => {
      const btn = form.querySelector('button[type="submit"]')
      if (btn) {
        btn.classList.add('px-btn-loading')
        btn.textContent = 'PROCESANDO...'
      }
    })
  })

  // ── Toast helper (global) ────────────────────────────────────
  window.showToast = (msg, color = '#38b764') => {
    const t = document.createElement('div')
    t.className = 'px-toast'
    t.style.borderColor = color
    t.style.color = color
    t.textContent = msg
    document.getElementById('toast-container').appendChild(t)
    setTimeout(() => t.remove(), 2900)
  }

  // ── Theme toggle (dark ⇄ light, persistido en localStorage) ──
  try {
    const toggleBtn = document.getElementById('rxpro-theme-toggle')
    const toggleLbl = document.getElementById('rxpro-theme-label')
    const applyLabel = () => {
      const t = document.documentElement.getAttribute('data-theme') || 'dark'
      if (toggleLbl) toggleLbl.textContent = t === 'light' ? 'CLARO' : 'OSCURO'
    }
    applyLabel()
    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        const cur = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark'
        const next = cur === 'light' ? 'dark' : 'light'
        document.documentElement.setAttribute('data-theme', next)
        try { localStorage.setItem('rxpro_theme', next) } catch {}
        applyLabel()
      })
    }
  } catch { /* noop */ }

  // ── Banner "backend offline" ─────────────────────────────────
  // utils/api.ts dispara eventos globales cuando la red falla o vuelve.
  // Aquí montamos el listener y el botón de reintentar (recarga la pág).
  try {
    const banner = document.getElementById('api-offline-banner')
    const detail = document.getElementById('api-offline-detail')
    const retry  = document.getElementById('api-offline-retry')
    if (banner) {
      window.addEventListener('rxpro:api-offline', (ev) => {
        const d = (ev && ev.detail) || {}
        if (detail && d.message) detail.textContent = '(' + d.message + ')'
        banner.style.display = 'flex'
      })
      window.addEventListener('rxpro:api-online', () => {
        banner.style.display = 'none'
      })
    }
    if (retry) {
      retry.addEventListener('click', () => window.location.reload())
    }
  } catch { /* noop */ }

  // ── Botón de logout en el topbar ─────────────────────────────
  // El botón vive en todos los layouts, pero solo se muestra si hay
  // sesión. No mezclamos con el flujo de login/landing (donde no aplica).
  try {
    const logoutBtn = document.getElementById('rxpro-logout')
    if (logoutBtn) {
      const raw = sessionStorage.getItem('rxpro_session')
      if (raw) {
        logoutBtn.style.display = 'inline-flex'
        logoutBtn.addEventListener('click', () => {
          sessionStorage.removeItem('rxpro_token')
          sessionStorage.removeItem('rxpro_session')
          window.location.replace('/')
        })
      }
    }
  } catch { /* sessionStorage bloqueado: ignorar */ }
</script>

</body>
</html>
