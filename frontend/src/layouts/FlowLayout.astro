</svg>

<!-- ═══ PAGE LOADER ══════════════════════════════════════════════════ -->
<div id="px-loader" class="px-loader">
  <div id="loader-pill" style="animation:px-bounce .5s ease-in-out infinite;">
    <svg width="80" height="40" viewBox="0 0 32 16" style="image-rendering:pixelated;">
      <use href="#ico-pill"/>
    </svg>
  </div>
  <div style={"font-family:'Press Start 2P',monospace;font-size:10px;color:"+rc.color+";letter-spacing:.1em;"} id="loader-msg">
    CARGANDO...
  </div>
  <div class="px-progress-track">
    <div class="px-progress-fill" style={'background:repeating-linear-gradient(90deg,'+rc.color+' 0px,'+rc.color+' 8px,'+rc.dark+' 8px,'+rc.dark+' 16px);'}></div>
  </div>
</div>

<!-- ═══ ANIMATED BG ═══════════════════════════════════════════════ -->
<div class="pill-bg" aria-hidden="true">
  {pillSprites.map((ps) => (
    <div class="pill-sprite" style={ps.style}>
      <svg width="14" height="28" viewBox="0 0 32 16" style={ps.svgStyle}>
        <rect x="1" y="3" width="14" height="10" rx="5" fill={ps.a}/>
        <rect x="17" y="3" width="14" height="10" rx="5" fill={ps.b}/>
        <rect x="15" y="3" width="2" height="10" fill="#1a1c2c"/>
        <rect x="2" y="3" width="12" height="4" rx="3" fill="rgba(255,255,255,.2)"/>
      </svg>
    </div>
  ))}
    <!-- Ambient viruses -->
  {[
    {t:'12%',l:'4%', c:'#e8003d',d:'0s',  dur:'1.5s'},
    {t:'38%',l:'93%',c:'#41a6f6',d:'.6s', dur:'1.9s'},
    {t:'65%',l:'3%', c:'#38b764',d:'1.2s',dur:'1.4s'},
    {t:'78%',l:'90%',c:'#ffcd75',d:'.3s', dur:'2.1s'},
    {t:'22%',l:'87%',c:'#b13e53',d:'1s',  dur:'1.7s'},
    {t:'50%',l:'97%',c:'#38b764',d:'1.5s',dur:'1.3s'},
  ].map(v=>{
    const vs = 'top:'+v.t+';left:'+v.l+';animation-delay:'+v.d+';animation-duration:'+v.dur+';color:'+v.c+';'
    return (
      <div class="virus-ambient" style={vs}>
        <svg width="24" height="24" viewBox="0 0 20 20" style="image-rendering:pixelated;"><use href="#ico-virus"/></svg>
      </div>
    )
  })}
</div>

<!-- ═══ TOP BAR ══════════════════════════════════════════════════ -->
<header class="topbar">
  <div style="max-width:1100px;margin:0 auto;padding:0 20px;height:52px;display:flex;align-items:center;justify-content:space-between;gap:12px;">

    <!-- Logo -->
    <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0;">
      <svg width="36" height="18" viewBox="0 0 32 16" style="image-rendering:pixelated;">
        <rect x="1" y="3" width="14" height="10" rx="5" fill="#e8003d"/>
        <rect x="17" y="3" width="14" height="10" rx="5" fill="#f4f4f4"/>
        <rect x="15" y="3" width="2" height="10" fill="#1a1c2c"/>
        <rect x="2" y="3" width="12" height="4" rx="3" fill="rgba(255,255,255,.25)"/>
      </svg>
      <span style="font-family:'Press Start 2P',monospace;font-size:12px;color:#f4f4f4;">RxPro</span>
    </a>

    <!-- Role badge with icon -->
    <div style={roleBadgeStyle}>
      <svg width="18" height="20" viewBox="0 0 24 28" style="image-rendering:pixelated;">
        <use href={'#ico-'+rc.ico}/>
      </svg>
      <span style={roleLabelStyle}>{rc.label}</span>
    </div>

    <!-- Nav with role icons -->
    <nav style="display:flex;gap:3px;">
      {navLinks.map((r) => (
        <a href={r.href}
           title={r.label}
           style={r.style}
           onmouseover={r.onOver}
           onmouseout={r.onOut}>
          <svg width="14" height="17" viewBox="0 0 24 28" style="image-rendering:pixelated;">
            <use href={'#ico-'+r.ico}/>
          </svg>
          <span style={r.spanStyle} class="sm:inline">{r.label}</span>
        </a>
      ))}
    </nav>
  </div>
</header>

<!-- ═══ STEPPER ═══════════════════════════════════════════════════ -->
<div class="stepbar">
  <div style="max-width:640px;margin:0 auto;padding:16px 20px;">
    <div style="display:flex;align-items:center;gap:3px;">
      {stepData.map((sd) => (
        <>
          <div style="display:flex;flex-direction:column;align-items:center;gap:5px;flex-shrink:0;">
            {sd.isDone ? (
              <a href={sd.href} style={sd.aStyle} title={sd.label}>
                <svg width="16" height="13" viewBox="0 0 20 16" style="image-rendering:pixelated;color:white;"><use href="#ico-checkmark"/></svg>
              </a>
            ) : sd.isActive ? (
              <div style={sd.curStyle}>{sd.num}</div>
            ) : (
              <div style="width:34px;height:34px;border:3px solid #29366f;background:#1a1e30;display:flex;align-items:center;justify-content:center;font-family:'Press Start 2P',monospace;font-size:10px;color:#29366f;">{sd.num}</div>
            )}
            <span style={sd.spanStyle}>{sd.label}</span>
          </div>
          {!sd.isLast && (
            <div style={sd.lineStyle}></div>
          )}
        </>
      ))}
    </div>
  </div>
</div>

<!-- ═══ MAIN ════════════════════════════════════════════════════ -->
<main class="flow-main">
  <div style={mainWidth}>
    {back && (
      <a href={back}
         style="display:inline-flex;align-items:center;gap:8px;font-family:'Press Start 2P',monospace;font-size:8px;color:#5b6ee1;text-decoration:none;margin-bottom:24px;padding:8px 12px;border:2px solid #29366f;background:#1a1e30;box-shadow:2px 2px 0 #0d0e1a;"
         onmouseover="this.style.color='#f4f4f4';this.style.borderColor='#5b6ee1'"
         onmouseout="this.style.color='#5b6ee1';this.style.borderColor='#29366f'">
        <svg width="12" height="10" viewBox="0 0 16 12" style="image-rendering:pixelated;color:currentColor;">
          <rect x="4" y="4" width="12" height="4" fill="currentColor"/>
          <rect x="4" y="0" width="4" height="4" fill="currentColor"/>
          <rect x="4" y="8" width="4" height="4" fill="currentColor"/>
          <rect x="0" y="4" width="4" height="4" fill="currentColor"/>
        </svg>
        ATRÁS
      </a>
    )}
    <slot/>
  </div>
</main>

<!-- ═══ FOOTER ═══════════════════════════════════════════════════ -->
<footer style="background:#0d0e1a;border-top:3px solid #1a1e30;padding:12px 20px;position:relative;z-index:1;">
  <div style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:10px;">
    <div style="display:flex;align-items:center;gap:8px;">
      <svg width="20" height="10" viewBox="0 0 32 16" style="image-rendering:pixelated;opacity:.5;">
        <rect x="1" y="3" width="14" height="10" rx="5" fill="#e8003d"/>
        <rect x="17" y="3" width="14" height="10" rx="5" fill="#f4f4f4"/>
        <rect x="15" y="3" width="2" height="10" fill="#1a1c2c"/>
      </svg>
      <span style="font-family:'Press Start 2P',monospace;font-size:7px;color:#1a1e30;">RxPro · CRYPTOGRAPHY 2026</span>
    </div>
    <div style="display:flex;gap:5px;flex-wrap:wrap;">
      {['ECDSA','AES-GCM','HMAC','RFC8785'].map(t=>(
        <span style="font-family:'Press Start 2P',monospace;font-size:6px;padding:3px 7px;border:2px solid #29366f;color:#29366f;">{t}</span>
      ))}
    </div>
  </div>
</footer>

<!-- ═══ TOAST NOTIFICATION SLOT ══════════════════════════════════ -->
<div id="toast-container"></div>

<script>
  // ── Loader messages cycling ──────────────────────────────────
  const msgs = ['CARGANDO...','CONECTANDO...','CIFRANDO...','LISTO...']
  const el = document.getElementById('loader-msg')
  let mi = 0
  if (el) {
    const iv = setInterval(()=>{ el.textContent = msgs[++mi % msgs.length] }, 180)
    setTimeout(()=> clearInterval(iv), 780)
  }

  // ── Button loading state ─────────────────────────────────────
  document.querySelectorAll('form').forEach(form => {
    form.addEventListener('submit', e => {
      const btn = form.querySelector('button[type="submit"]')
      if (btn) {
        btn.classList.add('px-btn-loading')
        btn.textContent = 'PROCESANDO...'
      }
    })
  })

  // ── Toast helper (global) ────────────────────────────────────
  window.showToast = (msg, color = '#38b764') => {
    const t = document.createElement('div')
    t.className = 'px-toast'
    t.style.borderColor = color
    t.style.color = color
    t.textContent = msg
    document.getElementById('toast-container').appendChild(t)
    setTimeout(() => t.remove(), 2900)
  }
</script>

</body>
</html>
