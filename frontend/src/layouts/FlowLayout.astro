---
// Astro 5: import CSS in frontmatter so Vite processes it through
// the PostCSS/Tailwind pipeline — never use <link href="/src/...">
import '../styles/global.css'

interface Step { label: string; href?: string }
interface Props {
  title: string
  role: 'doctor' | 'pharmacy' | 'patient'
  steps: Step[]
  currentStep: number
  back?: string
  wide?: boolean
}
const { title, role, steps, currentStep, back, wide = false } = Astro.props
const rc = {
  doctor:   { color:'#38b764', dark:'#257a43', label:'MÉDICO',       ico:'doctor',      pillA:'#38b764', pillB:'white'    },
  pharmacy: { color:'#e8003d', dark:'#8c0025', label:'FARMACÉUTICO', ico:'pharmacist',  pillA:'#e8003d', pillB:'white'    },
  patient:  { color:'#41a6f6', dark:'#1a6eb0', label:'PACIENTE',     ico:'patient',     pillA:'#41a6f6', pillB:'#29366f'  },
}[role]

const pillPairs = [
  ['#e8003d','#f4f4f4'],['#41a6f6','#29366f'],['#38b764','#ffcd75'],
  ['#ffcd75','#e8003d'],['#f4f4f4','#41a6f6'],['#b13e53','#38b764'],
  ['#29366f','#f4f4f4'],['#38b764','#e8003d'],
]

// Precompute step styles in frontmatter to avoid Astro 4.x $$render bug
// with map-callback variables in JSX attributes
const stepData = steps.map((step, n) => {
  const done   = n < currentStep
  const active = n === currentStep
  return {
    label:     step.label,
    href:      step.href ?? '#',
    num:       String(n + 1),
    isDone:    done,
    isActive:  active,
    isLast:    n === steps.length - 1,
    aStyle:    'width:34px;height:34px;border:3px solid '+rc.color+';background:'+rc.color+';display:flex;align-items:center;justify-content:center;box-shadow:3px 3px 0 '+rc.dark+';text-decoration:none;',
    curStyle:  'width:34px;height:34px;border:3px solid #f4f4f4;background:'+rc.color+';display:flex;align-items:center;justify-content:center;box-shadow:3px 3px 0 '+rc.dark+";font-family:'Press Start 2P',monospace;font-size:10px;color:#1a1c2c;",
    spanStyle: "font-family:'Press Start 2P',monospace;font-size:6px;white-space:nowrap;color:"+(active?rc.color:done?'#5b6ee1':'#29366f')+';',
    lineStyle: 'flex:1;height:3px;background:'+(done?rc.color:'#29366f')+';min-width:6px;margin-bottom:18px;',
  }
})

// Precompute nav link styles (also avoids map-callback variable bug)
const navLinks = [
  {id:'doctor',   href:'/doctor',   label:'DR',  c:'#38b764', dark:'#257a43', ico:'doctor'},
  {id:'patient',  href:'/patient',  label:'PAC', c:'#41a6f6', dark:'#1a6eb0', ico:'patient'},
  {id:'pharmacy', href:'/pharmacy', label:'FAR', c:'#e8003d', dark:'#8c0025', ico:'pharmacist'},
].map(r => ({
  ...r,
  active: r.id === role,
  style: 'display:flex;align-items:center;gap:5px;padding:5px 8px;border:2px solid '+(r.id===role?r.c:'#29366f')+';background:'+(r.id===role?r.c+'22':'transparent')+';text-decoration:none;box-shadow:'+(r.id===role?'2px 2px 0 '+r.dark:'none')+';transition:all .05s;',
  spanStyle: "font-family:'Press Start 2P',monospace;font-size:7px;color:"+(r.id===role?r.c:'#c0cbdc')+';display:none;',
  onOver:  r.id!==role ? "this.style.borderColor='"+r.c+"';this.style.background='"+r.c+"15'" : '',
  onOut:   r.id!==role ? "this.style.borderColor='#29366f';this.style.background='transparent'" : '',
}))

// Precompute pill bg sprites
const pillSprites = pillPairs.flatMap(([a,b], pi) =>
  Array.from({length:3}, (_, ii) => {
    const n = pi*3+ii
    return {
      a, b,
      style: 'left:'+((n*6.1)%100)+'%;animation-duration:'+(8+(n*1.2)%10)+'s;animation-delay:'+((n*0.85)%9)+'s;',
      svgStyle: 'image-rendering:pixelated;transform:rotate('+((n*53)%360)+'deg);',
    }
  })
)

const mainWidth = 'width:100%;'+(wide?'max-width:1040px':'max-width:520px')+';'
const roleBadgeStyle = 'display:flex;align-items:center;gap:8px;padding:6px 12px;border:3px solid '+rc.color+';background:'+rc.dark+'25;box-shadow:3px 3px 0 '+rc.dark+';'
const roleLabelStyle = "font-family:'Press Start 2P',monospace;font-size:8px;color:"+rc.color+';'
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>{title} — RxPro</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 16'><rect x='1' y='3' width='14' height='10' rx='5' fill='%23e8003d'/><rect x='17' y='3' width='14' height='10' rx='5' fill='white'/></svg>"/>
  <style>
    .pill-bg { position:fixed;inset:0;pointer-events:none;overflow:hidden;z-index:0; }
    .pill-sprite { position:absolute;animation:pill-fall linear infinite;opacity:0; }
    .virus-ambient { position:absolute;animation:virus-wiggle ease-in-out infinite;opacity:.35; }
    .topbar { background:#0d0e1a;border-bottom:4px solid #070810;position:sticky;top:0;z-index:50; }
    .stepbar { background:#1a1e30;border-bottom:3px solid #0d0e1a; }
    .flow-main { flex:1;display:flex;flex-direction:column;align-items:center;padding:36px 16px;position:relative;z-index:1; }
    body::after { content:'';position:fixed;inset:0;pointer-events:none;z-index:9998;background:repeating-linear-gradient(0deg,rgba(0,0,0,.035),rgba(0,0,0,.035) 1px,transparent 1px,transparent 3px); }
  </style>
</head>
<body style="min-height:100vh;display:flex;flex-direction:column;">

<!-- ═══ SVG SPRITE SHEET ═══════════════════════════════════════════ -->
