<!-- ═══ ANIMATED BG ═══════════════════════════════════════════════ -->
<div class="pill-bg" aria-hidden="true">
  {pillSprites.map((ps) => (
    <div class="pill-sprite" style={ps.style}>
      <svg width="14" height="28" viewBox="0 0 32 16" style={ps.svgStyle}>
