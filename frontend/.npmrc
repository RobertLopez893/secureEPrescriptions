# Astro 6 todavía no está en el rango de peerDependencies de
# @astrojs/tailwind@5.1.4 (declara astro ^3 || ^4 || ^5). La integración
# funciona correctamente contra Astro 6 — no hay API que se haya roto —
# pero npm 7+ aborta la instalación por defecto. Migrar a la integración
# oficial de Tailwind 4 (@tailwindcss/vite) es trabajo separado; mientras
# tanto, este flag permite que `npm install` funcione sin fricción para
# nuevos colaboradores. Ver item 14 del hardening log.
legacy-peer-deps=true
