# ─────────────────────────────────────────────────────────────────────────────
# RxPro backend — configuración por entorno.
# Copia este archivo como `.env` y rellena los valores reales. NO subas `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# APP_ENV: "development" o "production".
#   development → siembra usuarios demo al arrancar + permite SECRET_KEY default.
#   production  → NO siembra nada + aborta si SECRET_KEY está vacío o es demo.
APP_ENV=development

# SECRET_KEY: clave para firmar JWT (HS256). Genera una con:
#   openssl rand -hex 32
# En producción es OBLIGATORIA y no puede ser el valor de ejemplo.
SECRET_KEY=change-me-run-openssl-rand-hex-32

# Tiempo de vida del access token (minutos).
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Base de datos ──────────────────────────────────────────────────────────
# Opción 1: URL completa (preferida). Si se define, gana sobre DB_* sueltas.
# Ejemplos:
#   postgresql+psycopg2://user:pass@host:5432/dbname
#   sqlite:///./rxpro.db
DATABASE_URL=postgresql+psycopg2://app_user:changeme@localhost:5432/e_prescriptions_db

# Opción 2: piezas sueltas (usadas por src/database/db_manager.py).
DB_USER=app_user
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432
DB_NAME=e_prescriptions_db

# ─── CORS ───────────────────────────────────────────────────────────────────
# Lista separada por comas de orígenes permitidos para el frontend.
# En desarrollo el default incluye localhost:4321 (Astro dev) y localhost:3000.
CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321

# ─── Semillas de usuarios demo (solo dev) ───────────────────────────────────
# 32 bytes hex (64 chars) cada una. Se usan para derivar la llave pública de
# los usuarios demo al primer arranque en development. Si se omiten, el
# backend genera semillas aleatorias y las imprime al stdout; en ese caso
# los QRs demo cambian en cada arranque. Define estas variables solo si
# quieres QRs demo estables entre reinicios. NUNCA se persisten en BD.
#DEMO_SEED_MEDICO=
#DEMO_SEED_PACIENTE=
#DEMO_SEED_FARMACEUTICO=
